# Database Connection
ConnectionStrings__DefaultConnection=Server=YOUR_SERVER;Database=YOUR_DB;Integrated Security=True;TrustServerCertificate=True;

# Gemini API
GeminiAPI__ApiKey=YOUR_GEMINI_API_KEY
GeminiAPI__ApiUrl=https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent

# Email Settings
EmailSettings__SmtpHost=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__SenderEmail=YOUR_SENDER_EMAIL
EmailSettings__SenderPassword=YOUR_SENDER_PASSWORD
EmailSettings__SenderName=YOUR_SENDER_NAME

# PayOS Settings
PayOS__ClientId=YOUR_PAYOS_CLIENT_ID
PayOS__ApiKey=YOUR_PAYOS_API_KEY
PayOS__ChecksumKey=YOUR_PAYOS_CHECKSUM_KEY
PayOS__ReturnUrl=https://localhost:7091/Payment/Success
PayOS__CancelUrl=https://localhost:7091/Payment/Cancel
