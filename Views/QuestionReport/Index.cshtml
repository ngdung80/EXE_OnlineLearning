@model List<POT_System_ASPNET.Data.Entities.QuestionReport>
@{
    ViewData["Title"] = "Báo cáo câu hỏi lỗi";
    var selectedStatus = ViewBag.SelectedStatus as string;
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
}
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .report-section {
        padding: 140px 15px 80px;
        font-family: 'Nunito', sans-serif !important;
        background: transparent;
        color: #1e1b4b;
    }
    .report-section *:not(i):not(.fa) {
        font-family: 'Nunito', sans-serif !important;
    }
    .page-title {
        font-weight: 900 !important;
        font-size: 2.4rem !important;
        background: linear-gradient(135deg, #ec6090 0%, #7c3aed 100%) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
        background-clip: text !important;
        margin-bottom: 12px !important;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .filter-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 30px;
        flex-wrap: wrap;
    }
    .filter-btn {
        padding: 10px 24px;
        border-radius: 20px;
        text-decoration: none !important;
        color: #4b5563 !important;
        border: 2px solid #f3f4f6 !important;
        background: rgba(255, 255, 255, 0.7) !important;
        font-weight: 800 !important;
        font-size: .9rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .filter-btn:hover {
        border-color: #ec6090 !important;
        color: #ec6090 !important;
        transform: translateY(-2px);
    }
    .filter-btn.active {
        background: linear-gradient(135deg, #ec6090 0%, #7c3aed 100%) !important;
        border-color: transparent !important;
        color: #fff !important;
    }
    
    .report-card {
        background: rgba(255, 255, 255, 0.9) !important;
        border: 3px solid #fbcfe8 !important;
        border-radius: 32px !important;
        padding: 30px;
        margin-bottom: 30px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        box-shadow: 0 15px 35px rgba(236, 96, 144, 0.04) !important;
        color: #1e1b4b;
    }
    .report-card:hover {
        transform: translateY(-5px) !important;
        border-color: #ec6090 !important;
        box-shadow: 0 20px 40px rgba(236, 96, 144, 0.12) !important;
    }
    .report-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #f3f4f6;
        padding-bottom: 15px;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 10px;
    }
    .report-meta {
        font-size: .95rem;
        color: #4b5563;
    }
    .badge-pending {
        background: rgba(245, 158, 11, 0.1) !important;
        color: #d97706 !important;
        border: 2px solid rgba(245, 158, 11, 0.2) !important;
        padding: 6px 16px;
        border-radius: 999px;
        font-size: .85rem;
        font-weight: 800;
    }
    .badge-reviewed {
        background: rgba(59, 130, 246, 0.1) !important;
        color: #2563eb !important;
        border: 2px solid rgba(59, 130, 246, 0.2) !important;
        padding: 6px 16px;
        border-radius: 999px;
        font-size: .85rem;
        font-weight: 800;
    }
    .badge-resolved {
        background: rgba(16, 185, 129, 0.1) !important;
        color: #059669 !important;
        border: 2px solid rgba(16, 185, 129, 0.2) !important;
        padding: 6px 16px;
        border-radius: 999px;
        font-size: .85rem;
        font-weight: 800;
    }
    
    .reason-box {
        background: rgba(239, 68, 68, 0.05) !important;
        border-left: 5px solid #ef4444 !important;
        padding: 18px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: .95rem;
        font-weight: 600;
    }
    
    .question-box {
        background: #fafafa;
        border: 2px solid #f3f4f6;
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 20px;
    }
    .question-content {
        font-weight: 800;
        font-size: 1.05rem;
        margin-bottom: 12px;
        color: #1e1b4b;
    }
    .option-list {
        list-style: none;
        padding-left: 0;
        margin-bottom: 0;
        font-size: .95rem;
    }
    .option-item {
        padding: 10px 16px;
        background: #ffffff;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 8px;
        font-weight: 600;
    }
    .option-correct {
        border-color: #a7f3d0 !important;
        background: #ecfdf5 !important;
        color: #065f46 !important;
    }
    
    .action-panel {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }
    .btn-action {
        padding: 10px 20px;
        border-radius: 16px;
        font-size: .9rem;
        font-weight: 800;
        text-decoration: none !important;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .btn-review {
        background: rgba(59, 130, 246, 0.1);
        color: #2563eb;
        border: 2px solid rgba(59, 130, 246, 0.2);
    }
    .btn-review:hover {
        background: rgba(59, 130, 246, 0.2);
        transform: translateY(-2px);
    }
    .btn-fix {
        background: linear-gradient(135deg, #ec6090, #e75485) !important;
        color: #fff !important;
        box-shadow: 0 8px 20px rgba(236, 96, 144, 0.15);
    }
    .btn-fix:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 25px rgba(236, 96, 144, 0.25);
    }
    
    .form-control, .form-select {
        background: #ffffff !important;
        border: 2px solid #e5e7eb !important;
        color: #1e1b4b !important;
        border-radius: 14px !important;
        padding: 12px 16px !important;
        width: 100%;
        font-size: .95rem !important;
        font-weight: 600 !important;
        transition: all 0.2s;
    }
    .form-control:focus, .form-select:focus {
        border-color: #ec6090 !important;
        outline: none;
        box-shadow: 0 0 0 4px rgba(236, 96, 144, 0.1) !important;
    }
    
    .panel-form {
        background: #fdf2f8;
        border: 2px dashed #fbcfe8;
        padding: 24px;
        border-radius: 20px;
        margin-top: 15px;
        display: none;
    }
</style>

<section class="report-section">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-exclamation-triangle"></i> Báo cáo câu hỏi lỗi</h1>
        <p style="color:#4b5563; font-weight: 600; margin-bottom:30px;">Xem xét và khắc phục các câu hỏi bị học sinh báo lỗi do lỗi chính tả, sai đáp án hoặc công thức tính toán.</p>

        <!-- Filters -->
        <div class="filter-bar">
            <a asp-action="Index" asp-route-status="" class="filter-btn @(string.IsNullOrEmpty(selectedStatus) ? "active" : "")">Tất cả báo cáo</a>
            <a asp-action="Index" asp-route-status="Pending" class="filter-btn @(selectedStatus == "Pending" ? "active" : "")">Chờ xử lý</a>
            <a asp-action="Index" asp-route-status="Reviewed" class="filter-btn @(selectedStatus == "Reviewed" ? "active" : "")">Đã xem xét</a>
            <a asp-action="Index" asp-route-status="Resolved" class="filter-btn @(selectedStatus == "Resolved" ? "active" : "")">Đã khắc phục</a>
        </div>

        @if (Model != null && Model.Any())
        {
            foreach (var r in Model)
            {
                string statusText = r.Status == "Pending" ? "Chờ xử lý" : r.Status == "Reviewed" ? "Đã xem xét" : "Đã khắc phục";
                string badgeClass = r.Status == "Pending" ? "badge-pending" : r.Status == "Reviewed" ? "badge-reviewed" : "badge-resolved";
                <div class="report-card">
                    <div class="report-header">
                        <div class="report-meta">
                            <strong>Báo cáo #@r.ReportId</strong> &bull; Người báo cáo: <strong>@r.Reporter?.FullName</strong> vào lúc @(r.CreatedAt.HasValue ? r.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")
                        </div>
                        <span class="@badgeClass">● @statusText</span>
                    </div>

                    <div class="reason-box">
                        <strong>Lý do lỗi:</strong> @r.Reason
                    </div>

                    <div class="question-box">
                        <div class="question-content">
                            @r.Question?.QuestionContent
                        </div>
                        <ul class="option-list">
                            @{
                                var opts = r.Question?.Answer?.Split(',').Select(o => o.Trim()).ToArray() ?? new string[0];
                                foreach (var opt in opts)
                                {
                                    bool isCorrect = opt.Equals(r.Question?.CorrectAnswer, StringComparison.OrdinalIgnoreCase);
                                    <li class="option-item @(isCorrect ? "option-correct" : "")">
                                        @if (isCorrect) { <span><i class="fas fa-check-circle"></i> </span> }
                                        @opt
                                    </li>
                                }
                            }
                        </ul>
                    </div>

                    @if (!string.IsNullOrEmpty(r.ReviewNote))
                    {
                        <div style="background:rgba(255,255,255,.02); padding:15px; border-radius:8px; margin-bottom:20px; border:1px dashed rgba(255,255,255,.1); font-size:.9rem;">
                            <strong>Ghi chú phản hồi:</strong> @r.ReviewNote
                        </div>
                    }

                    @if (r.Status != "Resolved")
                    {
                        <div class="action-panel">
                            <button type="button" class="btn-action btn-review" onclick="toggleForm('reviewForm-@r.ReportId')">
                                <i class="fas fa-eye"></i> Đánh dấu đã xem
                            </button>
                            <button type="button" class="btn-action btn-fix" onclick="toggleForm('fixForm-@r.ReportId')">
                                <i class="fas fa-wrench"></i> Sửa đề & Đóng báo cáo
                            </button>
                        </div>

                        <!-- Review Form -->
                        <div class="panel-form" id="reviewForm-@r.ReportId">
                            <form asp-action="Review" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.ReportId" />
                                <input type="hidden" name="status" value="Reviewed" />
                                <div class="mb-3">
                                    <label class="form-label" style="font-weight: 800; color: #1e1b4b;">Ghi chú phản hồi</label>
                                    <textarea name="reviewNote" class="form-control" rows="2" placeholder="Ví dụ: Báo cáo chính xác, đang kiểm tra để sửa lại..."></textarea>
                                </div>
                                <button type="submit" class="btn-action btn-review">Lưu phản hồi</button>
                            </form>
                        </div>

                        <!-- Fix Form -->
                        <div class="panel-form" id="fixForm-@r.ReportId">
                            <form asp-action="EditQuestion" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="reportId" value="@r.ReportId" />
                                <input type="hidden" name="questionId" value="@r.QuestionId" />
                                <div class="mb-3">
                                    <label class="form-label" style="font-weight: 800; color: #1e1b4b;">Nội dung câu hỏi</label>
                                    <textarea name="questionContent" class="form-control" rows="3" required>@r.Question?.QuestionContent</textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label" style="font-weight: 800; color: #1e1b4b;">Các lựa chọn (Ngăn cách bằng dấu phẩy)</label>
                                    <input type="text" name="answer" class="form-control" value="@r.Question?.Answer" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label" style="font-weight: 800; color: #1e1b4b;">Nội dung đáp án đúng</label>
                                    <input type="text" name="correctAnswer" class="form-control" value="@r.Question?.CorrectAnswer" required />
                                </div>
                                <button type="submit" class="btn-action btn-fix">💾 Lưu câu hỏi & Giải quyết báo cáo</button>
                            </form>
                        </div>
                    }
                </div>
            }

            <!-- Pagination -->
            if (totalPages > 1)
            {
                <div class="d-flex justify-content-center gap-2 mt-4">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <a asp-action="Index" asp-route-status="@selectedStatus" asp-route-page="@i" class="filter-btn @(i == currentPage ? "active" : "")" style="padding:6px 14px;">@i</a>
                    }
                </div>
            }
        }
        else
        {
            <div class="text-center py-5" style="background:rgba(255,255,255,0.9); border-radius:32px; border:3px dashed #fbcfe8;">
                <div style="font-size:3rem; margin-bottom:15px; opacity:.8;">🎉</div>
                <p style="color:#4b5563; font-weight: 800; font-size:1.2rem;">Không tìm thấy báo cáo nào cho trạng thái "@(selectedStatus ?? "Tất cả")". Tuyệt vời!</p>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        function toggleForm(formId) {
            const form = document.getElementById(formId);
            const isVisible = form.style.display === 'block';
            
            // Close all forms
            document.querySelectorAll('.panel-form').forEach(f => f.style.display = 'none');
            
            if (!isVisible) {
                form.style.display = 'block';
            }
        }
    </script>
}