@{
    ViewData["Title"] = "Đổi mật khẩu";
}
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<style>
    .pwd-section {
        padding: 140px 0 80px;
        background: transparent !important;
        min-height: 80vh;
        position: relative;
        overflow: hidden;
        font-family: 'Nunito', sans-serif !important;
        color: #1e1b4b;
    }
    .pwd-section *:not(i):not(.fa) {
        font-family: 'Nunito', sans-serif !important;
    }

    .pwd-card {
        background: rgba(255, 255, 255, 0.88) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        border: 4px solid #fbcfe8 !important;
        border-radius: 35px !important;
        overflow: hidden !important;
        box-shadow: 0 15px 35px rgba(236, 96, 144, 0.08) !important;
        position: relative;
        z-index: 10;
        padding: 40px;
        color: #1e1b4b !important;
    }

    .pwd-card h2 { color:#ec6090; font-weight:900; margin-bottom:30px; font-size:2.2rem; }
    .form-label { color:#4f46e5; font-size:.95rem; font-weight: 800; }
    .form-control { background:#ffffff !important; border: 2px solid #e5e7eb !important; color:#1e1b4b; border-radius:15px; padding:12px 15px; width:100%; font-size:14px; transition:all .3s; font-weight: 700; }
    .form-control:focus { background:#fff; border-color:#ec6090; box-shadow: 0 0 0 4px rgba(236, 96, 144, 0.1) !important; outline:none; color:#1e1b4b; }
    .form-control::placeholder { color:#a5b4fc; }
    
    .input-wrap { position:relative; }
    .input-wrap i { position:absolute; right:15px; top:50%; transform:translateY(-50%); color:#64748b; cursor:pointer; }
    
    .btn-save { padding:12px 30px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff !important; border:none; border-radius:25px; font-weight:800; cursor:pointer; transition:all .3s cubic-bezier(0.175, 0.885, 0.32, 1.275); box-shadow: 0 5px 15px rgba(236, 96, 144, 0.2); width:100%; }
    .btn-save:hover { transform:translateY(-2px) scale(1.02); box-shadow:0 8px 20px rgba(236,96,144,.4); }
    
    .msg { padding:12px; border-radius:10px; margin-bottom:20px; font-size:.9rem; font-weight:700; }
    .msg-error { background:rgba(239,68,68,.15); border:1px solid #ef4444; color:#ef4444; }
    .msg-success { background:rgba(16,185,129,.15); border:1px solid #10b981; color:#10b981; }
    .strength-bar { height:4px; border-radius:2px; margin-top:5px; transition:all .3s; }
    .req-item { font-size:.8rem; color:#64748b; margin-top:4px; font-weight: 600; }
    .req-ok { color:#10b981; }

    .kid-bg-cloud {
        position: absolute;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 100px;
        pointer-events: none;
        z-index: 1;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02);
    }
    .kid-bg-cloud::before, .kid-bg-cloud::after {
        content: '';
        position: absolute;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 50%;
    }
    .kid-bg-cloud.c1 {
        width: 120px; height: 40px; top: 12%; left: 8%;
        animation: floatCloud 24s linear infinite;
    }
    .kid-bg-cloud.c1::before { width: 50px; height: 50px; top: -25px; left: 15px; }
    .kid-bg-cloud.c1::after { width: 70px; height: 70px; top: -35px; right: 15px; }

    .kid-bg-cloud.c2 {
        width: 160px; height: 50px; bottom: 15%; right: 8%;
        animation: floatCloudReverse 28s linear infinite;
    }
    .kid-bg-cloud.c2::before { width: 70px; height: 70px; top: -35px; left: 20px; }
    .kid-bg-cloud.c2::after { width: 90px; height: 90px; top: -45px; right: 20px; }

    @@keyframes floatCloud {
        0% { transform: translateX(0); }
        50% { transform: translateX(50px); }
        100% { transform: translateX(0); }
    }
    @@keyframes floatCloudReverse {
        0% { transform: translateX(0); }
        50% { transform: translateX(-50px); }
        100% { transform: translateX(0); }
    }

    .kid-bg-star {
        position: absolute;
        font-size: 2.5rem;
        color: #f59e0b;
        opacity: 0.35;
        pointer-events: none;
        z-index: 5;
    }
    .kid-bg-star.s1 { top: 15%; right: 12%; animation: orbitRight 14s ease-in-out infinite alternate; }
    .kid-bg-star.s2 { bottom: 18%; left: 10%; animation: orbitLeft 17s ease-in-out infinite alternate; color: #fbbf24; }
    .kid-bg-star.s3 { top: 45%; left: 6%; animation: floatAroundVertical 11s ease-in-out infinite alternate; font-size: 1.8rem; color: #fca5a5; }
    .kid-bg-star.s4 { bottom: 40%; right: 6%; animation: floatAroundHorizontal 15s ease-in-out infinite alternate; font-size: 2rem; color: #38bdf8; }
    .kid-bg-star.s5 { top: 10%; left: 25%; animation: diagonalFloat 20s ease-in-out infinite alternate; font-size: 1.6rem; color: #c084fc; }

    @@keyframes orbitRight {
        0% { transform: translate(0, 0) rotate(0deg) scale(1); }
        35% { transform: translate(45px, -70px) rotate(120deg) scale(1.25); }
        70% { transform: translate(-30px, -120px) rotate(240deg) scale(0.8); }
        100% { transform: translate(0, 0) rotate(360deg) scale(1); }
    }
    @@keyframes orbitLeft {
        0% { transform: translate(0, 0) rotate(360deg) scale(0.9); }
        40% { transform: translate(-60px, 50px) rotate(180deg) scale(1.3); }
        80% { transform: translate(40px, -40px) rotate(0deg) scale(0.7); }
        100% { transform: translate(0, 0) rotate(-360deg) scale(0.9); }
    }
    @@keyframes floatAroundVertical {
        0% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-90px) rotate(180deg); }
        100% { transform: translateY(0) rotate(360deg); }
    }
    @@keyframes floatAroundHorizontal {
        0% { transform: translateX(0) rotate(0deg); }
        50% { transform: translateX(90px) rotate(-180deg); }
        100% { transform: translateX(0) rotate(-360deg); }
    }
    @@keyframes diagonalFloat {
        0% { transform: translate(0, 0) rotate(0deg); }
        50% { transform: translate(80px, 80px) rotate(180deg); }
        100% { transform: translate(0, 0) rotate(360deg); }
    }
</style>

<section class="pwd-section">
    <!-- Clouds -->
    <div class="kid-bg-cloud c1"></div>
    <div class="kid-bg-cloud c2"></div>

    <!-- Stars -->
    <div class="kid-bg-star s1">⭐</div>
    <div class="kid-bg-star s2">✨</div>
    <div class="kid-bg-star s3">🌟</div>
    <div class="kid-bg-star s4">⭐</div>
    <div class="kid-bg-star s5">✨</div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5">
                <div class="pwd-card">
                    <h2>🔑 Đổi mật khẩu</h2>
                    @if (ViewBag.Error != null) { <div class="msg msg-error">@ViewBag.Error</div> }
                    @if (ViewBag.Success != null) { <div class="msg msg-success">@ViewBag.Success</div> }

                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu hiện tại</label>
                            <div class="input-wrap">
                                <input type="password" name="currentPassword" id="curPwd" class="form-control" placeholder="Nhập mật khẩu hiện tại" required>
                                <i class="fas fa-eye" onclick="toggle('curPwd',this)"></i>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <div class="input-wrap">
                                <input type="password" name="newPassword" id="newPwd" class="form-control" placeholder="Tối thiểu 8 ký tự" required oninput="checkStrength(this)">
                                <i class="fas fa-eye" onclick="toggle('newPwd',this)"></i>
                            </div>
                            <div class="strength-bar" id="strengthBar"></div>
                            <div id="pwdReqs" style="margin-top:6px;">
                                <div class="req-item" id="req-len"> ✗ Ít nhất 8 ký tự</div>
                                <div class="req-item" id="req-upper"> ✗ Có chữ in hoa</div>
                                <div class="req-item" id="req-lower"> ✗ Có chữ thường</div>
                                <div class="req-item" id="req-num"> ✗ Có chữ số</div>
                                <div class="req-item" id="req-special"> ✗ Có ký tự đặc biệt (@@, $, !, %, *, ?, &)</div>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Xác nhận mật khẩu mới</label>
                            <div class="input-wrap">
                                <input type="password" name="confirmPassword" id="confPwd" class="form-control" placeholder="Nhập lại mật khẩu mới" required>
                                <i class="fas fa-eye" onclick="toggle('confPwd',this)"></i>
                            </div>
                        </div>
                        <button type="submit" class="btn-save">🔐 Đổi mật khẩu</button>
                        <div class="text-center mt-3">
                            <a asp-action="Profile" style="color:#94a3b8;text-decoration:none;font-size:.9rem;">← Quay lại thông tin cá nhân</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    function toggle(id, icon) {
        const input = document.getElementById(id);
        input.type = input.type === 'password' ? 'text' : 'password';
        icon.classList.toggle('fa-eye'); icon.classList.toggle('fa-eye-slash');
    }
    function checkStrength(input) {
        const v = input.value;
        const reqs = {
            'req-len': v.length >= 8,
            'req-upper': /[A-Z]/.test(v),
            'req-lower': /[a-z]/.test(v),
            'req-num': /\d/.test(v),
            'req-special': /[@@$!%*?&]/.test(v)
        };
        let score = 0;
        Object.entries(reqs).forEach(([id, ok]) => {
            const el = document.getElementById(id);
            el.textContent = (ok ? '✓ ' : '✗ ') + el.textContent.slice(2);
            el.className = 'req-item' + (ok ? ' req-ok' : '');
            if (ok) score++;
        });
        const bar = document.getElementById('strengthBar');
        const colors = ['#ef4444','#f97316','#eab308','#22c55e','#10b981'];
        bar.style.width = (score * 20) + '%';
        bar.style.background = colors[score - 1] || '#ef4444';
    }
</script>
}
