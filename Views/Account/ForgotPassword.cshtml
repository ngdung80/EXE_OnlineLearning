@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quên mật khẩu - PLO Learning</title>
    <link href="~/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
        body { background:linear-gradient(135deg,#f9e8e8,#f4d4d4); font-family:'Inter',sans-serif; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:20px; }
        .card { background:#fff; border-radius:20px; padding:40px; box-shadow:0 8px 30px rgba(0,0,0,.1); width:100%; max-width:460px; }
        .card img { width:130px; display:block; margin:0 auto 20px; }
        h2 { color:#2a0040; font-weight:700; text-align:center; margin-bottom:25px; }
        .form-control { border:1px solid #e0e0e0; border-radius:10px; padding:12px 15px; font-size:14px; width:100%; transition:all .3s; }
        .form-control:focus { border-color:#e75485; outline:none; box-shadow:0 0 8px rgba(231,84,133,.2); }
        .btn-main { background:#e75485; border:none; width:100%; padding:12px; border-radius:25px; color:#fff; font-weight:600; cursor:pointer; transition:all .3s; }
        .btn-main:hover { background:#c63e6b; transform:translateY(-2px); }
        .msg-error { background:#ffe6e6; color:#d43f6f; border:1px solid #d43f6f; padding:10px; border-radius:8px; margin-bottom:15px; font-size:13px; }
        .msg-success { background:#e6f4e6; color:#28a745; border:1px solid #28a745; padding:10px; border-radius:8px; margin-bottom:15px; font-size:13px; }
        .step { display:none; }
        .step.active { display:block; }
        .back-link { text-align:center; margin-top:15px; }
        .back-link a { color:#e75485; text-decoration:none; font-size:14px; }
    </style>
</head>
<body>
    <div class="card">
        <img src="~/assets/images/logo.png" alt="Logo">
        <h2>Quên mật khẩu</h2>

        @if (ViewBag.Error != null) { <div class="msg-error">@ViewBag.Error</div> }
        @if (ViewBag.Success != null) { <div class="msg-success">@ViewBag.Success</div> }

        <!-- Step 1: Enter email & send code -->
        @if (ViewBag.EmailSent == null && ViewBag.Success == null)
        {
            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="step" value="send">
                <div class="mb-3">
                    <label style="font-weight:500;font-size:14px;">Email của bạn</label>
                    <input type="email" name="email" id="emailInput" class="form-control" placeholder="Nhập email đã đăng ký" required>
                </div>
                <button type="submit" class="btn-main">Gửi mã xác thực</button>
                <div class="back-link"><a asp-action="Login">← Quay lại đăng nhập</a></div>
            </form>
        }

        <!-- Step 2: Enter code + new password -->
        @if (ViewBag.EmailSent != null)
        {
            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="step" value="verify">
                <input type="hidden" name="email" value="@ViewBag.Email">
                <div class="mb-3">
                    <label style="font-weight:500;font-size:14px;">Mã xác thực</label>
                    <input type="text" name="verificationCode" class="form-control" placeholder="Nhập mã 6 chữ số" required>
                </div>
                <div class="mb-3">
                    <label style="font-weight:500;font-size:14px;">Mật khẩu mới</label>
                    <input type="password" name="newPassword" class="form-control" placeholder="Tối thiểu 8 ký tự" required>
                </div>
                <div class="mb-3">
                    <label style="font-weight:500;font-size:14px;">Xác nhận mật khẩu mới</label>
                    <input type="password" name="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" required>
                </div>
                <button type="submit" class="btn-main">Đặt lại mật khẩu</button>
                <div class="back-link"><a asp-action="Login">← Quay lại đăng nhập</a></div>
            </form>
        }
    </div>
</body>
</html>
