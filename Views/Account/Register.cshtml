@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký - PLO Learning</title>
    <link href="~/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { background:linear-gradient(135deg,#f9e8e8,#f4d4d4); font-family:'Inter',sans-serif; color:#2a0040; display:flex; flex-direction:column; align-items:center; min-height:100vh; padding:20px; }
        .header-area { background:#fff; position:fixed; top:0; left:0; width:100%; z-index:1000; padding:10px 0; box-shadow:0 2px 10px rgba(0,0,0,.05); }
        .main-nav { display:flex; align-items:center; justify-content:space-between; padding:0 20px; }
        .main-nav .logo img { height:40px; }
        .main-nav .nav { list-style:none; display:flex; margin:0; padding:0; }
        .main-nav .nav li { margin-left:25px; }
        .main-nav .nav li a { color:#e75485; text-decoration:none; font-weight:500; }
        .register-container { background:url('/assets/images/cosmic-login-bg.jpg') no-repeat center center; background-size:cover; padding:2.5rem; border-radius:20px; box-shadow:0 8px 20px rgba(0,0,0,.1); width:100%; max-width:670px; margin-top:80px; margin-bottom:40px; text-align:center; position:relative; animation:fadeIn .5s ease-in-out; }
        .register-container::before { content:''; position:absolute; top:0; left:0; width:100%; height:100%; background:rgba(255,255,255,.85); border-radius:20px; z-index:1; }
        .register-content { position:relative; z-index:2; }
        .register-content img { width:180px; margin-bottom:1rem; }
        @@keyframes fadeIn { from{opacity:0;transform:translateY(20px);} to{opacity:1;transform:translateY(0);} }
        h2 { color:#2a0040; font-weight:600; font-size:28px; margin-bottom:1.5rem; }
        .form-group { margin-bottom:1.5rem; text-align:left; }
        .form-group label { color:#2a0040; font-weight:500; font-size:14px; margin-bottom:.5rem; display:block; }
        .form-control { background:#fff; border:1px solid #e0e0e0; color:#333; border-radius:10px; padding:12px 15px 12px 45px; width:100%; font-size:14px; transition:all .3s; }
        .form-control:focus { border-color:#e75485; box-shadow:0 0 8px rgba(231,84,133,.2); outline:none; }
        .input-group { position:relative; display:flex; align-items:center; }
        .input-group i { position:absolute; left:15px; top:50%; transform:translateY(-50%); color:#e75485; z-index:3; }
        .role-options { display:flex; flex-wrap:wrap; gap:15px; margin-bottom:1.5rem; }
        .role-options label { display:flex; align-items:center; font-size:14px; cursor:pointer; position:relative; padding-left:30px; }
        .role-options input[type="radio"] { display:none; }
        .role-options label::before { content:''; position:absolute; left:0; top:50%; transform:translateY(-50%); width:18px; height:18px; border:2px solid #e75485; border-radius:50%; background:#fff; transition:all .3s; }
        .role-options input[type="radio"]:checked + label::before { background:#e75485; box-shadow:inset 0 0 0 3px #fff; }
        .verification-group { background:#f9e8e8; padding:15px; border:1px solid #e75485; border-radius:10px; margin-bottom:1.5rem; }
        .verification-note { color:#2a0040; font-size:12px; margin-top:.5rem; }
        .btn-primary { background:#e75485; border:none; padding:12px; width:100%; font-weight:500; border-radius:30px; font-size:15px; color:#fff; cursor:pointer; transition:all .3s; }
        .btn-primary:hover { background:#c63e6b; transform:translateY(-2px); }
        .btn-send { width:auto; padding:8px 20px; }
        .btn-link { color:#e75485; text-decoration:none; font-size:14px; font-weight:500; }
        .error-message { background:#ffe6e6; color:#d43f6f; border:1px solid #d43f6f; padding:10px; border-radius:8px; margin-bottom:15px; font-size:13px; }
        .success-message { background:#e6f4e6; color:#28a745; border:1px solid #28a745; padding:10px; border-radius:8px; margin-bottom:15px; font-size:13px; }
        #contentManagerFields { display:none; }
    </style>
</head>
<body>
    <header class="header-area">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <nav class="main-nav">
                        <a asp-controller="Home" asp-action="Index" class="logo" style="display:flex;align-items:center;gap:8px;text-decoration:none;">
                            <img src="~/assets/images/logo.png" asp-append-version="true" alt="PLO Logo" style="height:35px;width:35px;object-fit:contain;">
                            <span class="logo-text" style="font-family:'Inter',sans-serif;font-weight:900;font-size:22px;color:#e75485;text-transform:uppercase;letter-spacing:1px;">PLO</span>
                        </a>
                        <ul class="nav">
                            <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                            <li><a asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </header>

    <div class="register-container">
        <div class="register-content">
            @if (ViewBag.Error != null) { <div class="error-message">@ViewBag.Error</div> }
            @if (ViewBag.Success != null) { <div class="success-message">@ViewBag.Success</div> }

            <h2>Đăng ký tài khoản</h2>
            <img src="~/assets/images/logo.png" asp-append-version="true" alt="PLO Logo" style="width:80px;height:80px;object-fit:contain;margin-bottom:1rem;">

            <form id="registerForm" asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <!-- Role Selection -->
                <div class="form-group">
                    <label>Chọn vai trò:</label>
                    <div class="role-options">
                        <input type="radio" name="role" value="Mentee" id="role-mentee" onchange="toggleRole('Mentee')" checked>
                        <label for="role-mentee">Học sinh</label>
                        <input type="radio" name="role" value="Parent" id="role-parent" onchange="toggleRole('Parent')">
                        <label for="role-parent">Phụ huynh</label>
                        <input type="radio" name="role" value="Content Manager" id="role-cm" onchange="toggleRole('Content Manager')">
                        <label for="role-cm">Quản lý nội dung</label>
                    </div>
                </div>
                <!-- Username -->
                <div class="form-group">
                    <label>Tên đăng nhập</label>
                    <div class="input-group">
                        <i class="fas fa-user"></i>
                        <input type="text" name="username" id="username" class="form-control" placeholder="6–20 ký tự, chữ/số/dấu gạch dưới" required>
                    </div>
                </div>
                <!-- Email -->
                <div class="form-group">
                    <label>Email</label>
                    <div class="input-group">
                        <i class="fas fa-envelope"></i>
                        <input type="email" name="email" id="regEmail" class="form-control" placeholder="Nhập email" required>
                    </div>
                </div>
                <!-- Password -->
                <div class="form-group">
                    <label>Mật khẩu</label>
                    <div class="input-group">
                        <i class="fas fa-lock"></i>
                        <input type="password" name="password" id="regPassword" class="form-control" placeholder="Tối thiểu 8 ký tự, gồm chữ hoa, chữ thường, số và ký tự đặc biệt" required>
                    </div>
                </div>
                <!-- Confirm Password -->
                <div class="form-group">
                    <label>Xác nhận mật khẩu</label>
                    <div class="input-group">
                        <i class="fas fa-lock"></i>
                        <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" required>
                    </div>
                </div>
                <!-- Full Name -->
                <div class="form-group">
                    <label>Họ và tên</label>
                    <div class="input-group">
                        <i class="fas fa-id-card"></i>
                        <input type="text" name="fullName" class="form-control" placeholder="Nhập họ và tên" required>
                    </div>
                </div>
                <!-- Phone -->
                <div class="form-group">
                    <label>Số điện thoại</label>
                    <div class="input-group">
                        <i class="fas fa-phone"></i>
                        <input type="text" name="phone" class="form-control" placeholder="10 chữ số bắt đầu bằng số 0">
                    </div>
                </div>
                <!-- DOB -->
                <div class="form-group">
                    <label>Ngày sinh</label>
                    <div class="input-group">
                        <i class="fas fa-calendar-alt"></i>
                        <input type="date" name="dob" class="form-control" required>
                    </div>
                </div>
                <!-- Specialization (Content Manager only) -->
                <div class="form-group" id="contentManagerFields">
                    <label>Chuyên môn</label>
                    <div class="input-group">
                        <i class="fas fa-briefcase"></i>
                        <input type="text" name="specialization" class="form-control" placeholder="Chuyên môn giảng dạy của bạn">
                    </div>
                </div>
                <!-- Verification Code -->
                <div class="form-group verification-group">
                    <label>Mã xác thực</label>
                    <div class="input-group">
                        <i class="fas fa-key"></i>
                        <input type="text" name="verificationCode" id="verificationCode" class="form-control" placeholder="Nhập mã 6 chữ số" required>
                    </div>
                    <p class="verification-note">Nhập mã xác thực gồm 6 chữ số được gửi đến email của bạn. Hết hạn sau 5 phút.</p>
                    <button type="button" id="btnSendCode" class="btn btn-primary btn-send mt-2" onclick="sendCode()">Gửi mã</button>
                    <span id="codeStatus" style="font-size:12px;margin-left:10px;color:#28a745;"></span>
                </div>

                <button type="submit" id="registerBtn" class="btn btn-primary">Đăng ký</button>
                <p class="mt-3">Đã có tài khoản? <a asp-action="Login" class="btn-link">Đăng nhập ngay</a></p>
            </form>
        </div>
    </div>

    <script>
        function toggleRole(role) {
            document.getElementById('contentManagerFields').style.display = (role === 'Content Manager') ? 'block' : 'none';
        }

        async function sendCode() {
            const email = document.getElementById('regEmail').value;
            if (!email || !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
                alert('Vui lòng nhập email hợp lệ trước.');
                return;
            }
            const btn = document.getElementById('btnSendCode');
            btn.disabled = true;
            btn.textContent = 'Đang gửi...';
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const res = await fetch('/Account/SendVerificationCode', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({ email })
                });
                const data = await res.json();
                if (data.success) {
                    document.getElementById('codeStatus').textContent = '✓ Đã gửi mã! Vui lòng kiểm tra email.';
                    let sec = 60;
                    const timer = setInterval(() => {
                        btn.textContent = `Gửi lại (${--sec}s)`;
                        if (sec <= 0) { clearInterval(timer); btn.disabled = false; btn.textContent = 'Gửi mã'; }
                    }, 1000);
                } else {
                    document.getElementById('codeStatus').textContent = '✗ Thất bại: ' + data.message;
                    document.getElementById('codeStatus').style.color = '#d43f6f';
                    btn.disabled = false;
                    btn.textContent = 'Gửi mã';
                }
            } catch (e) {
                btn.disabled = false; btn.textContent = 'Gửi mã';
                document.getElementById('codeStatus').textContent = '✗ Lỗi khi gửi mã';
            }
        }
    </script>
</body>
</html>
