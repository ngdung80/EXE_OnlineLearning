@model POT_System_ASPNET.Data.Entities.User
@{
    ViewData["Title"] = "Cửa hàng Ảnh nền VIP";
    var unlocked = ViewBag.UnlockedAvatars as List<string> ?? new List<string>();
    var equipped = ViewBag.EquippedAvatar as string;
    int availableStars = ViewBag.AvailableStars;
    int totalEarned = ViewBag.TotalEarnedStars;

    // Define shop items
    var items = new[]
    {
        new { Id = "VIP_1", Name = "Mầm non Tinh tú", Emoji = "⭐", Cost = 400, Description = "Khung sao tinh tú lấp lánh xoay vòng, thích hợp cho bé thích sự rực rỡ!" },
        new { Id = "VIP_2", Name = "Thủy thủ Đại dương", Emoji = "🌊", Cost = 800, Description = "Sóng biển rì rào cùng những bong bóng nước xanh mát mẻ." },
        new { Id = "VIP_3", Name = "Chiến binh Công nghệ", Emoji = "🤖", Cost = 1200, Description = "Mạng lưới cyber neon quét liên tục cực chất cho các bạn nhỏ mê robot." },
        new { Id = "VIP_4", Name = "Phượng hoàng Lửa", Emoji = "🔥", Cost = 1600, Description = "Ngọn lửa bốc cháy bùng bùng tràn đầy năng lượng và lòng quyết tâm!" },
        new { Id = "VIP_5", Name = "Chúa tể Vũ trụ", Emoji = "🌌", Cost = 2000, Description = "Hố đen tinh vân ảo diệu lôi cuốn, quyền lực nhất dải ngân hà." }
    };
}

<style>
    .shop-section {
        padding: 130px 0 80px;
        min-height: 90vh;
        font-family: 'Inter', sans-serif !important;
        position: relative;
        overflow: hidden;
    }
    .shop-section *:not(i):not(.fa) {
        font-family: 'Inter', sans-serif !important;
    }

    .btn-shop-back-profile {
        display: inline-block;
        background: linear-gradient(135deg, #ec6090, #e75485) !important;
        color: #ffffff !important;
        border: none !important;
        border-radius: 99px !important;
        font-weight: 700 !important;
        font-size: 1rem;
        padding: 10px 35px;
        box-shadow: 0 5px 15px rgba(236, 96, 144, 0.2) !important;
        text-decoration: none !important;
        transition: all 0.3s ease;
    }
    .btn-shop-back-profile:hover {
        transform: translateY(-3px) scale(1.03) !important;
        box-shadow: 0 8px 25px rgba(236, 96, 144, 0.35) !important;
        color: #ffffff !important;
    }

    /* Clouds and stars animation backdrops */
    .kid-bg-cloud {
        position: absolute;
        background: rgba(255, 255, 255, 0.85);
        border-radius: 100px;
        pointer-events: none;
        z-index: 1;
    }
    .kid-bg-cloud::before, .kid-bg-cloud::after {
        content: '';
        position: absolute;
        background: rgba(255, 255, 255, 0.85);
        border-radius: 50%;
    }
    .kid-bg-cloud.c1 { width: 120px; height: 40px; top: 10%; left: 5%; animation: floatCloud 25s linear infinite; }
    .kid-bg-cloud.c1::before { width: 50px; height: 50px; top: -25px; left: 15px; }
    .kid-bg-cloud.c1::after { width: 70px; height: 70px; top: -35px; right: 15px; }

    .kid-bg-cloud.c2 { width: 150px; height: 45px; bottom: 8%; right: 5%; animation: floatCloudReverse 30s linear infinite; }
    .kid-bg-cloud.c2::before { width: 60px; height: 60px; top: -30px; left: 20px; }
    .kid-bg-cloud.c2::after { width: 80px; height: 80px; top: -40px; right: 20px; }

    @@keyframes floatCloud {
        0%, 100% { transform: translateX(0); }
        50% { transform: translateX(60px); }
    }
    @@keyframes floatCloudReverse {
        0%, 100% { transform: translateX(0); }
        50% { transform: translateX(-60px); }
    }

    /* Header card design */
    .shop-header-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 4px solid #fbcfe8;
        border-radius: 30px;
        padding: 30px;
        box-shadow: 0 15px 30px rgba(236, 96, 144, 0.08);
        position: relative;
        z-index: 5;
        margin-bottom: 40px;
        text-align: center;
    }

    .shop-header-card h1 {
        font-weight: 900;
        color: #db2777;
        font-size: 2.2rem;
        margin-bottom: 10px;
    }

    .star-badge-wrap {
        display: inline-flex;
        align-items: center;
        gap: 15px;
        background: linear-gradient(135deg, #fef3c7, #fde68a);
        border: 3px solid #fbbf24;
        padding: 12px 30px;
        border-radius: 50px;
        box-shadow: 0 8px 20px rgba(251, 191, 36, 0.25);
        margin: 15px 0;
        animation: pulseBadge 2s infinite alternate;
    }

    @@keyframes pulseBadge {
        0% { transform: scale(1); }
        100% { transform: scale(1.05); }
    }

    .star-badge-wrap i {
        font-size: 2rem;
        color: #d97706;
        animation: spinStarSlow 6s linear infinite;
    }
    @@keyframes spinStarSlow {
        100% { transform: rotate(360deg); }
    }

    .star-badge-value {
        font-size: 2rem;
        font-weight: 900;
        color: #b45309;
    }

    /* Cards Grid */
    .avatar-card {
        background: rgba(255, 255, 255, 0.9);
        border: 3px solid #e9d5ff;
        border-radius: 25px;
        padding: 25px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.03);
        position: relative;
        overflow: hidden;
        z-index: 5;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .avatar-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(168, 85, 247, 0.15);
        border-color: #c084fc;
    }

    .avatar-card.equipped {
        border-color: #d946ef !important;
        box-shadow: 0 0 25px rgba(217, 70, 239, 0.25) !important;
        background: linear-gradient(180deg, #ffffff, #fdf4ff) !important;
    }

    .avatar-card.equipped::before {
        content: '✨ Đang Sử Dụng ✨';
        position: absolute;
        top: 12px;
        right: -35px;
        background: linear-gradient(135deg, #d946ef, #a855f7);
        color: #fff;
        font-size: 0.65rem;
        font-weight: 900;
        padding: 5px 40px;
        transform: rotate(45deg);
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
        z-index: 10;
        letter-spacing: 1px;
    }

    .preview-box {
        width: 140px;
        height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        position: relative;
    }

    .avatar-card-title {
        font-size: 1.3rem;
        font-weight: 900;
        color: #581c87;
        margin-bottom: 8px;
    }

    .avatar-card-cost {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 1.15rem;
        font-weight: 800;
        color: #d97706;
        background: #fef3c7;
        padding: 4px 15px;
        border-radius: 20px;
        margin-bottom: 12px;
        border: 1px solid #fde68a;
    }

    .avatar-card-desc {
        font-size: 0.85rem;
        font-weight: 600;
        color: #6b7280;
        line-height: 1.4;
        margin-bottom: 20px;
        flex-grow: 1;
    }

    /* Buttons styling */
    .btn-shop {
        width: 100%;
        padding: 10px 20px;
        border-radius: 20px;
        font-weight: 800;
        font-size: 0.95rem;
        border: none;
        cursor: pointer;
        transition: all 0.25s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-shop-locked {
        background: linear-gradient(135deg, #fbbf24, #f59e0b);
        color: #fff;
        box-shadow: 0 4px 10px rgba(245, 158, 11, 0.25);
    }
    .btn-shop-locked:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(245, 158, 11, 0.4);
    }

    .btn-shop-insufficient {
        background: #e5e7eb;
        color: #9ca3af;
        cursor: not-allowed;
    }

    .btn-shop-unlocked {
        background: linear-gradient(135deg, #a855f7, #7c3aed);
        color: #fff;
        box-shadow: 0 4px 10px rgba(124, 58, 237, 0.25);
    }
    .btn-shop-unlocked:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(124, 58, 237, 0.4);
    }

    .btn-shop-equipped {
        background: #fdf2f8;
        color: #db2777;
        border: 2px solid #db2777;
        cursor: default;
    }

    .btn-unequip {
        background: transparent;
        color: #6b7280;
        border: 2px solid #d1d5db;
        border-radius: 20px;
        padding: 6px 15px;
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.25s;
        margin-top: 15px;
    }
    .btn-unequip:hover {
        background: #f3f4f6;
        color: #111827;
        border-color: #9ca3af;
    }

    /* Confetti Particle */
    .confetti {
        position: absolute;
        width: 10px;
        height: 10px;
        background-color: #f00;
        z-index: 999;
        pointer-events: none;
        border-radius: 50%;
        animation: confettiFall 3s linear forwards;
    }
    @@keyframes confettiFall {
        0% { transform: translateY(-50px) rotate(0deg); opacity: 1; }
        100% { transform: translateY(80vh) rotate(360deg); opacity: 0; }
    }
</style>

<section class="shop-section">
    <div class="kid-bg-cloud c1"></div>
    <div class="kid-bg-cloud c2"></div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <!-- Header Card -->
                <div class="shop-header-card">
                    <h1><i class="fa fa-shopping-cart" style="color: #db2777; margin-right: 8px;"></i> Cửa hàng Ảnh nền VIP</h1>
                    <p class="text-muted fw-bold">Làm bài tập AI để tích lũy thật nhiều Sao vàng và mở khóa các hiệu ứng đại diện siêu cấp vvippro nhé!</p>
                    
                    <div class="star-badge-wrap">
                        <i class="fas fa-star"></i>
                        <span class="star-badge-value" id="starBalance">@availableStars</span>
                    </div>
                    
                    <div class="text-secondary fw-bold mt-2" style="font-size: 0.9rem;">
                        <span>Tổng số sao đã tích lũy từ trước đến nay: </span>
                        <strong class="text-warning"><i class="fas fa-star"></i> @totalEarned</strong>
                    </div>

                    @if (equipped != null && equipped.StartsWith("VIP_"))
                    {
                        <div>
                            <button class="btn-unequip" onclick="unequipAvatar()"><i class="fas fa-times-circle"></i> Trở về ảnh đại diện mặc định</button>
                        </div>
                    }
                </div>

                <!-- Products Grid -->
                <div class="row g-4">
                    @foreach (var item in items)
                    {
                        bool isUnlocked = unlocked.Contains(item.Id);
                        bool isEquipped = equipped == item.Id;

                        <div class="col-md-6 col-lg-4">
                            <div class="avatar-card @(isEquipped ? "equipped" : "")" id="card-@item.Id">
                                <!-- Actual Live CSS Animated Preview! -->
                                <div class="preview-box">
                                    <div class="vip-avatar-frame @item.Id.ToLower()">
                                        <div class="vip-avatar-effect-bg"></div>
                                        <div class="vip-avatar-glow"></div>
                                        <div class="vip-avatar-emoji">@item.Emoji</div>
                                    </div>
                                </div>

                                <div class="avatar-card-title">@item.Name</div>

                                <div class="avatar-card-cost">
                                    <i class="fas fa-star"></i> @item.Cost Sao
                                </div>

                                <div class="avatar-card-desc">@item.Description</div>

                                @if (isEquipped)
                                {
                                    <button class="btn-shop btn-shop-equipped" disabled>
                                        <i class="fas fa-check-circle"></i> Đang trang bị
                                    </button>
                                }
                                else if (isUnlocked)
                                {
                                    <button class="btn-shop btn-shop-unlocked" onclick="equipAvatar('@item.Id')">
                                        <i class="fas fa-user-tag"></i> Sử dụng ngay
                                    </button>
                                }
                                else
                                {
                                    bool canAfford = availableStars >= item.Cost;
                                    if (canAfford)
                                    {
                                        <button class="btn-shop btn-shop-locked" onclick="unlockAvatar('@item.Id', @item.Cost)" id="btn-unlock-@item.Id">
                                            <i class="fas fa-lock-open"></i> Mở khóa
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn-shop btn-shop-insufficient" disabled title="Bạn cần thêm sao!">
                                            <i class="fas fa-lock"></i> Chưa đủ Sao
                                        </button>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="text-center mt-5">
                    <a href="/Account/Profile" class="btn-shop-back-profile">← Quay lại Hồ sơ</a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
<script>
    function unlockAvatar(avatarId, cost) {
        Swal.fire({
            title: 'Mở khóa ảnh nền VIP?',
            text: `Bạn muốn dùng ${cost} sao để mở khóa hiệu ứng này chứ?`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Đồng ý mở khóa 🔓',
            cancelButtonText: 'Hủy',
            confirmButtonColor: '#a855f7',
            cancelButtonColor: '#6b7280',
            background: '#fff',
            borderRadius: '20px'
        }).then((result) => {
            if (result.isConfirmed) {
                // Ajax call to unlock
                fetch('/Account/UnlockAvatar', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    body: `avatarId=${avatarId}`
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        // Play confetti animation
                        triggerConfetti();

                        Swal.fire({
                            title: 'Mở khóa thành công! 🎉',
                            text: 'Bạn đã sở hữu hiệu ứng đặc biệt này. Hãy nhấn Sử dụng ngay nhé!',
                            icon: 'success',
                            confirmButtonText: 'Tuyệt vời',
                            confirmButtonColor: '#10b981',
                            borderRadius: '20px'
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            title: 'Lỗi',
                            text: data.message,
                            icon: 'error',
                            confirmButtonText: 'Đồng ý',
                            confirmButtonColor: '#ef4444',
                            borderRadius: '20px'
                        });
                    }
                });
            }
        });
    }

    function equipAvatar(avatarId) {
        fetch('/Account/EquipAvatar', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            body: `avatarId=${avatarId}`
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                Swal.fire({
                    title: 'Đã trang bị! 💖',
                    text: 'Hiệu ứng ảnh nền đại diện mới đã được áp dụng.',
                    icon: 'success',
                    timer: 2000,
                    showConfirmButton: false,
                    borderRadius: '20px'
                }).then(() => {
                    location.reload();
                });
            } else {
                Swal.fire('Lỗi', data.message, 'error');
            }
        });
    }

    function unequipAvatar() {
        fetch('/Account/UnequipAvatar', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            }
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                Swal.fire({
                    title: 'Đã gỡ bỏ!',
                    text: 'Ảnh đại diện đã trở lại mặc định.',
                    icon: 'info',
                    timer: 2000,
                    showConfirmButton: false,
                    borderRadius: '20px'
                }).then(() => {
                    location.reload();
                });
            }
        });
    }

    // Confetti effect helper
    function triggerConfetti() {
        const colors = ['#f59e0b', '#fbbf24', '#d946ef', '#a855f7', '#06b6d4', '#10b981', '#ef4444'];
        for (let i = 0; i < 80; i++) {
            const confetti = document.createElement('div');
            confetti.classList.add('confetti');
            confetti.style.left = Math.random() * 100 + 'vw';
            confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
            confetti.style.transform = `scale(${Math.random() * 0.8 + 0.4})`;
            confetti.style.animationDelay = Math.random() * 2 + 's';
            confetti.style.animationDuration = Math.random() * 3 + 2 + 's';
            document.body.appendChild(confetti);

            setTimeout(() => {
                confetti.remove();
            }, 5000);
        }
    }
</script>
}
