@model POT_System_ASPNET.Data.Entities.User
@{
    ViewData["Title"] = "Chỉnh sửa thông tin";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .edit-section { padding:80px 0; background:linear-gradient(135deg,#1a0533,#2d0a4e); min-height:80vh; }
    .edit-card { background:rgba(255,255,255,.05); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,.1); border-radius:20px; padding:40px; color:#fff; }
    .edit-card h2 { color:#ec6090; font-weight:700; margin-bottom:30px; }
    .form-label { color:#94a3b8; font-size:.9rem; }
    .form-control { background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.2); color:#fff; border-radius:10px; padding:12px 15px; }
    .form-control:focus { background:rgba(255,255,255,.12); border-color:#ec6090; box-shadow:0 0 0 3px rgba(236,96,144,.2); color:#fff; outline:none; }
    .form-control::placeholder { color:#64748b; }
    .btn-save { padding:12px 30px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff; border:none; border-radius:25px; font-weight:600; cursor:pointer; transition:all .3s; }
    .btn-save:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(236,96,144,.4); }
    .btn-cancel { padding:12px 30px; background:transparent; color:#ec6090; border:2px solid #ec6090; border-radius:25px; text-decoration:none; font-weight:600; }
    .current-avatar { width:80px; height:80px; border-radius:50%; border:3px solid #ec6090; object-fit:cover; }
    .success-msg { background:rgba(16,185,129,.15); border:1px solid #10b981; color:#10b981; padding:12px; border-radius:10px; margin-bottom:20px; }
</style>

<section class="edit-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="edit-card">
                    <h2>✏️ Chỉnh sửa thông tin</h2>
                    @if (ViewBag.Success != null) { <div class="success-msg">@ViewBag.Success</div> }

                    <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="text-center mb-4">
                            <img src="@(Model?.Image ?? "/assets/images/profile-header.jpg")" class="current-avatar" id="previewImg" alt="Avatar">
                            <div class="mt-2">
                                <label class="btn-cancel" style="cursor:pointer;font-size:.85rem;padding:8px 20px;">📷 Đổi ảnh đại diện
                                    <input type="file" name="imageFile" id="imageFile" accept="image/*" style="display:none" onchange="previewImg(this)">
                                </label>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Họ và tên</label>
                                <input type="text" name="fullName" class="form-control" value="@Model?.FullName" placeholder="Họ và tên" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                <input type="email" name="email" class="form-control" value="@Model?.Email" placeholder="Email" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Số điện thoại</label>
                                <input type="text" name="phone" class="form-control" value="@Model?.Phone" placeholder="Số điện thoại">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ngày sinh</label>
                                <input type="date" name="dob" class="form-control" value="@Model?.Dob?.ToString("yyyy-MM-dd")">
                            </div>
                            @if (Model?.Role == "Content Manager") {
                                <div class="col-12">
                                    <label class="form-label">Chuyên môn</label>
                                    <input type="text" name="specialization" class="form-control" value="@Model?.Specialization" placeholder="Chuyên môn giảng dạy của bạn">
                                </div>
                            }
                        </div>
                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn-save">💾 Lưu thay đổi</button>
                            <a asp-action="Profile" class="btn-cancel">← Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
@section Scripts {
<script>
    function previewImg(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => document.getElementById('previewImg').src = e.target.result;
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
}
