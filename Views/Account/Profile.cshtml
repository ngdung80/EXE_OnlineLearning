@model POT_System_ASPNET.Data.Entities.User
@{
    ViewData["Title"] = "Thông tin cá nhân";
}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<style>
    .profile-section {
        padding: 140px 0 80px;
        background: transparent !important;
        min-height: 80vh;
        position: relative;
        overflow: hidden;
        font-family: 'Inter', sans-serif !important;
        color: #1e1b4b;
    }
    .profile-section *:not(i):not(.fa) {
        font-family: 'Inter', sans-serif !important;
    }

    .profile-card {
        background: rgba(255, 255, 255, 0.9) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        border: 4px solid #fbcfe8 !important;
        border-radius: 35px !important;
        overflow: hidden !important;
        box-shadow: 0 15px 35px rgba(236, 96, 144, 0.08) !important;
        position: relative;
        z-index: 10;
        padding: 40px;
        color: #1e1b4b !important;
    }

    .avatar-wrap { text-align:center; margin-bottom:30px; }
    .avatar-wrap img { width:120px; height:120px; border-radius:50%; border:4px solid #ec6090; object-fit:cover; box-shadow: 0 8px 20px rgba(236,96,144,0.2); }
    .avatar-wrap h3 { margin-top:15px; font-size:1.8rem; font-weight:900; color:#ec6090; }
    .avatar-wrap .role-badge { display:inline-block; padding:6px 20px; border-radius:20px; background:linear-gradient(135deg,#ec6090,#a855f7); font-size:.85rem; font-weight:800; color: #fff; box-shadow: 0 4px 10px rgba(236,96,144,0.2); }
    
    .info-row { display:flex; align-items:center; padding:18px 0; border-bottom:1px solid #f3e8ff; }
    .info-row:last-child { border-bottom:none; }
    .info-label { width:160px; color:#ec6090; font-weight: 800; font-size:.95rem; display:flex; align-items:center; gap:8px; }
    .info-value { flex:1; color:#1e1b4b; font-weight:700; font-size:1rem; }
    
    .btn-edit { display:inline-block; padding:12px 30px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff !important; border-radius:25px; text-decoration:none; font-weight:800; transition:all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); box-shadow: 0 5px 15px rgba(236, 96, 144, 0.2); }
    .btn-edit:hover { transform:translateY(-3px) scale(1.03); box-shadow:0 8px 20px rgba(236,96,144,.4); color:#fff !important; }
    
    .btn-pwd { display:inline-block; padding:12px 30px; background:transparent; color:#ec6090 !important; border:2px solid #ec6090; border-radius:25px; text-decoration:none; font-weight:800; transition:all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .btn-pwd:hover { background:#ec6090; color:#fff !important; transform:translateY(-3px) scale(1.03); box-shadow:0 8px 20px rgba(236,96,144,.2); }

    .kid-bg-cloud {
        position: absolute;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 100px;
        pointer-events: none;
        z-index: 1;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02);
    }
    .kid-bg-cloud::before, .kid-bg-cloud::after {
        content: '';
        position: absolute;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 50%;
    }
    .kid-bg-cloud.c1 {
        width: 120px; height: 40px; top: 12%; left: 8%;
        animation: floatCloud 24s linear infinite;
    }
    .kid-bg-cloud.c1::before { width: 50px; height: 50px; top: -25px; left: 15px; }
    .kid-bg-cloud.c1::after { width: 70px; height: 70px; top: -35px; right: 15px; }

    .kid-bg-cloud.c2 {
        width: 160px; height: 50px; bottom: 15%; right: 8%;
        animation: floatCloudReverse 28s linear infinite;
    }
    .kid-bg-cloud.c2::before { width: 70px; height: 70px; top: -35px; left: 20px; }
    .kid-bg-cloud.c2::after { width: 90px; height: 90px; top: -45px; right: 20px; }

    @@keyframes floatCloud {
        0% { transform: translateX(0); }
        50% { transform: translateX(50px); }
        100% { transform: translateX(0); }
    }
    @@keyframes floatCloudReverse {
        0% { transform: translateX(0); }
        50% { transform: translateX(-50px); }
        100% { transform: translateX(0); }
    }

    .kid-bg-star {
        position: absolute;
        font-size: 2.5rem;
        color: #f59e0b;
        opacity: 0.35;
        pointer-events: none;
        z-index: 5;
    }
    .kid-bg-star.s1 { top: 15%; right: 12%; animation: orbitRight 14s ease-in-out infinite alternate; }
    .kid-bg-star.s2 { bottom: 18%; left: 10%; animation: orbitLeft 17s ease-in-out infinite alternate; color: #fbbf24; }
    .kid-bg-star.s3 { top: 45%; left: 6%; animation: floatAroundVertical 11s ease-in-out infinite alternate; font-size: 1.8rem; color: #fca5a5; }
    .kid-bg-star.s4 { bottom: 40%; right: 6%; animation: floatAroundHorizontal 15s ease-in-out infinite alternate; font-size: 2rem; color: #38bdf8; }
    .kid-bg-star.s5 { top: 10%; left: 25%; animation: diagonalFloat 20s ease-in-out infinite alternate; font-size: 1.6rem; color: #c084fc; }

    @@keyframes orbitRight {
        0% { transform: translate(0, 0) rotate(0deg) scale(1); }
        35% { transform: translate(45px, -70px) rotate(120deg) scale(1.25); }
        70% { transform: translate(-30px, -120px) rotate(240deg) scale(0.8); }
        100% { transform: translate(0, 0) rotate(360deg) scale(1); }
    }
    @@keyframes orbitLeft {
        0% { transform: translate(0, 0) rotate(360deg) scale(0.9); }
        40% { transform: translate(-60px, 50px) rotate(180deg) scale(1.3); }
        80% { transform: translate(40px, -40px) rotate(0deg) scale(0.7); }
        100% { transform: translate(0, 0) rotate(-360deg) scale(0.9); }
    }
    @@keyframes floatAroundVertical {
        0% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-90px) rotate(180deg); }
        100% { transform: translateY(0) rotate(360deg); }
    }
    @@keyframes floatAroundHorizontal {
        0% { transform: translateX(0) rotate(0deg); }
        50% { transform: translateX(90px) rotate(-180deg); }
        100% { transform: translateX(0) rotate(-360deg); }
    }
    @@keyframes diagonalFloat {
        0% { transform: translate(0, 0) rotate(0deg); }
        50% { transform: translate(80px, 80px) rotate(180deg); }
        100% { transform: translate(0, 0) rotate(360deg); }
    }
</style>

<section class="profile-section">
    <!-- Clouds -->
    <div class="kid-bg-cloud c1"></div>
    <div class="kid-bg-cloud c2"></div>

    <!-- Stars -->
    <div class="kid-bg-star s1">⭐</div>
    <div class="kid-bg-star s2">✨</div>
    <div class="kid-bg-star s3">🌟</div>
    <div class="kid-bg-star s4">⭐</div>
    <div class="kid-bg-star s5">✨</div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="profile-card">
                    <div class="avatar-wrap" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 15px;">
                        @if (Model?.Image != null && Model.Image.StartsWith("VIP_"))
                        {
                            <div class="vip-avatar-frame @Model.Image.ToLower()" style="margin: 0 auto;">
                                <div class="vip-avatar-effect-bg"></div>
                                <div class="vip-avatar-glow"></div>
                                <div class="vip-avatar-emoji">
                                    @(Model.Image == "VIP_1" ? "⭐" : Model.Image == "VIP_2" ? "🌊" : Model.Image == "VIP_3" ? "🤖" : Model.Image == "VIP_4" ? "🔥" : "🌌")
                                </div>
                            </div>
                        }
                        else
                        {
                            <img src="@(Model?.Image ?? "/assets/images/profile-header.jpg")" alt="Avatar" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 4px solid #ec6090; box-shadow: 0 8px 20px rgba(236,96,144,0.2);">
                        }
                        <h3 style="margin-top: 5px;">@(Model?.FullName ?? Model?.Username)</h3>
                        <span class="role-badge">@(Model?.Role == "Admin" ? "Quản trị viên" : Model?.Role == "Student" ? "Học sinh" : Model?.Role == "Parent" ? "Phụ huynh" : Model?.Role == "Content Manager" ? "Quản lý nội dung" : Model?.Role)</span>
                    </div>
                    <div class="profile-info">
                        <div class="info-row">
                            <div class="info-label"><i class="fas fa-user"></i> Tên đăng nhập</div>
                            <div class="info-value">@Model?.Username</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="fas fa-envelope"></i> Email</div>
                            <div class="info-value">@Model?.Email</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="fas fa-phone"></i> Số điện thoại</div>
                            <div class="info-value">@(Model?.Phone ?? "Chưa thiết lập")</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="fas fa-birthday-cake"></i> Ngày sinh</div>
                            <div class="info-value">@(Model?.Dob?.ToString("dd/MM/yyyy") ?? "Chưa thiết lập")</div>
                        </div>
                        @if (Model?.Role == "Content Manager") {
                            <div class="info-row">
                                <div class="info-label"><i class="fas fa-briefcase"></i> Chuyên môn</div>
                                <div class="info-value">@(Model?.Specialization ?? "Chưa thiết lập")</div>
                            </div>
                        }
                        <div class="info-row">
                            <div class="info-label"><i class="fas fa-circle"></i> Trạng thái</div>
                            <div class="info-value"><span style="color:@(Model?.Status == "active" ? "#10b981" : "#ef4444")">@(Model?.Status == "active" ? "Đang hoạt động" : "Không hoạt động")</span></div>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-3 flex-wrap">
                        <a asp-action="EditProfile" class="btn-edit">✏️ Chỉnh sửa thông tin</a>
                        <a asp-action="ChangePassword" class="btn-pwd">🔑 Đổi mật khẩu</a>
                        <a asp-action="Logout" class="btn-pwd" style="border-color:#ef4444;color:#ef4444;" onmouseover="this.style.background='#ef4444';this.style.color='#fff'" onmouseout="this.style.background='transparent';this.style.color='#ef4444'">🚪 Đăng xuất</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
