@model POT_System_ASPNET.Data.Entities.User
@{
    ViewData["Title"] = "Thông tin cá nhân";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .profile-section { padding: 80px 0; background: linear-gradient(135deg,#1a0533,#2d0a4e); min-height:80vh; }
    .profile-card { background: rgba(255,255,255,.05); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,.1); border-radius:20px; padding:40px; color:#fff; }
    .avatar-wrap { text-align:center; margin-bottom:30px; }
    .avatar-wrap img { width:120px; height:120px; border-radius:50%; border:4px solid #ec6090; object-fit:cover; }
    .avatar-wrap h3 { margin-top:15px; font-size:1.5rem; font-weight:700; color:#ec6090; }
    .avatar-wrap .role-badge { display:inline-block; padding:4px 16px; border-radius:20px; background:linear-gradient(135deg,#ec6090,#e75485); font-size:.8rem; font-weight:600; }
    .info-row { display:flex; align-items:center; padding:14px 0; border-bottom:1px solid rgba(255,255,255,.08); }
    .info-row:last-child { border-bottom:none; }
    .info-label { width:160px; color:#94a3b8; font-size:.9rem; display:flex; align-items:center; gap:8px; }
    .info-value { flex:1; color:#fff; font-weight:500; }
    .btn-edit { display:inline-block; padding:12px 30px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff; border-radius:25px; text-decoration:none; font-weight:600; transition:all .3s; }
    .btn-edit:hover { transform:translateY(-3px); box-shadow:0 8px 20px rgba(236,96,144,.4); color:#fff; }
    .btn-pwd { display:inline-block; padding:12px 30px; background:transparent; color:#ec6090; border:2px solid #ec6090; border-radius:25px; text-decoration:none; font-weight:600; transition:all .3s; }
    .btn-pwd:hover { background:#ec6090; color:#fff; }
</style>

<section class="profile-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="profile-card">
                    <div class="avatar-wrap">
                        <img src="@(Model?.Image ?? "/assets/images/profile-header.jpg")" alt="Avatar">
                        <h3>@(Model?.FullName ?? Model?.Username)</h3>
                        <span class="role-badge">@(Model?.Role == "Admin" ? "Quản trị viên" : Model?.Role == "Student" ? "Học sinh" : Model?.Role == "Parent" ? "Phụ huynh" : Model?.Role == "Content Manager" ? "Quản lý nội dung" : Model?.Role)</span>
                    </div>
                    <div class="profile-info">
                        <div class="info-row">
                            <div class="info-label"><i class="fas fa-user"></i> Tên đăng nhập</div>
                            <div class="info-value">@Model?.Username</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="fas fa-envelope"></i> Email</div>
                            <div class="info-value">@Model?.Email</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="fas fa-phone"></i> Số điện thoại</div>
                            <div class="info-value">@(Model?.Phone ?? "Chưa thiết lập")</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="fas fa-birthday-cake"></i> Ngày sinh</div>
                            <div class="info-value">@(Model?.Dob?.ToString("dd/MM/yyyy") ?? "Chưa thiết lập")</div>
                        </div>
                        @if (Model?.Role == "Content Manager") {
                            <div class="info-row">
                                <div class="info-label"><i class="fas fa-briefcase"></i> Chuyên môn</div>
                                <div class="info-value">@(Model?.Specialization ?? "Chưa thiết lập")</div>
                            </div>
                        }
                        <div class="info-row">
                            <div class="info-label"><i class="fas fa-circle"></i> Trạng thái</div>
                            <div class="info-value"><span style="color:@(Model?.Status == "active" ? "#10b981" : "#ef4444")">@(Model?.Status == "active" ? "Đang hoạt động" : "Không hoạt động")</span></div>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-3 flex-wrap">
                        <a asp-action="EditProfile" class="btn-edit">✏️ Chỉnh sửa thông tin</a>
                        <a asp-action="ChangePassword" class="btn-pwd">🔑 Đổi mật khẩu</a>
                        <a asp-action="Logout" class="btn-pwd" style="border-color:#ef4444;color:#ef4444;" onmouseover="this.style.background='#ef4444';this.style.color='#fff'" onmouseout="this.style.background='transparent';this.style.color='#ef4444'">🚪 Đăng xuất</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
