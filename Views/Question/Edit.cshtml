@model POT_System_ASPNET.Data.Entities.Question
@{
    ViewData["Title"] = "Chỉnh sửa câu hỏi";
    var lessons = ViewBag.Lessons as List<POT_System_ASPNET.Data.Entities.Lesson> ?? new List<POT_System_ASPNET.Data.Entities.Lesson>();
    
    // Split the comma-separated options
    var opts = Model.Answer?.Split(',').Select(o => o.Trim()).ToArray() ?? new string[4];
    var optA = opts.Length > 0 ? opts[0] : "";
    var optB = opts.Length > 1 ? opts[1] : "";
    var optC = opts.Length > 2 ? opts[2] : "";
    var optD = opts.Length > 3 ? opts[3] : "";

    // Determine which option letter is correct
    string correctLetter = "A";
    if (Model.CorrectAnswer != null)
    {
        if (Model.CorrectAnswer.Equals(optB, StringComparison.OrdinalIgnoreCase)) correctLetter = "B";
        else if (Model.CorrectAnswer.Equals(optC, StringComparison.OrdinalIgnoreCase)) correctLetter = "C";
        else if (Model.CorrectAnswer.Equals(optD, StringComparison.OrdinalIgnoreCase)) correctLetter = "D";
    }
}
<style>
    .form-section { padding:80px 0; background:linear-gradient(135deg,#0f172a,#1e293b); min-height:80vh; }
    .form-card { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:20px; padding:40px; color:#fff; }
    .form-card h2 { color:#ec6090; font-weight:700; margin-bottom:30px; }
    .form-label { color:#94a3b8; font-size:.9rem; }
    .form-control, .form-select { background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.15); color:#fff; border-radius:10px; padding:12px 15px; width:100%; }
    .form-control:focus, .form-select:focus { border-color:#ec6090; background:rgba(255,255,255,.12); outline:none; color:#fff; box-shadow:0 0 0 3px rgba(236,96,144,.2); }
    .form-control::placeholder { color:#64748b; }
    .form-select option { background:#1e293b; }
    .btn-save { padding:12px 30px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff; border:none; border-radius:25px; font-weight:600; cursor:pointer; }
    .btn-cancel { display:inline-block; padding:12px 30px; background:transparent; color:#ec6090; border:2px solid #ec6090; border-radius:25px; text-decoration:none; font-weight:600; }
</style>
<section class="form-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="form-card">
                    <h2>Chỉnh sửa câu hỏi</h2>
                    <form asp-action="Edit" method="post" id="questionForm" onsubmit="prepareAnswers(event)">
                        @Html.AntiForgeryToken()
                        
                        <input type="hidden" name="QuestionId" value="@Model.QuestionId" />
                        <input type="hidden" name="Answer" id="answerHidden" value="@Model.Answer" />
                        <input type="hidden" name="CorrectAnswer" id="correctAnswerHidden" value="@Model.CorrectAnswer" />

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Bài học *</label>
                                <select name="LessonId" class="form-select" required>
                                    @foreach (var l in lessons)
                                    {
                                        <option value="@l.LessonId" selected="@(l.LessonId == Model.LessonId)">@l.LessonName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Mức độ nhận thức *</label>
                                <select name="Level" class="form-select" required>
                                    <option value="Remember" selected="@(Model.Level == "Remember")">Nhận biết</option>
                                    <option value="Understand" selected="@(Model.Level == "Understand")">Thông hiểu</option>
                                    <option value="Apply" selected="@(Model.Level == "Apply")">Vận dụng</option>
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Trạng thái *</label>
                                <select name="Status" class="form-select" required>
                                    <option value="Active" selected="@(Model.Status == "Active")">Hoạt động</option>
                                    <option value="Inactive" selected="@(Model.Status == "Inactive")">Không hoạt động</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Nội dung câu hỏi *</label>
                            <textarea name="QuestionContent" class="form-control" rows="4" required>@Model.QuestionContent</textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Đáp án A *</label>
                                <input type="text" id="optA" class="form-control" value="@optA" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Đáp án B *</label>
                                <input type="text" id="optB" class="form-control" value="@optB" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Đáp án C *</label>
                                <input type="text" id="optC" class="form-control" value="@optC" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Đáp án D *</label>
                                <input type="text" id="optD" class="form-control" value="@optD" required>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Đáp án đúng *</label>
                            <select id="correctOptionSelect" class="form-select" required>
                                <option value="A" selected="@(correctLetter == "A")">Đáp án A</option>
                                <option value="B" selected="@(correctLetter == "B")">Đáp án B</option>
                                <option value="C" selected="@(correctLetter == "C")">Đáp án C</option>
                                <option value="D" selected="@(correctLetter == "D")">Đáp án D</option>
                            </select>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn-save">💾 Lưu thay đổi</button>
                            <a asp-action="Index" class="btn-cancel">← Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function prepareAnswers(e) {
            e.preventDefault();

            const optA = document.getElementById('optA').value.trim();
            const optB = document.getElementById('optB').value.trim();
            const optC = document.getElementById('optC').value.trim();
            const optD = document.getElementById('optD').value.trim();
            const correctLetter = document.getElementById('correctOptionSelect').value;

            // Combine answers
            const answers = [optA, optB, optC, optD];
            document.getElementById('answerHidden').value = answers.join(', ');

            // Set correct answer text
            let correctVal = "";
            if (correctLetter === "A") correctVal = optA;
            else if (correctLetter === "B") correctVal = optB;
            else if (correctLetter === "C") correctVal = optC;
            else if (correctLetter === "D") correctVal = optD;

            document.getElementById('correctAnswerHidden').value = correctVal;

            // Submit the form
            document.getElementById('questionForm').submit();
        }
    </script>
}
