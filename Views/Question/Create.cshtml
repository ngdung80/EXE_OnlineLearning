@model POT_System_ASPNET.Data.Entities.Question
@{
    ViewData["Title"] = "Thêm câu hỏi";
    var lessons = ViewBag.Lessons as List<POT_System_ASPNET.Data.Entities.Lesson> ?? new List<POT_System_ASPNET.Data.Entities.Lesson>();
    var preselectedLessonId = ViewBag.PreselectedLessonId as int?;
}
<style>
    .form-section { padding:80px 0; background:linear-gradient(135deg,#0f172a,#1e293b); min-height:80vh; }
    .form-card { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:20px; padding:40px; color:#fff; }
    .form-card h2 { color:#ec6090; font-weight:700; margin-bottom:30px; }
    .form-label { color:#94a3b8; font-size:.9rem; }
    .form-control, .form-select { background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.15); color:#fff; border-radius:10px; padding:12px 15px; width:100%; }
    .form-control:focus, .form-select:focus { border-color:#ec6090; background:rgba(255,255,255,.12); outline:none; color:#fff; box-shadow:0 0 0 3px rgba(236,96,144,.2); }
    .form-control::placeholder { color:#64748b; }
    .form-select option { background:#1e293b; }
    .btn-save { padding:12px 30px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff; border:none; border-radius:25px; font-weight:600; cursor:pointer; }
    .btn-cancel { display:inline-block; padding:12px 30px; background:transparent; color:#ec6090; border:2px solid #ec6090; border-radius:25px; text-decoration:none; font-weight:600; }
</style>
<section class="form-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="form-card">
                    <h2>Thêm câu hỏi mới</h2>
                    <form asp-action="Create" method="post" id="questionForm" onsubmit="prepareAnswers(event)">
                        @Html.AntiForgeryToken()
                        
                        <!-- Hidden inputs populated by JS -->
                        <input type="hidden" name="Answer" id="answerHidden" />
                        <input type="hidden" name="CorrectAnswer" id="correctAnswerHidden" />

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Loại câu hỏi *</label>
                                <select name="IsMultipleChoice" id="qTypeSelect" class="form-select" onchange="toggleQuestionType()" required>
                                    <option value="true" selected>Trắc nghiệm</option>
                                    <option value="false">Tự luận</option>
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Bài học *</label>
                                <select name="LessonId" class="form-select" required>
                                    <option value="">-- Chọn bài học --</option>
                                    @foreach (var l in lessons)
                                    {
                                        <option value="@l.LessonId" selected="@(l.LessonId == preselectedLessonId)">@l.LessonName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Mức độ nhận thức *</label>
                                <select name="Level" class="form-select" required>
                                    <option value="Remember">Nhận biết</option>
                                    <option value="Understand">Thông hiểu</option>
                                    <option value="Apply">Vận dụng</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Nội dung câu hỏi *</label>
                            <textarea name="QuestionContent" class="form-control" rows="4" placeholder="Nhập nội dung câu hỏi..." required></textarea>
                        </div>

                        <!-- MC Options wrapper -->
                        <div class="row" id="mcOptionsWrapper">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Đáp án A *</label>
                                <input type="text" id="optA" class="form-control" placeholder="Lựa chọn đáp án A" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Đáp án B *</label>
                                <input type="text" id="optB" class="form-control" placeholder="Lựa chọn đáp án B" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Đáp án C *</label>
                                <input type="text" id="optC" class="form-control" placeholder="Lựa chọn đáp án C" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Đáp án D *</label>
                                <input type="text" id="optD" class="form-control" placeholder="Lựa chọn đáp án D" required>
                            </div>
                        </div>

                        <!-- MC Correct Option Select -->
                        <div class="mb-4" id="mcCorrectOptionWrapper">
                            <label class="form-label">Đáp án đúng *</label>
                            <select id="correctOptionSelect" class="form-select" required>
                                <option value="A">Đáp án A</option>
                                <option value="B">Đáp án B</option>
                                <option value="C">Đáp án C</option>
                                <option value="D">Đáp án D</option>
                            </select>
                        </div>

                        <!-- Essay Answer Hint wrapper (Initially Hidden) -->
                        <div class="mb-4" id="essayCorrectAnswerWrapper" style="display: none;">
                            <label class="form-label">Gợi ý đáp án đúng / Mẫu đáp án tự luận *</label>
                            <textarea id="essayCorrectAnswerInput" class="form-control" rows="3" placeholder="Nhập câu trả lời mẫu cho tự luận..."></textarea>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn-save">💾 Lưu câu hỏi</button>
                            <a asp-action="Index" class="btn-cancel">← Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function toggleQuestionType() {
            const isMultiple = document.getElementById('qTypeSelect').value === 'true';
            const mcWrapper = document.getElementById('mcOptionsWrapper');
            const mcCorrectWrapper = document.getElementById('mcCorrectOptionWrapper');
            const essayWrapper = document.getElementById('essayCorrectAnswerWrapper');

            const optInputs = [document.getElementById('optA'), document.getElementById('optB'), document.getElementById('optC'), document.getElementById('optD')];
            const correctOptSel = document.getElementById('correctOptionSelect');
            const essayInput = document.getElementById('essayCorrectAnswerInput');

            if (isMultiple) {
                mcWrapper.style.display = 'flex';
                mcCorrectWrapper.style.display = 'block';
                essayWrapper.style.display = 'none';

                optInputs.forEach(i => i.setAttribute('required', 'required'));
                correctOptSel.setAttribute('required', 'required');
                essayInput.removeAttribute('required');
            } else {
                mcWrapper.style.display = 'none';
                mcCorrectWrapper.style.display = 'none';
                essayWrapper.style.display = 'block';

                optInputs.forEach(i => i.removeAttribute('required'));
                correctOptSel.removeAttribute('required');
                essayInput.setAttribute('required', 'required');
            }
        }

        function prepareAnswers(e) {
            e.preventDefault();

            const isMultiple = document.getElementById('qTypeSelect').value === 'true';
            if (isMultiple) {
                const optA = document.getElementById('optA').value.trim();
                const optB = document.getElementById('optB').value.trim();
                const optC = document.getElementById('optC').value.trim();
                const optD = document.getElementById('optD').value.trim();
                const correctLetter = document.getElementById('correctOptionSelect').value;

                // Combine answers
                const answers = [optA, optB, optC, optD];
                document.getElementById('answerHidden').value = answers.join(', ');

                // Set correct answer text
                let correctVal = "";
                if (correctLetter === "A") correctVal = optA;
                else if (correctLetter === "B") correctVal = optB;
                else if (correctLetter === "C") correctVal = optC;
                else if (correctLetter === "D") correctVal = optD;

                document.getElementById('correctAnswerHidden').value = correctVal;
            } else {
                document.getElementById('answerHidden').value = ""; // No multiple choice options
                document.getElementById('correctAnswerHidden').value = document.getElementById('essayCorrectAnswerInput').value.trim();
            }

            // Submit the form
            document.getElementById('questionForm').submit();
        }
    </script>
}
