<section class="admin-section">
    <div class="container">
        <div class="page-header">
            <h1 class="page-title"><i class="fas fa-database"></i> Ngân hàng câu hỏi</h1>
            @if (User.IsInRole("Content Manager") || User.IsInRole("Admin"))
            {
                <a asp-action="Create" asp-route-lessonId="@getLessonId()" class="btn-add">
                    <i class="fas fa-plus"></i> Thêm câu hỏi
                </a>
            }
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mb-4" style="background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3); color: #f87171; border-radius: 15px; padding: 15px 20px; font-weight: 600;">
                <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            </div>
        }

        <!-- Filters Form -->
        <div class="filter-card">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="search" class="form-control" placeholder="Tìm nội dung câu hỏi..." value="@getSearch()" />
                </div>
                <div class="col-md-3">
                    <select name="lessonId" class="form-select">
                        <option value="">-- Tất cả bài học --</option>
                        @foreach (var l in lessons)
                        {
                            <option value="@l.LessonId" selected="@(l.LessonId == getLessonId())">@l.LessonName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="level" class="form-select">
                        <option value="">-- Tất cả độ khó --</option>
                        <option value="Remember" selected="@(getLevel() == "Remember")">Nhận biết</option>
                        <option value="Understand" selected="@(getLevel() == "Understand")">Thông hiểu</option>
                        <option value="Apply" selected="@(getLevel() == "Apply")">Vận dụng</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="status" class="form-select">
                        <option value="">-- Tất cả trạng thái --</option>
                        <option value="Active" selected="@(getStatus() == "Active")">Hoạt động</option>
                        <option value="Inactive" selected="@(getStatus() == "Inactive")">Ngừng hoạt động</option>
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn-search"><i class="fas fa-filter"></i> Lọc dữ liệu</button>
                </div>
            </form>
        </div>

        <!-- Question List Form to build test -->
        @if (Model != null && Model.Any())
        {
            <div style="margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                <button type="button" class="btn btn-outline-info btn-sm" onclick="toggleSelectAll(true)" style="border-radius: 20px; font-weight: 700; color: #60a5fa; border-color: #60a5fa;">Chọn tất cả trang này</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleSelectAll(false)" style="border-radius: 20px; font-weight: 700; color: #94a3b8; border-color: #94a3b8;">Bỏ chọn tất cả trang này</button>
                <button type="button" class="btn btn-outline-warning btn-sm" onclick="clearAllSelections()" style="border-radius: 20px; font-weight: 700; color: #f59e0b; border-color: #f59e0b;">Xóa hết đã chọn</button>
            </div>

            foreach (var q in Model)
            {
                string vnLevel = q.Level == "Remember" ? "Nhận biết" : q.Level == "Understand" ? "Thông hiểu" : "Vận dụng";
                bool isMc = q.IsMultipleChoice;
                
                <div class="question-card">
                    <div class="q-header">
                        <div class="q-meta">
                            @if (User.IsInRole("Content Manager") || User.IsInRole("Admin"))
                            {
                                <input type="checkbox" class="q-checkbox" value="@q.QuestionId" onchange="handleCheckboxChange(this)" style="width:20px; height:20px; cursor:pointer;" />
                            }
                            <strong>Câu hỏi #@q.QuestionId (@(isMc ? "Trắc nghiệm" : "Tự luận"))</strong> &bull; Bài học: <strong>@q.Lesson?.LessonName</strong>
                        </div>
                        <span class="badge-level level-@q.Level">@vnLevel</span>
                    </div>

                    <div class="q-content">@q.QuestionContent</div>

                    @if (isMc)
                    {
                        <div class="options-grid">
                            @{
                                var opts = q.Answer?.Split(',').Select(o => o.Trim()).ToArray() ?? new string[0];
                                foreach (var opt in opts)
                                {
                                    bool isCorrect = opt.Equals(q.CorrectAnswer, StringComparison.OrdinalIgnoreCase);
                                    <div class="opt-box @(isCorrect ? "opt-correct" : "")">
                                        <span>@(isCorrect ? "🟢" : "⚪")</span> @opt
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="essay-box">
                            <i class="fas fa-key"></i> <strong>Đáp án mẫu tự luận:</strong> @q.CorrectAnswer
                        </div>
                    }

                    <div class="action-row">
                        @if (User.IsInRole("Content Manager") || User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@q.QuestionId" class="btn-edit">
                                <i class="fas fa-edit"></i> Sửa
                            </a>
                            <form asp-action="Delete" asp-route-id="@q.QuestionId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa câu hỏi này không?');" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-delete">
                                    <i class="fas fa-trash-alt"></i> Xóa
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }

            <!-- Pagination -->
            if (totalPages > 1)
            {
                <div class="pagination-container">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <a asp-action="Index" asp-route-search="@getSearch()" asp-route-lessonId="@getLessonId()" asp-route-level="@getLevel()" asp-route-status="@getStatus()" asp-route-page="@i" class="pagination-link @(i == currentPage ? "active" : "")">@i</a>
                    }
                </div>
            }
        }
        else
        {
            <div class="text-center py-5" style="background:rgba(255,255,255,.03); border-radius:20px; border:1px dashed rgba(255,255,255,.1);">
                <p style="color:#94a3b8; font-size:1.1rem; margin:0;">Không tìm thấy câu hỏi nào phù hợp với bộ lọc.</p>
            </div>
        }
    </div>
</section>

<!-- Floating Create Test Bar -->
@if (User.IsInRole("Content Manager") || User.IsInRole("Admin"))
{
    <div class="create-test-bar" id="createTestDrawer">
        <form id="createTestForm" method="post" action="/Question/CreateTestFromQuestions">
            @Html.AntiForgeryToken()
            <div id="hiddenCheckboxes"></div>
            
            <div class="create-test-bar-container">
                <div style="flex: 1; min-width: 250px;">
                    <h5 style="color: #ec6090; font-weight: 800; margin-bottom: 5px;"><i class="fas fa-file-signature"></i> Tạo Đề Thi/Luyện Tập (<span id="selectedCountText">0</span> câu hỏi đã chọn)</h5>
                    <p style="color: #94a3b8; font-size: 0.8rem; margin: 0;">Lựa chọn câu hỏi ở trên rồi điền thông tin đề thi để tạo.</p>
                </div>
                
                <div class="d-flex gap-2 align-items-center" style="flex: 3; min-width: 500px; flex-wrap: wrap;">
                    <input type="text" name="testName" class="form-control" placeholder="Tên đề thi..." style="width: 200px;" required />
                    
                    <select name="duration" class="form-select" style="width: 130px;" required>
                        <option value="15">15 phút</option>
                        <option value="30">30 phút</option>
                        <option value="45">45 phút</option>
                        <option value="60">60 phút</option>
                        <option value="90">90 phút</option>
                    </select>

                    <select name="types" class="form-select" style="width: 130px;" required>
                        <option value="Test">Đề kiểm tra</option>
                        <option value="Practice">Đề luyện tập</option>
                    </select>

                    <select name="subjectId" class="form-select" style="width: 150px;" required>
                        <option value="">-- Môn học * --</option>
                        @foreach (var s in subjects)
                        {
                            <option value="@s.SubjectId">@s.SubjectName</option>
                        }
                    </select>

                    <select name="lessonId" class="form-select" style="width: 150px;">
                        <option value="">-- Bài học (tùy chọn) --</option>
                        @foreach (var l in lessons)
                        {
                            <option value="@l.LessonId">@l.LessonName</option>
                        }
                    </select>
                </div>

                <div style="min-width: 150px;">
                    <button type="submit" class="btn btn-success" style="background: #10b981; border: none; font-weight: 700; padding: 10px 20px; border-radius: 10px; width: 100%;">
                        🚀 Tạo Đề Ngay
                    </button>
                </div>
            </div>
        </form>
    </div>
}

@section Scripts {
    <script>
        const STORAGE_KEY = 'selected_question_ids';

        function getSelectedIds() {
            try {
                const stored = sessionStorage.getItem(STORAGE_KEY);
                return stored ? JSON.parse(stored) : [];
            } catch (e) {
                return [];
            }
        }

        function saveSelectedIds(ids) {
            sessionStorage.setItem(STORAGE_KEY, JSON.stringify(ids));
        }

        // Run on page load
        document.addEventListener('DOMContentLoaded', () => {
            const selectedIds = getSelectedIds();
            const checkboxes = document.querySelectorAll('.q-checkbox');
            checkboxes.forEach(cb => {
                if (selectedIds.includes(parseInt(cb.value))) {
                    cb.checked = true;
                }
            });
            updateSelectedCount();
        });

        function handleCheckboxChange(cb) {
            const val = parseInt(cb.value);
            let selectedIds = getSelectedIds();
            if (cb.checked) {
                if (!selectedIds.includes(val)) {
                    selectedIds.push(val);
                }
            } else {
                selectedIds = selectedIds.filter(id => id !== val);
            }
            saveSelectedIds(selectedIds);
            updateSelectedCount();
        }

        function toggleSelectAll(checked) {
            const checkboxes = document.querySelectorAll('.q-checkbox');
            let selectedIds = getSelectedIds();
            checkboxes.forEach(cb => {
                cb.checked = checked;
                const val = parseInt(cb.value);
                if (checked) {
                    if (!selectedIds.includes(val)) {
                        selectedIds.push(val);
                    }
                } else {
                    selectedIds = selectedIds.filter(id => id !== val);
                }
            });
            saveSelectedIds(selectedIds);
            updateSelectedCount();
        }

        function clearAllSelections() {
            saveSelectedIds([]);
            const checkboxes = document.querySelectorAll('.q-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
            updateSelectedCount();
        }

        function updateSelectedCount() {
            const selectedIds = getSelectedIds();
            const count = selectedIds.length;
            const drawer = document.getElementById('createTestDrawer');
            const countText = document.getElementById('selectedCountText');
            
            if (countText) {
                countText.innerText = count;
            }

            if (drawer) {
                if (count > 0) {
                    drawer.style.display = 'block';
                } else {
                    drawer.style.display = 'none';
                }
            }

            // Sync values to hidden inputs in the form
            const hiddenContainer = document.getElementById('hiddenCheckboxes');
            if (hiddenContainer) {
                hiddenContainer.innerHTML = '';
                selectedIds.forEach(id => {
                    hiddenContainer.innerHTML += `<input type="hidden" name="questionIds" value="${id}" />`;
                });
            }
        }

        // Clear selection on successful submit
        const testForm = document.getElementById('createTestForm');
        if (testForm) {
            testForm.addEventListener('submit', () => {
                sessionStorage.removeItem(STORAGE_KEY);
            });
        }
    </script>
}
