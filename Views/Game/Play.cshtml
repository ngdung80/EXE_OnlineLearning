@model POT_System_ASPNET.Data.Entities.Lesson
@{
    ViewData["Title"] = "Đang chơi Trò chơi";
    var gameType = ViewBag.GameType as string;
    var lessonId = ViewBag.LessonId;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Pacifico&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

<style>
    .game-play-section {
        padding: 40px 0;
        background: linear-gradient(135deg, #a5b4fc 0%, #fbcfe8 50%, #c084fc 100%);
        min-height: 95vh;
        font-family: 'Nunito', sans-serif !important;
        position: relative;
    }

    .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 15px;
        position: relative;
        z-index: 5;
    }

    /* Top Navigation / Status Header */
    .game-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(255, 255, 255, 0.9);
        border: 4px solid #818cf8;
        border-radius: 25px;
        padding: 15px 25px;
        margin-bottom: 30px;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
    }

    .btn-exit {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #ef4444;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 18px;
        font-weight: 800;
        font-size: 0.95rem;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
        box-shadow: 0 4px 10px rgba(239, 68, 68, 0.25);
    }
    .btn-exit:hover {
        background: #dc2626;
        transform: translateY(-2px);
    }

    .lesson-title-badge {
        font-weight: 900;
        font-size: 1.2rem;
        color: #312e81;
    }

    .star-counter-badge {
        background: linear-gradient(135deg, #fbbf24, #f59e0b);
        color: white;
        padding: 8px 18px;
        border-radius: 20px;
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: 6px;
        border: 2px solid white;
        box-shadow: 0 4px 10px rgba(245, 158, 11, 0.3);
    }

    /* Main Arena Container */
    .arena-card {
        background: white;
        border: 5px solid #a855f7;
        border-radius: 35px;
        padding: 40px 30px;
        min-height: 500px;
        box-shadow: 0 15px 35px rgba(124, 58, 237, 0.15);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .arena-title {
        font-family: 'Pacifico', cursive;
        color: #7c3aed;
        font-size: 2.2rem;
        margin-bottom: 25px;
        text-align: center;
    }

    /* Success / Reward Dialog */
    .reward-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 30px;
        z-index: 100;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: all 0.4s ease;
        padding: 40px;
        text-align: center;
    }
    .reward-overlay.show {
        opacity: 1;
        pointer-events: auto;
    }

    .trophy-glow {
        font-size: 6rem;
        color: #fbbf24;
        animation: pulseGold 2s infinite ease-in-out;
        margin-bottom: 20px;
    }
    @@keyframes pulseGold {
        0%, 100% { transform: scale(1); filter: drop-shadow(0 0 10px rgba(251, 191, 36, 0.6)); }
        50% { transform: scale(1.1); filter: drop-shadow(0 0 25px rgba(251, 191, 36, 0.9)); }
    }

    .reward-title {
        font-family: 'Pacifico', cursive;
        font-size: 2.8rem;
        color: #ec6090;
        margin-bottom: 10px;
    }
    .reward-subtitle {
        font-size: 1.3rem;
        font-weight: 800;
        color: #4338ca;
        margin-bottom: 25px;
    }
    .reward-stars-earned {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 2rem;
        font-weight: 900;
        color: #f59e0b;
        background: #fef3c7;
        padding: 10px 25px;
        border-radius: 30px;
        border: 3px dashed #fbbf24;
        margin-bottom: 30px;
        animation: bounce 1.5s infinite;
    }

    .reward-actions {
        display: flex;
        gap: 20px;
    }
    .btn-reward-action {
        padding: 12px 28px;
        border-radius: 20px;
        font-weight: 900;
        font-size: 1.05rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-reward-replay {
        background: #a855f7;
        color: white;
    }
    .btn-reward-replay:hover { background: #9333ea; transform: scale(1.05); }
    .btn-reward-back {
        background: #10b981;
        color: white;
    }
    .btn-reward-back:hover { background: #059669; transform: scale(1.05); }

    /* ──── GAME 1: MEMORY MATCH CARDS ──── */
    .memory-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        width: 100%;
        max-width: 650px;
    }
    .memory-card {
        height: 110px;
        perspective: 1000px;
        cursor: pointer;
    }
    .card-inner {
        position: relative;
        width: 100%;
        height: 100%;
        text-align: center;
        transition: transform 0.6s;
        transform-style: preserve-3d;
        border-radius: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .memory-card.flipped .card-inner {
        transform: rotateY(180deg);
    }
    .card-front, .card-back {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        border-radius: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 10px;
    }
    .card-front {
        background: linear-gradient(135deg, #818cf8, #4f46e5);
        color: white;
        border: 4px solid #c7d2fe;
        font-size: 2.2rem;
    }
    .card-back {
        background: #faf5ff;
        color: #4c1d95;
        border: 4px solid #d8b4fe;
        transform: rotateY(180deg);
        font-weight: 800;
        font-size: 1rem;
        line-height: 1.2;
    }
    .memory-card.matched .card-inner .card-back {
        background: #dcfce7;
        border-color: #4ade80;
        color: #16a34a;
    }

    /* ──── GAME 2: LISTEN & BUBBLE CATCH ──── */
    .listen-speaker-btn {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ec6090, #db2777);
        border: 4px solid white;
        color: white;
        font-size: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(236, 96, 144, 0.4);
        margin-bottom: 40px;
        transition: all 0.2s;
    }
    .listen-speaker-btn:hover {
        transform: scale(1.1);
    }
    .bubble-answers-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        width: 100%;
        max-width: 550px;
    }
    .bubble-btn {
        background: #faf5ff;
        border: 4px solid #e9d5ff;
        border-radius: 25px;
        padding: 20px;
        font-size: 1.25rem;
        font-weight: 800;
        color: #4c1d95;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 6px 15px rgba(0,0,0,0.05);
    }
    .bubble-btn:hover {
        transform: translateY(-5px);
        border-color: #a855f7;
        background: white;
        box-shadow: 0 10px 20px rgba(168, 85, 247, 0.15);
    }
    .bubble-btn.correct {
        background: #dcfce7;
        border-color: #4ade80;
        color: #16a34a;
        transform: scale(1.05);
    }
    .bubble-btn.wrong {
        background: #fee2e2;
        border-color: #fca5a5;
        color: #dc2626;
        animation: shake 0.5s;
    }

    /* ──── GAME 3: SPELLING BEE SCRAMBLE ──── */
    .spell-prompt {
        text-align: center;
        margin-bottom: 30px;
    }
    .spell-emoji {
        font-size: 5rem;
        margin-bottom: 10px;
        display: block;
    }
    .spell-meaning {
        font-size: 1.4rem;
        font-weight: 800;
        color: #4338ca;
    }
    .spell-inputs-row {
        display: flex;
        gap: 10px;
        margin-bottom: 30px;
        justify-content: center;
        flex-wrap: wrap;
    }
    .spell-letter-box {
        width: 50px;
        height: 50px;
        border: 3px solid #cbd5e1;
        border-radius: 12px;
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 900;
        color: #1e293b;
    }
    .spell-letter-box.filled {
        background: #e0f2fe;
        border-color: #38bdf8;
        color: #0369a1;
        animation: scalePop 0.2s;
    }
    @@keyframes scalePop {
        0% { transform: scale(0.8); }
        100% { transform: scale(1); }
    }
    .scrambled-letters-row {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }
    .scrambled-btn {
        width: 55px;
        height: 55px;
        border-radius: 16px;
        border: 3px solid #e9d5ff;
        background: #faf5ff;
        font-size: 1.4rem;
        font-weight: 800;
        color: #6b21a8;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
    }
    .scrambled-btn:hover {
        transform: translateY(-3px);
        background: white;
        border-color: #a855f7;
    }
    .scrambled-btn.used {
        opacity: 0.3;
        pointer-events: none;
        transform: scale(0.9);
    }

    /* ──── GAME 4: BUBBLE POP ──── */
    .bubblepop-arena {
        position: relative;
        width: 100%;
        max-width: 600px;
        height: 380px;
        background: linear-gradient(to bottom, #ecfeff, #e0f2fe);
        border: 4px solid #38bdf8;
        border-radius: 24px;
        overflow: hidden;
        margin-bottom: 20px;
    }
    .bubblepop-target {
        font-size: 1.4rem;
        font-weight: 900;
        color: #0369a1;
        background: white;
        padding: 10px 25px;
        border-radius: 20px;
        border: 3px solid #38bdf8;
        margin-bottom: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }
    .floating-bubble {
        position: absolute;
        bottom: -70px;
        width: 75px;
        height: 75px;
        border-radius: 50%;
        background: rgba(56, 189, 248, 0.85);
        border: 3px solid #0284c7;
        box-shadow: inset 0 0 10px rgba(255,255,255,0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 800;
        font-size: 0.95rem;
        cursor: pointer;
        transition: transform 0.1s;
    }
    .floating-bubble:hover {
        transform: scale(1.1);
    }

    /* ──── GAME 5: WORD-MEANING CONNECTOR ──── */
    .connector-box {
        display: flex;
        justify-content: space-between;
        width: 100%;
        max-width: 650px;
        gap: 80px;
        position: relative;
    }
    .connector-column {
        display: flex;
        flex-direction: column;
        gap: 15px;
        flex: 1;
        position: relative;
        z-index: 5;
    }
    .connect-item {
        background: #faf5ff;
        border: 3px solid #e9d5ff;
        border-radius: 18px;
        padding: 15px 20px;
        font-weight: 800;
        font-size: 1.05rem;
        color: #4c1d95;
        cursor: pointer;
        text-align: center;
        transition: all 0.25s;
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
    }
    .connect-item:hover {
        background: white;
        border-color: #a855f7;
        transform: translateY(-2px);
    }
    .connect-item.selected {
        background: #f3e8ff;
        border-color: #a855f7;
        box-shadow: 0 0 12px rgba(168, 85, 247, 0.4);
    }
    .connect-item.matched {
        background: #dcfce7;
        border-color: #4ade80;
        color: #16a34a;
        cursor: default;
        pointer-events: none;
        opacity: 0.85;
    }

    /* Progress bar */
    .game-progress-container {
        width: 100%;
        max-width: 550px;
        height: 16px;
        background: #e2e8f0;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 25px;
    }
    .game-progress-bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #ec6090, #a855f7);
        border-radius: 8px;
        transition: width 0.4s ease;
    }

    /* Animations */
    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-8px); }
        75% { transform: translateX(8px); }
    }
</style>

<div class="game-play-section">
    <div class="container">
        <!-- Status Header -->
        <div class="game-header animate__animated animate__fadeInDown">
            <a href="/Game/Index" class="btn-exit"><i class="fas fa-sign-out-alt"></i> Thoát</a>
            <div class="lesson-title-badge"><i class="fa-solid fa-graduation-cap" style="color: #6b21a8;"></i> @Model.LessonName</div>
            <div class="star-counter-badge"><i class="fas fa-star"></i> <span>10 sao</span></div>
        </div>

        <!-- Game Arena -->
        <div class="arena-card animate__animated animate__fadeInUp">
            <h2 class="arena-title" id="game-title-text">Đang tải trò chơi...</h2>

            <!-- Progress Bar (Used in Listen, Spelling, BubblePop) -->
            <div class="game-progress-container" id="progress-container" style="display: none;">
                <div class="game-progress-bar" id="progress-bar"></div>
            </div>

            <!-- Game Containers -->
            <div id="game-arena-content" style="width: 100%; display: flex; flex-direction: column; align-items: center;">
                <!-- HTML elements for games will be injected/rendered here -->
            </div>

            <!-- Success Overlay -->
            <div class="reward-overlay" id="reward-overlay">
                <i class="fa-solid fa-trophy trophy-glow"></i>
                <h3 class="reward-title">Tuyệt Vời Ông Mặt Trời!</h3>
                <p class="reward-subtitle">Con đã xuất sắc vượt qua toàn bộ thử thách từ vựng!</p>
                <div class="reward-stars-earned">
                    <i class="fas fa-star"></i> +10 Xu Sao Thưởng
                </div>
                <p style="font-weight: 800; color: #db2777; margin-bottom: 20px; font-size: 1.1rem;">Tích lũy thật nhiều xu sao để đổi những phần quà VIP siêu hấp dẫn tại Cửa Hàng Sao nhé!</p>
                <div class="reward-actions">
                    <button class="btn-reward-action btn-reward-replay" onclick="window.location.reload()"><i class="fas fa-redo"></i> Chơi Lại</button>
                    <button class="btn-reward-action btn-reward-back" onclick="window.location.href='/Game/Index'"><i class="fas fa-arrow-left"></i> Quay Lại Chọn Bài</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Audio voice synth
    let synthesisVoice = null;
    function loadVoices() {
        if ('speechSynthesis' in window) {
            const voices = window.speechSynthesis.getVoices();
            // Try to find an English (en-US or en-GB) voice
            synthesisVoice = voices.find(v => v.lang.startsWith('en-')) || voices[0];
        }
    }
    if ('speechSynthesis' in window) {
        window.speechSynthesis.onvoiceschanged = loadVoices;
        loadVoices();
    }

    function speakEnglish(word) {
        if ('speechSynthesis' in window && word) {
            window.speechSynthesis.cancel(); // cancel any active speech
            const utterance = new SpeechSynthesisUtterance(word);
            utterance.lang = 'en-US';
            if (synthesisVoice) utterance.voice = synthesisVoice;
            utterance.rate = 0.85; // slightly slower for children's learning
            window.speechSynthesis.speak(utterance);
        }
    }

    // Dynamic Vocab List parsed from database model
    const vocabListRaw = @Html.Raw(Model.VocabularyJson);
    // Shuffle helper
    function shuffleArray(array) {
        return array.map(value => ({ value, sort: Math.random() }))
                    .sort((a, b) => a.sort - b.sort)
                    .map(({ value }) => value);
    }

    // Prepare active vocab list
    const vocabData = vocabListRaw && vocabListRaw.length > 0 ? vocabListRaw : [
        { word: "Hello", phonetic: "/həˈləʊ/", meaning: "Xin chào", emoji: "👋" },
        { word: "Goodbye", phonetic: "/ˌɡʊdˈbaɪ/", meaning: "Tạm biệt", emoji: "👋" },
        { word: "Friend", phonetic: "/frend/", meaning: "Người bạn", emoji: "🧑‍🤝‍🧑" }
    ];

    const gameType = "@gameType";
    const lessonId = @lessonId;

    document.addEventListener("DOMContentLoaded", function() {
        initGame();
    });

    function initGame() {
        if (gameType === "MemoryMatch") {
            initMemoryMatch();
        } else if (gameType === "ListenChoose") {
            initListenChoose();
        } else if (gameType === "Spelling") {
            initSpelling();
        } else if (gameType === "BubblePop") {
            initBubblePop();
        } else if (gameType === "Connector") {
            initConnector();
        }
    }

    // Award rewards via API
    let rewardSubmitted = false;
    function submitReward() {
        if (rewardSubmitted) return;
        rewardSubmitted = true;

        // Confetti explosion
        confetti({
            particleCount: 150,
            spread: 80,
            origin: { y: 0.6 }
        });

        // POST request to submit star rewards
        fetch('/Game/SubmitReward', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ lessonId: lessonId, gameType: gameType })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                // Play triumph sound / effect
                document.getElementById('reward-overlay').classList.add('show');
                // Update Layout session header star count immediately in UI if element is present
                const layoutStars = document.querySelector('.header-area .main-nav .profile-link span[style*="background: linear-gradient"]');
                if (layoutStars) {
                    layoutStars.innerHTML = `<i class="fas fa-star" style="color: white !important;"></i> ${data.totalStars}`;
                }
            } else {
                console.error("Star submission failed:", data.message);
                document.getElementById('reward-overlay').classList.add('show');
            }
        })
        .catch(err => {
            console.error("Error submitting stars:", err);
            document.getElementById('reward-overlay').classList.add('show');
        });
    }

    // ──────────────────────────────────────────────────────────
    // GAME 1: MEMORY MATCH CARDS LOGIC
    // ──────────────────────────────────────────────────────────
    function initMemoryMatch() {
        document.getElementById('game-title-text').innerText = "🎴 Trò Chơi Lật Thẻ Trí Nhớ";
        const arena = document.getElementById('game-arena-content');
        arena.innerHTML = `<div class="memory-grid" id="memory-grid"></div>`;

        // We take up to 6 words to make a 12-card grid (English & Vietnamese matching)
        const activeWords = vocabData.slice(0, 6);
        let cards = [];
        activeWords.forEach((item, index) => {
            cards.push({ id: index, type: 'english', text: item.word, emoji: item.emoji, matchId: index });
            cards.push({ id: index, type: 'meaning', text: item.meaning, emoji: item.emoji, matchId: index });
        });

        cards = shuffleArray(cards);
        const grid = document.getElementById('memory-grid');

        cards.forEach((card, idx) => {
            const cardEl = document.createElement('div');
            cardEl.className = 'memory-card';
            cardEl.dataset.idx = idx;
            cardEl.dataset.matchId = card.matchId;
            cardEl.dataset.type = card.type;
            cardEl.dataset.text = card.text;

            cardEl.innerHTML = `
                <div class="card-inner">
                    <div class="card-front"><i class="fa-solid fa-question"></i></div>
                    <div class="card-back">
                        <span style="font-size: 2.2rem; margin-bottom: 5px; display:block;">${card.emoji || "✨"}</span>
                        <span>${card.text}</span>
                    </div>
                </div>
            `;
            cardEl.addEventListener('click', flipCard);
            grid.appendChild(cardEl);
        });

        let firstCard = null;
        let secondCard = null;
        let lockGrid = false;
        let matchedCount = 0;

        function flipCard() {
            if (lockGrid) return;
            if (this === firstCard) return;

            this.classList.add('flipped');

            // Speak English card
            if (this.dataset.type === 'english') {
                speakEnglish(this.dataset.text);
            }

            if (!firstCard) {
                firstCard = this;
                return;
            }

            secondCard = this;
            checkMatch();
        }

        function checkMatch() {
            lockGrid = true;
            const isMatch = firstCard.dataset.matchId === secondCard.dataset.matchId;

            if (isMatch) {
                // If the second card is the english one, play its audio
                if (secondCard.dataset.type === 'english') {
                    speakEnglish(secondCard.dataset.text);
                }

                firstCard.classList.add('matched');
                secondCard.classList.add('matched');
                matchedCount++;
                resetCards();

                if (matchedCount === activeWords.length) {
                    setTimeout(submitReward, 800);
                }
            } else {
                setTimeout(() => {
                    firstCard.classList.remove('flipped');
                    secondCard.classList.remove('flipped');
                    resetCards();
                }, 1200);
            }
        }

        function resetCards() {
            firstCard = null;
            secondCard = null;
            lockGrid = false;
        }
    }

    // ──────────────────────────────────────────────────────────
    // GAME 2: LISTEN & BUBBLE CATCH LOGIC
    // ──────────────────────────────────────────────────────────
    function initListenChoose() {
        document.getElementById('game-title-text').innerText = "🎈 Nghe Phát Âm Chọn Từ Đúng";
        document.getElementById('progress-container').style.display = 'block';

        const arena = document.getElementById('game-arena-content');
        arena.innerHTML = `
            <div class="listen-speaker-btn" id="speaker-btn"><i class="fa-solid fa-volume-high"></i></div>
            <p style="font-weight: 800; color: #4338ca; font-size: 1.1rem; margin-bottom: 25px;">Nhấp vào chiếc loa hồng để nghe phát âm, sau đó chọn từ tương ứng!</p>
            <div class="bubble-answers-grid" id="bubble-grid"></div>
        `;

        let currentIdx = 0;
        const totalWords = Math.min(5, vocabData.length);
        const gameWords = shuffleArray(vocabData).slice(0, totalWords);

        document.getElementById('speaker-btn').addEventListener('click', () => {
            speakEnglish(gameWords[currentIdx].word);
        });

        function loadQuestion() {
            if (currentIdx >= totalWords) {
                submitReward();
                return;
            }

            // Update Progress Bar
            document.getElementById('progress-bar').style.width = `${(currentIdx / totalWords) * 100}%`;

            const currentItem = gameWords[currentIdx];
            setTimeout(() => { speakEnglish(currentItem.word); }, 400);

            // Generate choices
            let choices = [currentItem];
            const otherPool = vocabData.filter(v => v.word !== currentItem.word);
            const shuffledOther = shuffleArray(otherPool);
            choices = choices.concat(shuffledOther.slice(0, 3));
            choices = shuffleArray(choices);

            const grid = document.getElementById('bubble-grid');
            grid.innerHTML = '';

            choices.forEach(choice => {
                const btn = document.createElement('button');
                btn.className = 'bubble-btn';
                btn.innerHTML = `<span style="font-size: 1.8rem; display: block; margin-bottom: 5px;">${choice.emoji || "✨"}</span> ${choice.word}`;
                btn.addEventListener('click', () => handleAnswer(choice, btn));
                grid.appendChild(btn);
            });
        }

        let lockAnswer = false;
        function handleAnswer(choice, btnElement) {
            if (lockAnswer) return;
            lockAnswer = true;

            const currentItem = gameWords[currentIdx];
            if (choice.word === currentItem.word) {
                btnElement.classList.add('correct');
                confetti({ particleCount: 30, spread: 40, origin: { y: 0.8 } });
                currentIdx++;
                setTimeout(() => {
                    lockAnswer = false;
                    loadQuestion();
                }, 1200);
            } else {
                btnElement.classList.add('wrong');
                speakEnglish(currentItem.word); // re-speak target to guide student
                setTimeout(() => {
                    btnElement.classList.remove('wrong');
                    lockAnswer = false;
                }, 1000);
            }
        }

        loadQuestion();
    }

    // ──────────────────────────────────────────────────────────
    // GAME 3: SPELLING BEE SCRAMBLE LOGIC
    // ──────────────────────────────────────────────────────────
    function initSpelling() {
        document.getElementById('game-title-text').innerText = "🐝 Đại Sứ Đánh Vần Tiếng Anh";
        document.getElementById('progress-container').style.display = 'block';

        const arena = document.getElementById('game-arena-content');
        arena.innerHTML = `
            <div class="spell-prompt">
                <span class="spell-emoji" id="spell-emoji">🍎</span>
                <span class="spell-meaning" id="spell-meaning">Quả táo</span>
            </div>
            <div class="spell-inputs-row" id="spell-inputs-row"></div>
            <div class="scrambled-letters-row" id="scrambled-row"></div>
            <button id="spell-speak-btn" style="margin-top: 25px; background: #e0f2fe; color: #0284c7; font-weight:800; border:none; padding:10px 20px; border-radius:15px; cursor:pointer;"><i class="fa-solid fa-volume-high"></i> Nghe đọc từ</button>
        `;

        let currentIdx = 0;
        const totalWords = Math.min(5, vocabData.length);
        const gameWords = shuffleArray(vocabData).slice(0, totalWords);

        let spelledLetters = [];
        let wordLetters = [];

        document.getElementById('spell-speak-btn').addEventListener('click', () => {
            speakEnglish(gameWords[currentIdx].word);
        });

        function loadWord() {
            if (currentIdx >= totalWords) {
                submitReward();
                return;
            }

            document.getElementById('progress-bar').style.width = `${(currentIdx / totalWords) * 100}%`;

            const currentItem = gameWords[currentIdx];
            setTimeout(() => { speakEnglish(currentItem.word); }, 400);

            document.getElementById('spell-emoji').innerText = currentItem.emoji || "✨";
            document.getElementById('spell-meaning').innerText = currentItem.meaning;

            spelledLetters = [];
            wordLetters = currentItem.word.split('');

            // Create blank letter boxes
            const inputsRow = document.getElementById('spell-inputs-row');
            inputsRow.innerHTML = '';
            wordLetters.forEach(() => {
                const box = document.createElement('div');
                box.className = 'spell-letter-box';
                inputsRow.appendChild(box);
            });

            // Create scrambled button row
            const scrambledRow = document.getElementById('scrambled-row');
            scrambledRow.innerHTML = '';

            let indexedLetters = wordLetters.map((char, index) => ({ char, index }));
            indexedLetters = shuffleArray(indexedLetters);

            indexedLetters.forEach(item => {
                const btn = document.createElement('button');
                btn.className = 'scrambled-btn';
                btn.innerText = item.char;
                btn.addEventListener('click', () => tapLetter(item.char, item.index, btn));
                scrambledRow.appendChild(btn);
            });
        }

        function tapLetter(char, origIndex, btnElement) {
            const nextEmptyIdx = spelledLetters.length;
            const targetChar = wordLetters[nextEmptyIdx];

            // Verify if spelled character matches spelling
            if (char.toLowerCase() === targetChar.toLowerCase()) {
                spelledLetters.push(char);
                btnElement.classList.add('used');

                // Fill spelling letter box
                const boxes = document.querySelectorAll('.spell-letter-box');
                boxes[nextEmptyIdx].innerText = char;
                boxes[nextEmptyIdx].classList.add('filled');

                // Check if spelling word is complete
                if (spelledLetters.length === wordLetters.length) {
                    confetti({ particleCount: 30, spread: 40, origin: { y: 0.8 } });
                    currentIdx++;
                    setTimeout(loadWord, 1000);
                }
            } else {
                // Incorrect letter animation
                btnElement.style.animation = 'shake 0.5s';
                btnElement.style.borderColor = '#fca5a5';
                btnElement.style.background = '#fee2e2';
                btnElement.style.color = '#dc2626';

                setTimeout(() => {
                    btnElement.style.animation = '';
                    btnElement.style.borderColor = '';
                    btnElement.style.background = '';
                    btnElement.style.color = '';
                }, 600);
            }
        }

        loadWord();
    }

    // ──────────────────────────────────────────────────────────
    // GAME 4: BUBBLE POP LOGIC
    // ──────────────────────────────────────────────────────────
    function initBubblePop() {
        document.getElementById('game-title-text').innerText = "🧼 Trò Chơi Bắn Bong Bóng Từ Vựng";
        document.getElementById('progress-container').style.display = 'block';

        const arena = document.getElementById('game-arena-content');
        arena.innerHTML = `
            <div class="bubblepop-target" id="bubble-target-text">Tìm nghĩa: Quả táo</div>
            <div class="bubblepop-arena" id="bubble-arena"></div>
        `;

        let currentIdx = 0;
        const totalWords = Math.min(5, vocabData.length);
        const gameWords = shuffleArray(vocabData).slice(0, totalWords);

        let activeIntervals = [];

        function loadRound() {
            // Clear existing elements & intervals
            activeIntervals.forEach(clearInterval);
            activeIntervals = [];
            const arenaBox = document.getElementById('bubble-arena');
            arenaBox.innerHTML = '';

            if (currentIdx >= totalWords) {
                submitReward();
                return;
            }

            document.getElementById('progress-bar').style.width = `${(currentIdx / totalWords) * 100}%`;

            const currentTarget = gameWords[currentIdx];
            document.getElementById('bubble-target-text').innerText = `Tìm từ tiếng Anh cho: "${currentTarget.meaning}"`;

            // Prepare choices
            let pool = [currentTarget];
            const others = vocabData.filter(v => v.word !== currentTarget.word);
            pool = pool.concat(shuffleArray(others).slice(0, 3));
            pool = shuffleArray(pool);

            // Spawn floating bubbles
            pool.forEach((vocabItem, idx) => {
                const bubble = document.createElement('div');
                bubble.className = 'floating-bubble';
                bubble.innerText = vocabItem.word;
                
                // Random position & speed
                const randomX = Math.random() * 80 + 5; // percentage
                bubble.style.left = `${randomX}%`;
                
                const speed = Math.random() * 2 + 1.5; // px per tick
                let bottomY = -70;

                arenaBox.appendChild(bubble);

                const interval = setInterval(() => {
                    bottomY += speed;
                    bubble.style.bottom = `${bottomY}px`;

                    // Reset to bottom if it floats past the top border
                    if (bottomY > 390) {
                        bottomY = -70;
                        bubble.style.left = `${Math.random() * 80 + 5}%`;
                    }
                }, 30);

                activeIntervals.push(interval);

                bubble.addEventListener('click', () => {
                    if (vocabItem.word === currentTarget.word) {
                        speakEnglish(vocabItem.word);
                        // Pop effect
                        bubble.style.transform = 'scale(1.4)';
                        bubble.style.opacity = '0';
                        bubble.style.transition = 'all 0.2s';
                        
                        confetti({ particleCount: 20, spread: 35, origin: { y: 0.7 } });
                        currentIdx++;
                        setTimeout(loadRound, 500);
                    } else {
                        // Shake wrong bubble
                        bubble.style.animation = 'shake 0.5s';
                        bubble.style.borderColor = '#ef4444';
                        setTimeout(() => {
                            bubble.style.animation = '';
                            bubble.style.borderColor = '';
                        }, 500);
                    }
                });
            });
        }

        loadRound();
    }

    // ──────────────────────────────────────────────────────────
    // GAME 5: WORD-MEANING CONNECTOR LOGIC
    // ──────────────────────────────────────────────────────────
    function initConnector() {
        document.getElementById('game-title-text').innerText = "🔗 Trò Chơi Nối Từ Thông Thái";
        const arena = document.getElementById('game-arena-content');
        arena.innerHTML = `
            <p style="font-weight: 800; color: #4338ca; font-size: 1.1rem; margin-bottom: 25px;">Hãy nhấp chọn từ Tiếng Anh ở bên trái, sau đó nhấp vào nghĩa tương ứng ở cột bên phải!</p>
            <div class="connector-box" id="connector-box">
                <div class="connector-column" id="english-col"></div>
                <div class="connector-column" id="meaning-col"></div>
            </div>
        `;

        const activeWords = vocabData.slice(0, 5);
        const englishList = shuffleArray(activeWords);
        const meaningList = shuffleArray(activeWords);

        const engCol = document.getElementById('english-col');
        const meanCol = document.getElementById('meaning-col');

        englishList.forEach(item => {
            const el = document.createElement('div');
            el.className = 'connect-item';
            el.dataset.id = item.word;
            el.innerHTML = `${item.emoji || "✨"} ${item.word}`;
            el.addEventListener('click', () => selectEnglish(item.word, el));
            engCol.appendChild(el);
        });

        meaningList.forEach(item => {
            const el = document.createElement('div');
            el.className = 'connect-item';
            el.dataset.matchId = item.word;
            el.innerText = item.meaning;
            el.addEventListener('click', () => selectMeaning(item.word, el));
            meanCol.appendChild(el);
        });

        let selectedEngWord = null;
        let selectedEngEl = null;
        let matchedCount = 0;

        function selectEnglish(word, el) {
            if (el.classList.contains('matched')) return;

            speakEnglish(word);

            // Toggle select
            document.querySelectorAll('#english-col .connect-item').forEach(x => x.classList.remove('selected'));
            el.classList.add('selected');
            selectedEngWord = word;
            selectedEngEl = el;
        }

        function selectMeaning(word, el) {
            if (el.classList.contains('matched')) return;
            if (!selectedEngWord) return;

            if (selectedEngWord === word) {
                // Correct match
                selectedEngEl.classList.remove('selected');
                selectedEngEl.classList.add('matched');
                el.classList.add('matched');

                confetti({ particleCount: 20, spread: 30, origin: { y: 0.8 } });

                selectedEngWord = null;
                selectedEngEl = null;
                matchedCount++;

                if (matchedCount === activeWords.length) {
                    setTimeout(submitReward, 800);
                }
            } else {
                // Incorrect match animation
                el.classList.add('wrong');
                el.style.animation = 'shake 0.5s';
                el.style.borderColor = '#fca5a5';
                el.style.background = '#fee2e2';
                el.style.color = '#dc2626';

                setTimeout(() => {
                    el.classList.remove('wrong');
                    el.style.animation = '';
                    el.style.borderColor = '';
                    el.style.background = '';
                    el.style.color = '';
                }, 600);
            }
        }
    }
</script>
