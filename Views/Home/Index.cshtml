                </div>
            </div>
            <div class="col-md-4">
                <div class="trust-card">
                    <div class="trust-stars">★★★★★</div>
                    <div class="trust-quote">"10 phút học mà hiệu quả hơn cả tiếng học ép buộc. Con bé 7 tuổi nhà tôi mỗi lần được sao là hét lên gọi mẹ khoe. Rất vui và nhẹ nhõm khi thấy con thích học!"</div>
                    <div class="trust-parent">
                        <div class="trust-avatar">👩</div>
                        <div>
                            <div class="trust-name">Chị Bảo Châu</div>
                            <div class="trust-desc">Phụ huynh bé lớp 1, Đà Nẵng</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== PACKAGE COMPARE ===== -->
<section class="pkg-compare">
    <div class="container">
        <h2 class="section-title text-center">💎 Chọn gói phù hợp cho bé</h2>
        <p class="section-sub text-center">Bắt đầu miễn phí 7 ngày — nâng cấp bất cứ lúc nào, không ràng buộc</p>
        <div class="row g-4 justify-content-center">
            <!-- Free Trial -->
            <div class="col-lg-4 col-md-6">
                <div class="pkg-card-hp">
                    <div class="pkg-tier">🎁 Dùng thử</div>
                    <div class="pkg-title-hp">Gói Học Thử Miễn Phí</div>
                    <div class="pkg-price-hp">0đ <small>/ 7 ngày</small></div>
                    <div class="pkg-value">Dùng thử miễn phí đầy đủ tính năng trong 7 ngày học tập, không bao gồm chứng chỉ hoàn thành.</div>
                    <ul class="pkg-features-hp">
                        <li><span class="feat-check">✓</span> 5 bài học mẫu đầy đủ tính năng</li>
                        <li><span class="feat-check">✓</span> Báo cáo mẫu cho phụ huynh</li>
                        <li><span class="feat-check">✓</span> Mascot con ong & phần thưởng sao</li>
                        <li><span class="feat-check">✓</span> Không cần thẻ tín dụng</li>
                    </ul>
                    @if (!User.Identity!.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn-pkg outline" id="pkg-free-btn">Bắt đầu miễn phí</a>
                    }
                    else if (User.IsInRole("Parent"))
                    {
                        <a asp-controller="Package" asp-action="List" class="btn-pkg outline">Xem gói</a>
                    }
                </div>
            </div>
            <!-- Basic -->
            <div class="col-lg-4 col-md-6">
                <div class="pkg-card-hp">
                    <div class="pkg-tier">🌱 Nền tảng</div>
                    <div class="pkg-title-hp">Gói Cơ Bản (1 Tháng)</div>
                    <div class="pkg-price-hp">99.000đ <small>/ 1 tháng</small></div>
                    <div class="pkg-value">Học tiếng Anh 10 phút mỗi ngày bám sát lộ trình sách giáo khoa trong 1 tháng (30 ngày), không bao gồm chứng chỉ.</div>
                    <ul class="pkg-features-hp">
                        <li><span class="feat-check">✓</span> Ứng dụng công nghệ AI tự động điều chỉnh lộ trình học phù hợp với sức học của bé.</li>
                        <li><span class="feat-check">✓</span> Hệ thống tự động tạo đề luyện tập với AI và đưa ra gợi ý bài học tại nhà hàng tuần.</li>
                        <li><span class="feat-check">✓</span> Gửi báo cáo chi tiết kết quả học tập tự động cho phụ huynh vào cuối tuần.</li>
                    </ul>
                    @if (!User.Identity!.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn-pkg outline" id="pkg-basic-btn">Chọn gói này</a>
                    }
                    else if (User.IsInRole("Parent"))
                    {
                        <a asp-controller="Package" asp-action="List" class="btn-pkg outline">Xem & mua</a>
                    }
                </div>
            </div>
            <!-- Premium (Featured) -->
            <div class="col-lg-4 col-md-6">
                <div class="pkg-card-hp featured-hp">
                    <div class="featured-badge-hp">⭐ Phổ biến nhất</div>
                    <div class="pkg-tier" style="color:#e75485;">👑 Cao cấp</div>
                    <div class="pkg-title-hp">Gói Cao Cấp (6 Tháng)</div>
                    <div class="pkg-price-hp">499.000đ <small>/ 6 tháng</small></div>
                    <div class="pkg-value">Trọn bộ lộ trình cá nhân hóa + Báo cáo thông minh cho phụ huynh + Cấp chứng chỉ hoàn thành sau khi hoàn thành khóa học trong 6 tháng (180 ngày).</div>
                    <ul class="pkg-features-hp">
                        <li><span class="feat-check">✓</span> Gói dài hạn nhất, tối ưu trọn bộ lộ trình cá nhân hóa nâng cao trong vòng 6 tháng.</li>
                        <li><span class="feat-check">✓</span> Hệ thống báo cáo thông minh, phân tích toàn diện mọi chỉ số học tập dành riêng cho phụ huynh.</li>
                        <li><span class="feat-check">✓</span> Tự động cấp Chứng nhận hoàn thành khóa học sau khi bé hoàn thành lộ trình 6 tháng.</li>
                    </ul>
                    @if (!User.Identity!.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn-pkg" id="pkg-premium-btn">Bắt đầu ngay →</a>
                    }
                    else if (User.IsInRole("Parent"))
                    {
                        <a asp-controller="Package" asp-action="List" class="btn-pkg">Xem & mua →</a>
                    }
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a asp-controller="Package" asp-action="List" class="btn-pkg outline" style="width:auto;display:inline-block;padding:12px 32px;">Xem chi tiết tất cả gói →</a>
        </div>
    </div>
</section>

<!-- ===== FINAL CTA ===== -->
<section class="cta-section">
    <div class="cta-floating f1">🐝</div>
    <div class="cta-floating f2">⭐</div>
    <div class="cta-floating f3">🎨</div>
    <div class="container" style="position:relative;z-index:1;text-align:center;">
        <h2 style="font-family:'Nunito',sans-serif;font-size:2.3rem;font-weight:900;margin-bottom:14px;">
            Cho bé bắt đầu yêu Tiếng Anh ngay hôm nay! 🚀
        </h2>
        <p style="font-size:1.05rem;margin:0 auto 36px;opacity:.9;max-width:520px;line-height:1.75;">
            7 ngày dùng thử miễn phí — không cần thẻ tín dụng.<br>
            Thiết kế riêng cho trẻ <strong>lớp 1 & lớp 2 (6–7 tuổi)</strong>.
        </p>
        @if (!User.Identity!.IsAuthenticated)
        {
            <a asp-controller="Account" asp-action="Register" class="hero-btn" id="cta-final-btn" style="font-size:1.1rem;padding:18px 52px;background:linear-gradient(135deg,#fff3,#fff2);border:2px solid rgba(255,255,255,.6);backdrop-filter:blur(8px);">
                🎁 Cho bé học thử ngay — Miễn phí
            </a>
        }
        else if (User.IsInRole("Parent"))
        {
            <a asp-controller="Parent" asp-action="LinkedStudents" class="hero-btn">📊 Xem tiến bộ của bé →</a>
        }
        else
        {
            <a asp-controller="Chapter" asp-action="Index" class="hero-btn">📚 Tiếp tục học →</a>
        }
    </div>
</section>
}

