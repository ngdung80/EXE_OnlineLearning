                    @if (!User.Identity!.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn-pkg outline" id="pkg-basic-btn">Chọn gói này</a>
                    }
                    else if (User.IsInRole("Parent"))
                    {
                        <a asp-controller="Package" asp-action="List" class="btn-pkg outline">Xem & mua</a>
                    }
                </div>
            </div>
            <!-- Standard (Featured) -->
            <div class="col-md-3 col-sm-6">
                <div class="pkg-card-hp featured-hp">
                    <div class="featured-badge-hp">⭐ Phổ biến nhất</div>
                    <div class="pkg-tier" style="color:#e75485;">🚀 Cá nhân hóa</div>
                    <div class="pkg-title-hp">Standard</div>
                    <div class="pkg-price-hp">249.000đ <small>/ tháng</small></div>
                    <div class="pkg-value">AI điều chỉnh lộ trình + báo cáo tuần đầy đủ cho phụ huynh</div>
                    <ul class="pkg-features-hp">
