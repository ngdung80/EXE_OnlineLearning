@model List<POT_System_ASPNET.Data.Entities.Chapter>
@{
    ViewData["Title"] = "Chương học";
    var subject = ViewBag.Subject as POT_System_ASPNET.Data.Entities.Subject;
}
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .ch-section {
        padding: 140px 0 80px;
        background: transparent !important;
        min-height: 80vh;
        position: relative;
        overflow: hidden;
        font-family: 'Nunito', sans-serif !important;
        color: #1e1b4b;
    }
    .ch-section *:not(i):not(.fa) {
        font-family: 'Nunito', sans-serif !important;
    }

    .breadcrumb-bar { display:flex; align-items:center; gap:8px; color:#6b7280; font-size:.95rem; margin-bottom:20px; font-weight: 700; position: relative; z-index: 10; }
    .breadcrumb-bar a { color:#ec6090; text-decoration:none; }
    .breadcrumb-bar a:hover { text-decoration:underline; }

    .section-hd { display:flex; justify-content:space-between; align-items:center; margin-bottom:30px; position: relative; z-index: 10; }
    .section-hd h2 { color:#ec6090; font-weight:900; margin:0; font-size: 2.2rem; }
    
    .btn-add { display:inline-flex; align-items:center; gap:8px; padding:12px 28px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff !important; border-radius:25px; text-decoration:none; font-weight:800; font-size:.9rem; transition:all .3s cubic-bezier(0.175, 0.885, 0.32, 1.275); box-shadow: 0 5px 15px rgba(236, 96, 144, 0.2); }
    .btn-add:hover { transform:translateY(-2px) scale(1.02); box-shadow:0 8px 20px rgba(236,96,144,.4); }

    .ch-list { display:flex; flex-direction:column; gap:16px; position: relative; z-index: 10; }
    
    .ch-item {
        background: rgba(255, 255, 255, 0.88) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        border: 3px solid #fbcfe8 !important;
        border-radius: 30px !important;
        padding: 24px 30px !important;
        display: flex;
        align-items: center;
        gap: 25px;
        box-shadow: 0 10px 25px rgba(236, 96, 144, 0.05) !important;
        transition: all 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
    }
    .ch-item:hover {
        transform: translateY(-5px) scale(1.01) !important;
        box-shadow: 0 15px 35px rgba(168, 85, 247, 0.15), 0 0 0 6px rgba(244, 63, 94, 0.08) !important;
        border-color: #f472b6 !important;
    }

    .ch-num {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #ec6090, #e75485) !important;
        border-radius: 18px !important;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff !important;
        font-weight: 900 !important;
        font-size: 1.4rem !important;
        box-shadow: 0 5px 15px rgba(236, 96, 144, 0.2) !important;
        flex-shrink: 0;
    }
    .ch-info { flex:1; }
    .ch-name { color:#1e1b4b; font-weight:900; font-size:1.3rem; margin-bottom:6px; }
    .ch-desc { color:#4b5563; font-size:.95rem; font-weight: 700; }
    .ch-actions { display:flex; align-items:center; gap:12px; flex-shrink:0; }
    
    .badge-active { display:inline-block; padding:6px 14px; background:rgba(16,185,129,.1); color:#10b981; border-radius:20px; font-size:.8rem; font-weight:800; border: 1px solid rgba(16,185,129,.2); }
    .badge-inactive { display:inline-block; padding:6px 14px; background:rgba(239,68,68,.1); color:#ef4444; border-radius:20px; font-size:.8rem; font-weight:800; border: 1px solid rgba(239,68,68,.2); }
    
    .btn-lessons { padding:8px 18px; background:rgba(236,96,144,.1); color:#ec6090 !important; border-radius:20px; text-decoration:none; font-size:.85rem; font-weight:800; transition:all .2s; border: 1px solid rgba(236,96,144,.2); }
    .btn-lessons:hover { background:rgba(236,96,144,.2); transform: translateY(-1px); }
    
    .btn-sm-action { padding:8px 16px; border-radius:20px; font-size:.85rem; font-weight:800; border:none; cursor:pointer; transition:all .2s; text-decoration:none; display: inline-flex; align-items: center; justify-content: center; }
    .btn-edit-sm { background:rgba(59,130,246,.1); color:#3b82f6 !important; border: 1px solid rgba(59,130,246,.2); }
    .btn-edit-sm:hover { background:rgba(59,130,246,.2); transform: translateY(-1px); }
    .btn-del-sm { background:rgba(239,68,68,.1); color:#ef4444 !important; border: 1px solid rgba(239,68,68,.2); }
    .btn-del-sm:hover { background:rgba(239,68,68,.2); transform: translateY(-1px); }
    
    .empty-state { text-align:center; padding:60px; color:#4b5563; position: relative; z-index: 10; font-weight: 800; }

    .kid-bg-cloud {
        position: absolute;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 100px;
        pointer-events: none;
        z-index: 1;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02);
    }
    .kid-bg-cloud::before, .kid-bg-cloud::after {
        content: '';
        position: absolute;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 50%;
    }
    .kid-bg-cloud.c1 {
        width: 120px; height: 40px; top: 12%; left: 8%;
        animation: floatCloud 24s linear infinite;
    }
    .kid-bg-cloud.c1::before { width: 50px; height: 50px; top: -25px; left: 15px; }
    .kid-bg-cloud.c1::after { width: 70px; height: 70px; top: -35px; right: 15px; }

    .kid-bg-cloud.c2 {
        width: 160px; height: 50px; bottom: 15%; right: 8%;
        animation: floatCloudReverse 28s linear infinite;
    }
    .kid-bg-cloud.c2::before { width: 70px; height: 70px; top: -35px; left: 20px; }
    .kid-bg-cloud.c2::after { width: 90px; height: 90px; top: -45px; right: 20px; }

    @@keyframes floatCloud {
        0% { transform: translateX(0); }
        50% { transform: translateX(50px); }
        100% { transform: translateX(0); }
    }
    @@keyframes floatCloudReverse {
        0% { transform: translateX(0); }
        50% { transform: translateX(-50px); }
        100% { transform: translateX(0); }
    }

    .kid-bg-star {
        position: absolute;
        font-size: 2.5rem;
        color: #f59e0b;
        opacity: 0.35;
        pointer-events: none;
        z-index: 5;
    }
    .kid-bg-star.s1 { top: 15%; right: 12%; animation: orbitRight 14s ease-in-out infinite alternate; }
    .kid-bg-star.s2 { bottom: 18%; left: 10%; animation: orbitLeft 17s ease-in-out infinite alternate; color: #fbbf24; }
    .kid-bg-star.s3 { top: 45%; left: 6%; animation: floatAroundVertical 11s ease-in-out infinite alternate; font-size: 1.8rem; color: #fca5a5; }
    .kid-bg-star.s4 { bottom: 40%; right: 6%; animation: floatAroundHorizontal 15s ease-in-out infinite alternate; font-size: 2rem; color: #38bdf8; }
    .kid-bg-star.s5 { top: 10%; left: 25%; animation: diagonalFloat 20s ease-in-out infinite alternate; font-size: 1.6rem; color: #c084fc; }

    @@keyframes orbitRight {
        0% { transform: translate(0, 0) rotate(0deg) scale(1); }
        35% { transform: translate(45px, -70px) rotate(120deg) scale(1.25); }
        70% { transform: translate(-30px, -120px) rotate(240deg) scale(0.8); }
        100% { transform: translate(0, 0) rotate(360deg) scale(1); }
    }
    @@keyframes orbitLeft {
        0% { transform: translate(0, 0) rotate(360deg) scale(0.9); }
        40% { transform: translate(-60px, 50px) rotate(180deg) scale(1.3); }
        80% { transform: translate(40px, -40px) rotate(0deg) scale(0.7); }
        100% { transform: translate(0, 0) rotate(-360deg) scale(0.9); }
    }
    @@keyframes floatAroundVertical {
        0% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-90px) rotate(180deg); }
        100% { transform: translateY(0) rotate(360deg); }
    }
    @@keyframes floatAroundHorizontal {
        0% { transform: translateX(0) rotate(0deg); }
        50% { transform: translateX(90px) rotate(-180deg); }
        100% { transform: translateX(0) rotate(-360deg); }
    }
    @@keyframes diagonalFloat {
        0% { transform: translate(0, 0) rotate(0deg); }
        50% { transform: translate(80px, 80px) rotate(180deg); }
        100% { transform: translate(0, 0) rotate(360deg); }
    }
</style>

@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Student"))
{
    ViewData["Title"] = "Chương Học Của Bé - PLO";
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&display=swap');

        .kid-ch-container {
            min-height: 80vh;
            padding: 120px 20px 80px;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .kid-breadcrumb {
            font-family: 'Nunito', sans-serif !important;
            font-weight: 800 !important;
            font-size: 1.1rem !important;
            margin-bottom: 25px !important;
            color: #6366f1 !important;
            z-index: 10;
        }

        .kid-breadcrumb a {
            color: #ec6090 !important;
            text-decoration: none !important;
        }

        .kid-ch-header {
            text-align: center;
            margin-bottom: 50px;
            z-index: 10;
        }

        .kid-ch-title {
            font-family: 'Nunito', sans-serif !important;
            font-weight: 900 !important;
            font-size: 3rem !important;
            background: linear-gradient(135deg, #ec6090 0%, #a855f7 50%, #4f46e5 100%) !important;
            -webkit-background-clip: text !important;
            -webkit-text-fill-color: transparent !important;
            margin-bottom: 15px !important;
            display: inline-block;
        }

        .kid-ch-sub {
            font-family: 'Nunito', sans-serif !important;
            font-weight: 800 !important;
            font-size: 1.5rem !important;
            color: #4f46e5 !important;
        }

        .kid-ch-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
            max-width: 900px;
            width: 100%;
            z-index: 10;
        }

        .kid-ch-item {
            background: rgba(255, 255, 255, 0.88) !important;
            backdrop-filter: blur(20px) !important;
            -webkit-backdrop-filter: blur(20px) !important;
            border: 3px solid #fbcfe8 !important;
            border-radius: 30px !important;
            padding: 25px 30px !important;
            display: flex;
            align-items: center;
            gap: 25px;
            box-shadow: 0 10px 25px rgba(236, 96, 144, 0.06) !important;
            transition: all 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
            position: relative;
            overflow: hidden;
        }

        .kid-ch-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: -150%;
            width: 50%;
            height: 100%;
            background: linear-gradient(
                to right,
                rgba(255, 255, 255, 0) 0%,
                rgba(255, 255, 255, 0.4) 50%,
                rgba(255, 255, 255, 0) 100%
            );
            transform: skewX(-25deg);
        }

        .kid-ch-item:hover::before {
            animation: sweepShineCh 1.8s ease-in-out infinite;
        }

        @@keyframes sweepShineCh {
            0% { left: -150%; }
            50% { left: 150%; }
            100% { left: 150%; }
        }

        .kid-ch-item:hover {
            transform: translateY(-8px) scale(1.02) !important;
            box-shadow: 0 15px 35px rgba(168, 85, 247, 0.15), 0 0 0 6px rgba(244, 63, 94, 0.08) !important;
            border-color: #f472b6 !important;
        }

        .kid-ch-num {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #ec6090, #e75485) !important;
            border-radius: 20px !important;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff !important;
            font-family: 'Nunito', sans-serif !important;
            font-weight: 900 !important;
            font-size: 1.6rem !important;
            box-shadow: 0 8px 20px rgba(236, 96, 144, 0.25) !important;
            flex-shrink: 0;
            animation: bounceNum 3s ease-in-out infinite alternate;
        }

        .kid-ch-item:nth-child(even) .kid-ch-num {
            background: linear-gradient(135deg, #a855f7, #8b5cf6) !important;
            box-shadow: 0 8px 20px rgba(168, 85, 247, 0.25) !important;
            animation-delay: 0.5s;
        }

        @@keyframes bounceNum {
            0% { transform: translateY(0) rotate(-4deg); }
            100% { transform: translateY(-6px) rotate(4deg); }
        }

        .kid-ch-info {
            flex: 1;
        }

        .kid-ch-name {
            font-family: 'Nunito', sans-serif !important;
            font-weight: 900 !important;
            font-size: 1.4rem !important;
            color: #1e1b4b !important;
            margin-bottom: 6px !important;
        }

        .kid-ch-desc {
            font-family: 'Nunito', sans-serif !important;
            font-weight: 700 !important;
            font-size: 1.05rem !important;
            color: #64748b !important;
        }

        .btn-kid-ch-action {
            display: inline-block;
            padding: 10px 24px !important;
            background: linear-gradient(135deg, #ec6090 0%, #e75485 100%) !important;
            color: #ffffff !important;
            border-radius: 99px !important;
            font-family: 'Nunito', sans-serif !important;
            font-weight: 900 !important;
            font-size: 1rem !important;
            text-decoration: none !important;
            box-shadow: 0 6px 15px rgba(236, 96, 144, 0.25) !important;
            transition: all 0.3s !important;
            flex-shrink: 0;
        }

        .btn-kid-ch-action:hover {
            transform: scale(1.05) !important;
            box-shadow: 0 10px 20px rgba(236, 96, 144, 0.4) !important;
            color: #ffffff !important;
        }

        /* Decorative Elements */
        .kid-bg-cloud {
            position: absolute;
            font-size: 5rem;
            opacity: 0.12;
            pointer-events: none;
            animation: floatCloud 25s linear infinite;
        }
        .kid-bg-cloud.c1 { top: 15%; left: -10%; animation-duration: 45s; }
        .kid-bg-cloud.c2 { bottom: 20%; right: -10%; animation-duration: 35s; animation-delay: -10s; }

        @@keyframes floatCloud {
            0% { transform: translateX(-150px); }
            100% { transform: translateX(110vw); }
        }

        .kid-bg-star {
            position: absolute;
            font-size: 2.5rem;
            color: #f59e0b;
            opacity: 0.35;
            pointer-events: none;
            z-index: 5;
        }
        .kid-bg-star.s1 { top: 15%; right: 12%; animation: orbitRight 14s ease-in-out infinite alternate; }
        .kid-bg-star.s2 { bottom: 18%; left: 10%; animation: orbitLeft 17s ease-in-out infinite alternate; color: #fbbf24; }
        .kid-bg-star.s3 { top: 45%; left: 6%; animation: floatAroundVertical 11s ease-in-out infinite alternate; font-size: 1.8rem; color: #fca5a5; }
        .kid-bg-star.s4 { bottom: 40%; right: 6%; animation: floatAroundHorizontal 15s ease-in-out infinite alternate; font-size: 2rem; color: #38bdf8; }
        .kid-bg-star.s5 { top: 10%; left: 25%; animation: diagonalFloat 20s ease-in-out infinite alternate; font-size: 1.6rem; color: #c084fc; }

        @@keyframes orbitRight {
            0% { transform: translate(0, 0) rotate(0deg) scale(1); }
            35% { transform: translate(45px, -70px) rotate(120deg) scale(1.25); }
            70% { transform: translate(-30px, -120px) rotate(240deg) scale(0.8); }
            100% { transform: translate(0, 0) rotate(360deg) scale(1); }
        }

        @@keyframes orbitLeft {
            0% { transform: translate(0, 0) rotate(360deg) scale(0.9); }
            40% { transform: translate(-60px, 50px) rotate(180deg) scale(1.3); }
            80% { transform: translate(40px, -40px) rotate(0deg) scale(0.7); }
            100% { transform: translate(0, 0) rotate(-360deg) scale(0.9); }
        }

        @@keyframes floatAroundVertical {
            0% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-90px) rotate(180deg); }
            100% { transform: translateY(0) rotate(360deg); }
        }

        @@keyframes floatAroundHorizontal {
            0% { transform: translateX(0) rotate(0deg); }
            50% { transform: translateX(90px) rotate(-180deg); }
            100% { transform: translateX(0) rotate(-360deg); }
        }

        @@keyframes diagonalFloat {
            0% { transform: translate(0, 0) rotate(0deg); }
            50% { transform: translate(120px, 90px) rotate(180deg); }
            100% { transform: translate(0, 0) rotate(360deg); }
        }

        /* Responsive Media Queries */
        @@media (max-width: 768px) {
            .kid-ch-title { font-size: 2.2rem !important; }
            .kid-ch-sub { font-size: 1.25rem !important; }
            .kid-ch-item { padding: 20px !important; gap: 15px; }
            .kid-ch-num { width: 50px; height: 50px; font-size: 1.3rem !important; }
        }

        @@media (max-width: 480px) {
            .kid-ch-title { font-size: 1.85rem !important; }
            .kid-ch-item { flex-direction: column; text-align: center; }
            .btn-kid-ch-action { width: 100%; }
        }
    </style>

    <div class="kid-ch-container">
        <!-- Floating cloud & star decorations -->
        <div class="kid-bg-cloud c1">☁️</div>
        <div class="kid-bg-cloud c2">☁️</div>
        <div class="kid-bg-star s1">⭐</div>
        <div class="kid-bg-star s2">⭐</div>
        <div class="kid-bg-star s3">⭐</div>
        <div class="kid-bg-star s4">⭐</div>
        <div class="kid-bg-star s5">⭐</div>

        <div class="kid-breadcrumb">
            <a asp-controller="Grade" asp-action="Index">🎒 Khối lớp</a>
            <span>›</span>
            <a asp-controller="Subject" asp-action="Index" asp-route-gradeId="@subject?.GradeId">@subject?.Grade?.GradeName</a>
            <span>›</span>
            <span>@subject?.SubjectName</span>
        </div>

        <div class="kid-ch-header">
            <h1 class="kid-ch-title">Chọn Chương Học Của Bé</h1>
            <p class="kid-ch-sub">Bé muốn học chương học nào hôm nay thế nhỉ? 🎒</p>
        </div>

        <div class="kid-ch-list">
            @if (Model != null && Model.Any())
            {
                int n = 1;
                foreach (var ch in Model)
                {
                    <div class="kid-ch-item">
                        <div class="kid-ch-num">@n++</div>
                        <div class="kid-ch-info">
                            <h2 class="kid-ch-name">@ch.ChapterName</h2>
                            <p class="kid-ch-desc">@(ch.Description ?? "Khám phá các bài học thú vị bên trong!")</p>
                        </div>
                        <a asp-controller="Lesson" asp-action="Index" asp-route-chapterId="@ch.ChapterId" class="btn-kid-ch-action">📖 Học Bài Ngay</a>
                    </div>
                }
            }
            else
            {
                <div style="background:rgba(255,255,255,0.85); padding:40px; border-radius:30px; border:3px solid #fbcfe8; text-align:center;">
                    <span style="font-size:4rem;">🤔</span>
                    <p style="font-family:'Nunito',sans-serif; font-size:1.2rem; font-weight:800; color:#4f46e5; margin-top:15px;">Chưa tìm thấy chương học nào cho bé.</p>
                </div>
            }
        </div>
    </div>
}
else
{
    <!-- Clouds -->
    <div class="kid-bg-cloud c1"></div>
    <div class="kid-bg-cloud c2"></div>

    <!-- Stars -->
    <div class="kid-bg-star s1">⭐</div>
    <div class="kid-bg-star s2">✨</div>
    <div class="kid-bg-star s3">🌟</div>
    <div class="kid-bg-star s4">⭐</div>
    <div class="kid-bg-star s5">✨</div>

    <section class="ch-section">
        <div class="container">
            <div class="breadcrumb-bar">
                <a asp-controller="Grade" asp-action="Index">Khối lớp</a>
                <span>›</span>
                <a asp-controller="Subject" asp-action="Index" asp-route-gradeId="@subject?.GradeId">@subject?.Grade?.GradeName</a>
                <span>›</span>
                <span style="color:#1e1b4b;">@subject?.SubjectName</span>
            </div>
            <div class="section-hd">
                <h2>📑 @(subject?.SubjectName ?? "Chương học")</h2>
                @if (User.IsInRole("Admin") || User.IsInRole("Content Manager"))
                {
                    <a asp-action="Create" asp-route-subjectId="@subject?.SubjectId" class="btn-add"><i class="fas fa-plus"></i> Thêm chương học</a>
                }
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="ch-list">
                    @{ int n = 1; }
                    @foreach (var ch in Model)
                    {
                        <div class="ch-item">
                            <div class="ch-num">@n++</div>
                            <div class="ch-info">
                                <div class="ch-name">@ch.ChapterName</div>
                                <div class="ch-desc">@(ch.Description ?? "Không có mô tả")</div>
                            </div>
                            <div class="ch-actions">
                                @if (ch.Status == "Active") { <span class="badge-active">Hoạt động</span> }
                                else { <span class="badge-inactive">@(ch.Status == "Inactive" ? "Không hoạt động" : ch.Status)</span> }
                                <a asp-controller="Lesson" asp-action="Index" asp-route-chapterId="@ch.ChapterId" class="btn-lessons">Bài học →</a>
                                @if (User.IsInRole("Admin") || User.IsInRole("Content Manager"))
                                {
                                    <a asp-action="Edit" asp-route-id="@ch.ChapterId" class="btn-sm-action btn-edit-sm">✏️</a>
                                    <form asp-action="Delete" asp-route-id="@ch.ChapterId" method="post" style="display:inline" onsubmit="return confirm('Xóa chương học này?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-sm-action btn-del-sm">🗑️</button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div style="font-size:3rem;margin-bottom:15px;">📂</div>
                    <p>Không tìm thấy chương học nào cho môn học này.</p>
                </div>
            }
        </div>
    </section>
}
