@model POT_System_ASPNET.Data.Entities.TestAttempt
@{
    ViewData["Title"] = "Kết quả kiểm tra";
    double pct = Model?.TotalQuestions > 0 ? (double)(Model.CorrectAnswers ?? 0) / Model.TotalQuestions.Value * 100 : 0;
    string grade = Model?.Score >= 9 ? "Xuất sắc" : Model?.Score >= 8 ? "Giỏi" : Model?.Score >= 7 ? "Khá" : Model?.Score >= 5 ? "Trung bình" : "Yếu";
    string gradeColor = Model?.Score >= 8 ? "#10b981" : Model?.Score >= 5 ? "#eab308" : "#ef4444";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .result-section { padding:80px 0; background:linear-gradient(135deg,#0f172a,#1e293b); min-height:80vh; }
    .result-card { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:20px; padding:40px; color:#fff; text-align:center; }
    .score-circle { width:160px; height:160px; border-radius:50%; margin:0 auto 20px; display:flex; flex-direction:column; align-items:center; justify-content:center; border:6px solid @gradeColor; background:rgba(255,255,255,.04); }
    .score-num { font-size:3rem; font-weight:800; color:@gradeColor; }
    .score-max { font-size:1rem; color:#94a3b8; }
    .grade-badge { font-size:2rem; font-weight:800; color:@gradeColor; margin-bottom:5px; }
    .result-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:16px; margin:30px 0; }
    .stat-box { background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08); border-radius:12px; padding:20px; }
    .stat-val { font-size:1.8rem; font-weight:700; color:#ec6090; }
    .stat-lbl { color:#94a3b8; font-size:.85rem; margin-top:4px; }
    .review-section { text-align:left; margin-top:30px; }
    .review-section h4 { color:#ec6090; font-weight:700; margin-bottom:20px; }
    .q-review { background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.08); border-radius:12px; padding:20px; margin-bottom:14px; }
    .q-review.correct { border-color:rgba(16,185,129,.3); }
    .q-review.wrong { border-color:rgba(239,68,68,.3); }
    .q-txt { font-weight:500; margin-bottom:12px; }
    .ans-row { display:flex; gap:8px; align-items:center; font-size:.88rem; margin-top:6px; }
    .ans-lbl { color:#64748b; min-width:90px; }
    .ans-correct { color:#10b981; font-weight:600; }
    .ans-wrong { color:#ef4444; font-weight:600; }
    .btn-back { display:inline-block; padding:12px 30px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff; border-radius:25px; text-decoration:none; font-weight:700; margin-top:20px; }
    .btn-back:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(236,96,144,.4); color:#fff; }
    .progress-wrap { background:rgba(255,255,255,.08); border-radius:10px; height:10px; margin:15px 0; }
    .progress-fill { height:100%; background:linear-gradient(135deg,@gradeColor,@gradeColor); border-radius:10px; transition:width .5s ease; }
</style>

<section class="result-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="result-card">
                    <div class="score-circle">
                        <div class="score-num">@Model?.Score?.ToString("F1")</div>
                        <div class="score-max">/10</div>
                    </div>
                    <div class="grade-badge">Xếp loại: @grade</div>
                    <p style="color:#94a3b8;">@Model?.Test?.TestName</p>
                    <div class="progress-wrap"><div class="progress-fill" style="width:@pct%"></div></div>

                    <div class="result-stats">
                        <div class="stat-box"><div class="stat-val">@Model?.CorrectAnswers</div><div class="stat-lbl">✅ Đúng</div></div>
                        <div class="stat-box"><div class="stat-val">@((Model?.TotalQuestions ?? 0) - (Model?.CorrectAnswers ?? 0))</div><div class="stat-lbl">❌ Sai</div></div>
                        <div class="stat-box"><div class="stat-val">@Model?.TotalQuestions</div><div class="stat-lbl">📝 Tổng số câu</div></div>
                        <div class="stat-box"><div class="stat-val">@pct.ToString("F0")%</div><div class="stat-lbl">📊 Tỷ lệ chính xác</div></div>
                    </div>

                    <!-- Question Review -->
                    @if (Model?.TestQuestionResults != null && Model.TestQuestionResults.Any())
                    {
                        <div class="review-section">
                            <h4>📋 Xem lại câu hỏi</h4>
                            @{
                                int idx = 1;
                                foreach (var result in Model.TestQuestionResults)
                                {
                                    string cssClass = result.IsCorrect ? "correct" : "wrong";
                                    string iconColor = result.IsCorrect ? "#10b981" : "#ef4444";
                                    string icon = result.IsCorrect ? "✅" : "❌";
                                    string ansClass = result.IsCorrect ? "ans-correct" : "ans-wrong";
                                    <div class="q-review @cssClass">
                                        <div class="q-txt">
                                            <span style="color:@iconColor">@icon Q@(idx++):</span>
                                            @result.Question?.QuestionContent
                                        </div>
                                        <div class="ans-row">
                                            <span class="ans-lbl">Câu trả lời của bạn:</span>
                                            <span class="@ansClass">@(result.SelectedAnswer ?? "Chưa trả lời")</span>
                                        </div>
                                        @if (!result.IsCorrect)
                                        {
                                            <div class="ans-row">
                                                <span class="ans-lbl">Đáp án đúng:</span>
                                                <span class="ans-correct">@result.Question?.CorrectAnswer</span>
                                            </div>
                                        }
                                        <div class="text-end mt-2">
                                            <button type="button" class="btn btn-sm btn-link" style="color:#64748b; font-size:.8rem; padding:0; text-decoration:none; border:none; background:none; cursor:pointer;" onclick="toggleReportForm(@result.QuestionId)">
                                                ⚠️ Báo cáo lỗi cho câu hỏi này
                                            </button>
                                        </div>
                                        <form asp-action="Report" method="post" id="reportForm-@result.QuestionId" style="display:none; margin-top:10px; background:rgba(0,0,0,.15); padding:12px; border-radius:8px; border:1px solid rgba(255,255,255,.05);">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="questionId" value="@result.QuestionId" />
                                            <input type="hidden" name="attemptId" value="@Model.AttemptId" />
                                            <div class="d-flex gap-2">
                                                <input type="text" name="reason" class="form-control" style="padding:6px 12px; font-size:.85rem; border-radius:8px; flex:1;" placeholder="Ví dụ: đáp án đúng bị sai, lỗi chính tả..." required />
                                                <button type="submit" class="btn btn-save" style="padding:6px 15px; font-size:.85rem; border-radius:15px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff; border:none; cursor:pointer;">Gửi</button>
                                            </div>
                                        </form>
                                    </div>
                                }
                            }
                        </div>
                    }

                    <a asp-action="History" class="btn-back">← Quay lại lịch sử</a>
                    <a asp-action="List" class="btn-back" style="background:transparent;border:2px solid #ec6090;margin-left:10px;">📝 Làm đề kiểm tra khác</a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function toggleReportForm(qId) {
            const form = document.getElementById(`reportForm-${qId}`);
            if (form) {
                form.style.display = form.style.display === 'none' ? 'block' : 'none';
            }
        }
    </script>
}
