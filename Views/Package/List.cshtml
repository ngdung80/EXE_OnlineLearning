@model List<POT_System_ASPNET.Data.Entities.Package>
@{
    ViewData["Title"] = "Gói học tập";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .pkg-section { padding:80px 0; background:linear-gradient(135deg,#0f172a,#1e293b); min-height:80vh; }
    .section-title { color:#ec6090; font-weight:800; text-align:center; margin-bottom:10px; font-size:2rem; }
    .section-sub { color:#94a3b8; text-align:center; margin-bottom:50px; }
    .pkg-card { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:20px; padding:30px; color:#fff; transition:all .3s; height:100%; display:flex; flex-direction:column; }
    .pkg-card:hover { transform:translateY(-8px); box-shadow:0 20px 40px rgba(0,0,0,.3); border-color:rgba(236,96,144,.4); }
    .pkg-card.featured { border-color:#ec6090; background:linear-gradient(135deg,rgba(236,96,144,.1),rgba(231,84,133,.05)); }
    .pkg-icon { font-size:2.5rem; margin-bottom:15px; }
    .pkg-name { font-size:1.3rem; font-weight:700; color:#ec6090; margin-bottom:10px; }
    .pkg-desc { color:#94a3b8; font-size:.9rem; margin-bottom:20px; flex:1; }
    .pkg-price { font-size:2rem; font-weight:800; color:#fff; margin-bottom:5px; }
    .pkg-price span { font-size:1rem; font-weight:400; color:#94a3b8; }
    .pkg-duration { color:#94a3b8; font-size:.9rem; margin-bottom:25px; }
    .pkg-features { list-style:none; padding:0; margin-bottom:25px; }
    .pkg-features li { padding:6px 0; color:#94a3b8; font-size:.88rem; display:flex; align-items:center; gap:8px; }
    .pkg-features li::before { content:'✓'; color:#10b981; font-weight:700; }
    .btn-purchase { display:block; text-align:center; padding:14px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff; border-radius:25px; text-decoration:none; font-weight:700; transition:all .3s; border:none; cursor:pointer; width:100%; }
    .btn-purchase:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(236,96,144,.4); color:#fff; }
    .featured-badge { display:inline-block; padding:4px 12px; background:#ec6090; color:#fff; border-radius:20px; font-size:.75rem; font-weight:700; margin-bottom:10px; }
</style>

<section class="pkg-section">
    <div class="container">
        <h2 class="section-title">💎 Gói học tập</h2>
        <p class="section-sub">Chọn gói học tập tốt nhất cho hành trình học tập của con bạn</p>

        @if (TempData["Error"] != null) {
            <div style="background:rgba(239,68,68,.15);border:1px solid #ef4444;color:#ef4444;padding:12px;border-radius:10px;margin-bottom:20px;">@TempData["Error"]</div>
        }

        <div class="row g-4 justify-content-center">
            @if (Model != null)
            {
                var icons = new[] { "📚", "🎯", "🚀", "💡", "⭐" };
                int idx = 0;
                foreach (var pkg in Model)
                {
                    bool featured = idx == 1;
                    <div class="col-md-4">
                        <div class="pkg-card @(featured ? "featured" : "")">
                            @if (featured) { <span class="featured-badge">⭐ Phổ biến nhất</span> }
                            <div class="pkg-icon">@(icons[idx % icons.Length])</div>
                            <div class="pkg-name">@pkg.PackageName</div>
                            <p class="pkg-desc">@pkg.Description</p>
                            <div class="pkg-price">@pkg.Price.ToString("N0") <span>VNĐ</span></div>
                            <div class="pkg-duration">📅 Truy cập trong @pkg.Duration tháng</div>
                            <ul class="pkg-features">
                                <li>Không giới hạn bài luyện tập</li>
                                <li>Câu hỏi tạo bởi AI</li>
                                <li>Theo dõi tiến độ</li>
                                <li>Bao gồm tất cả môn học</li>
                            </ul>
                            @if (User.IsInRole("Parent"))
                            {
                                <a asp-controller="Package" asp-action="Purchase" asp-route-packageId="@pkg.PackageId" class="btn-purchase">Mua ngay →</a>
                            }
                            else if (!User.Identity!.IsAuthenticated)
                            {
                                <a asp-controller="Account" asp-action="Login" class="btn-purchase">Đăng nhập để mua</a>
                            }
                            else
                            {
                                <button class="btn-purchase" disabled style="opacity:.5">Chỉ dành cho Phụ huynh</button>
                            }
                        </div>
                    </div>
                    idx++;
                }
            }
        </div>
    </div>
</section>
