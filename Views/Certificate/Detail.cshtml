@{
    Layout = null; // No layout for printable page
    var student = ViewBag.Student as POT_System_ASPNET.Data.Entities.User;
    var grade = ViewBag.Grade as POT_System_ASPNET.Data.Entities.Grade;
    var chapter = ViewBag.Chapter as POT_System_ASPNET.Data.Entities.Chapter;
    var completedDate = (DateTime)ViewBag.CompletedDate;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chứng chỉ - @student?.FullName</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700;800&family=Great+Vibes&family=Playfair+Display:ital,wght@0,500;0,700;1,400&family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f3f4f6;
            font-family: 'Montserrat', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        /* Certificate Container */
        .certificate-container {
            width: 950px;
            height: 670px;
            padding: 40px;
            position: relative;
            background-color: #fdfcfa;
            background-image: 
                radial-gradient(circle at 0% 0%, rgba(218, 165, 32, 0.03) 0%, transparent 50%),
                radial-gradient(circle at 100% 100%, rgba(99, 102, 241, 0.03) 0%, transparent 50%);
            border: 20px solid #ffffff;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.1);
            border-radius: 4px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            overflow: hidden;
        }

        /* Dual Borders */
        .certificate-border-outer {
            position: absolute;
            top: 10px;
            bottom: 10px;
            left: 10px;
            right: 10px;
            border: 4px solid #1e1b4b;
            pointer-events: none;
        }

        .certificate-border-inner {
            position: absolute;
            top: 18px;
            bottom: 18px;
            left: 18px;
            right: 18px;
            border: 2px solid #daa520;
            pointer-events: none;
        }

        /* Corner Ornaments */
        .corner-ornament {
            position: absolute;
            width: 40px;
            height: 40px;
            border: 2px solid #daa520;
            pointer-events: none;
        }
        .corner-tl { top: 25px; left: 25px; border-right: none; border-bottom: none; }
        .corner-tr { top: 25px; right: 25px; border-left: none; border-bottom: none; }
        .corner-bl { bottom: 25px; left: 25px; border-right: none; border-top: none; }
        .corner-br { bottom: 25px; right: 25px; border-left: none; border-top: none; }

        /* Header Logo & Title */
        .header {
            text-align: center;
            margin-top: 10px;
        }
        .logo-img {
            height: 65px;
            margin-bottom: 5px;
        }
        .academy-name {
            font-family: 'Cinzel', serif;
            font-size: 0.95rem;
            color: #1e1b4b;
            letter-spacing: 4px;
            font-weight: 700;
            margin: 0;
            text-transform: uppercase;
        }

        /* Main Content */
        .content {
            text-align: center;
            width: 100%;
            z-index: 2;
        }
        
        .main-title {
            font-family: 'Cinzel', serif;
            font-size: 2.3rem;
            color: #1e1b4b;
            font-weight: 800;
            margin: 10px 0 5px 0;
            letter-spacing: 2px;
            background: linear-gradient(135deg, #1e1b4b 0%, #daa520 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtitle {
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-size: 1.15rem;
            color: #6b7280;
            margin: 0;
        }

        .student-name {
            font-family: 'Great Vibes', cursive;
            font-size: 4.2rem;
            color: #1e1b4b;
            margin: 15px 0;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.05);
            font-weight: 500;
        }

        .description {
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            color: #374151;
            max-width: 700px;
            margin: 0 auto;
            line-height: 1.6;
        }

        .grade-highlight {
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            color: #4f46e5;
        }

        /* Footer & Signatures */
        .footer-sec {
            display: flex;
            width: 100%;
            justify-content: space-between;
            align-items: flex-end;
            padding: 0 50px 10px 50px;
            box-sizing: border-box;
        }

        .date-box {
            text-align: left;
            font-size: 0.85rem;
            color: #4b5563;
            border-top: 1px solid #d1d5db;
            padding-top: 8px;
            width: 200px;
        }

        .signature-box {
            text-align: center;
            position: relative;
            width: 220px;
        }
        
        .signature-image {
            height: 60px;
            position: absolute;
            bottom: 25px;
            left: 50%;
            transform: translateX(-50%);
            opacity: 0.9;
        }

        .signature-title {
            font-size: 0.85rem;
            color: #4b5563;
            border-top: 1px solid #d1d5db;
            padding-top: 8px;
            margin-top: 45px;
            font-weight: 600;
        }

        /* Gold Seal Component */
        .seal-container {
            width: 110px;
            height: 110px;
            position: relative;
            margin-bottom: -10px;
        }

        .seal-bg {
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, #f39c12, #d35400);
            border-radius: 50%;
            box-shadow: 0 4px 15px rgba(211, 84, 0, 0.4), inset 0 0 10px rgba(255,255,255,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 3px dashed #f1c40f;
            position: relative;
            z-index: 2;
        }

        .seal-text {
            font-family: 'Cinzel', serif;
            color: #ffffff;
            font-size: 0.55rem;
            font-weight: 800;
            text-align: center;
            line-height: 1.2;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
        }

        .seal-star {
            font-size: 1rem;
            color: #f1c40f;
            display: block;
            margin-top: 2px;
        }

        .ribbon-l, .ribbon-r {
            position: absolute;
            width: 30px;
            height: 70px;
            background: #d35400;
            top: 70px;
            z-index: 1;
            clip-path: polygon(0 0, 100% 0, 100% 100%, 50% 80%, 0 100%);
            box-shadow: 0 5px 10px rgba(0,0,0,0.15);
        }
        .ribbon-l {
            left: 20px;
            transform: rotate(20deg);
            background: linear-gradient(135deg, #d35400, #c0392b);
        }
        .ribbon-r {
            right: 20px;
            transform: rotate(-20deg);
            background: linear-gradient(135deg, #d35400, #e67e22);
        }

        /* Control Buttons block */
        .controls {
            margin-top: 25px;
            display: flex;
            gap: 15px;
        }
        
        .btn {
            padding: 12px 24px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 0.95rem;
            text-decoration: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: none;
            transition: all 0.3s;
        }
        
        .btn-print {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
        }
        .btn-print:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
        }

        .btn-back {
            background: white;
            color: #4b5563;
            border: 2px solid #e5e7eb;
        }
        .btn-back:hover {
            background: #f9fafb;
            transform: translateY(-2px);
        }

        /* Print Specific CSS */
        @@media print {
            body {
                background-color: #ffffff;
                margin: 0;
                padding: 0;
            }
            .controls {
                display: none !important;
            }
            .certificate-container {
                box-shadow: none !important;
                border: none !important;
                margin: 0 !important;
                width: 950px;
                height: 670px;
                page-break-inside: avoid;
            }
        }
    </style>
</head>
<body>

    <!-- Certificate Container -->
    <div class="certificate-container">
        <!-- Borders -->
        <div class="certificate-border-outer"></div>
        <div class="certificate-border-inner"></div>
        
        <!-- Corners -->
        <div class="corner-ornament corner-tl"></div>
        <div class="corner-ornament corner-tr"></div>
        <div class="corner-ornament corner-bl"></div>
        <div class="corner-ornament corner-br"></div>

        <!-- Header -->
        <div class="header">
            <img src="/assets/images/logo.png" alt="PLO Logo" class="logo-img" />
            <h5 class="academy-name">PLO Online Academy</h5>
        </div>

        <!-- Content -->
        <div class="content">
            <h1 class="main-title">CHỨNG NHẬN HOÀN THÀNH</h1>
            <p class="subtitle">Chứng chỉ này được trân trọng trao tặng cho</p>
            
            <div class="student-name">@student?.FullName</div>
            
            <p class="description">
                Đã hoàn thành xuất sắc chương học <span class="grade-highlight">@chapter?.ChapterName</span> 
                thuộc lộ trình đào tạo <span class="grade-highlight">Tiếng Anh @grade?.GradeName</span>.
            </p>
        </div>

        <!-- Footer -->
        <div class="footer-sec">
            <div class="date-box">
                <div><strong>NGÀY CẤP:</strong></div>
                <div style="margin-top: 4px; font-weight: 600;">@completedDate.ToString("dd/MM/yyyy")</div>
            </div>

            <!-- Gold Seal in the middle of footer -->
            <div class="seal-container">
                <div class="ribbon-l"></div>
                <div class="ribbon-r"></div>
                <div class="seal-bg">
                    <div class="seal-text">
                        PLO SYSTEM<br>
                        OFFICIAL<br>
                        SEAL
                        <span class="seal-star">★</span>
                    </div>
                </div>
            </div>

            <div class="signature-box">
                <!-- Decorative signature font/stamp -->
                <div style="font-family: 'Great Vibes', cursive; font-size: 2.2rem; color: #1e1b4b; margin-bottom: -5px; line-height: 1;">PLO Director</div>
                <div class="signature-title">HỘI ĐỒNG TUYỂN SINH</div>
            </div>
        </div>
    </div>

    <!-- User Action Controls -->
    <div class="controls">
        <button onclick="window.history.back()" class="btn btn-back">
            <i class="fa fa-arrow-left"></i> Quay lại
        </button>
        <button onclick="window.print()" class="btn btn-print">
            <i class="fa fa-print"></i> In chứng chỉ
        </button>
    </div>

</body>
</html>
