@{
    Layout = null; // No layout for printable page
    var student = ViewBag.Student as POT_System_ASPNET.Data.Entities.User;
    var grade = ViewBag.Grade as POT_System_ASPNET.Data.Entities.Grade;
    var chapter = ViewBag.Chapter as POT_System_ASPNET.Data.Entities.Chapter;
    var completedDate = (DateTime)ViewBag.CompletedDate;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chứng chỉ - @(student?.FullName ?? student?.Username)</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Pacifico&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #fce7f3;
            font-family: 'Nunito', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        /* Certificate Container */
        .certificate-container {
            width: 1000px;
            height: 710px;
            padding: 45px 55px;
            position: relative;
            background-color: #fffefb;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(255, 182, 193, 0.1) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(167, 139, 250, 0.1) 0%, transparent 40%);
            border: 20px solid #ffccd8; /* Pastel pink outer border */
            border-radius: 40px;
            box-shadow: 0 20px 50px rgba(236, 96, 144, 0.15);
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            overflow: hidden;
            z-index: 1;
        }

        /* Inner thin pink border */
        .inner-border {
            position: absolute;
            top: 10px;
            bottom: 10px;
            left: 10px;
            right: 10px;
            border: 3px solid #ffb3c6;
            border-radius: 28px;
            pointer-events: none;
            z-index: 2;
        }

        /* Inner dashed purple border */
        .dashed-border {
            position: absolute;
            top: 18px;
            bottom: 18px;
            left: 18px;
            right: 18px;
            border: 2px dashed #c084fc;
            border-radius: 22px;
            pointer-events: none;
            z-index: 2;
            opacity: 0.6;
        }

        /* Decorative SVGs in corners */
        .deco-top-left {
            position: absolute;
            top: 25px;
            left: 25px;
            z-index: 3;
        }

        .deco-top-right {
            position: absolute;
            top: 25px;
            right: 25px;
            z-index: 3;
        }

        .deco-bottom-left {
            position: absolute;
            bottom: 20px;
            left: 20px;
            z-index: 3;
        }

        .deco-bottom-right {
            position: absolute;
            bottom: 25px;
            right: 25px;
            z-index: 3;
        }

        /* Floating decoration bubbles/stars */
        .floating-bubble {
            position: absolute;
            border-radius: 50%;
            opacity: 0.6;
            pointer-events: none;
        }
        .bubble-1 { width: 12px; height: 12px; background: #fbbf24; top: 120px; left: 160px; }
        .bubble-2 { width: 8px; height: 8px; background: #ec6090; top: 220px; right: 150px; }
        .bubble-3 { width: 10px; height: 10px; background: #a78bfa; bottom: 180px; left: 170px; }
        .bubble-4 { width: 9px; height: 9px; background: #60a5fa; top: 110px; right: 280px; }
        
        .floating-star {
            position: absolute;
            font-size: 16px;
            opacity: 0.5;
            pointer-events: none;
        }
        .star-1 { color: #a78bfa; top: 100px; left: 240px; transform: rotate(15deg); }
        .star-2 { color: #fca5a5; top: 130px; right: 220px; transform: rotate(-20deg); }
        .star-3 { color: #fde047; bottom: 180px; right: 180px; transform: rotate(10deg); }

        /* Header block */
        .header {
            text-align: center;
            margin-top: 10px;
            z-index: 4;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .logo-img {
            height: 52px;
            margin-bottom: 6px;
        }

        .academy-name {
            font-family: 'Nunito', sans-serif;
            font-size: 0.85rem;
            color: #4b5563;
            letter-spacing: 2px;
            font-weight: 800;
            margin: 0;
            text-transform: uppercase;
        }

        /* Content Area */
        .content {
            text-align: center;
            width: 100%;
            z-index: 4;
            padding: 0 60px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .main-title {
            font-family: 'Nunito', sans-serif;
            font-size: 2.3rem;
            font-weight: 900;
            margin: 0 0 8px 0;
            letter-spacing: 1px;
            color: #1e1b4b;
        }

        .subtitle {
            font-family: 'Nunito', sans-serif;
            font-size: 1.05rem;
            color: #6b7280;
            font-weight: 700;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .subtitle i {
            color: #ec6090;
            font-size: 0.8rem;
        }

        /* Student name script wrapper */
        .student-container {
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 5px 0;
        }

        .student-name {
            font-family: 'Pacifico', cursive;
            font-size: 3.8rem;
            color: #903df4; /* Cursive Purple */
            margin: 0;
            font-weight: 400;
            text-align: center;
            text-transform: lowercase;
            text-shadow: 
                -3px -3px 0 #fff,  
                 3px -3px 0 #fff,
                -3px  3px 0 #fff,
                 3px  3px 0 #fff,
                 0px  4px 10px rgba(144, 61, 244, 0.25);
            line-height: 1.4;
        }

        .description {
            font-family: 'Nunito', sans-serif;
            font-size: 1.15rem;
            color: #374151;
            max-width: 720px;
            margin: 10px auto 0 auto;
            line-height: 1.6;
            font-weight: 700;
        }

        .highlight-text {
            color: #7c3aed;
            font-weight: 800;
        }

        /* Classification badge (Giỏi/Khá) */
        .classification-badge {
            display: inline-flex;
            align-items: center;
            background: #fff;
            border: 2px dashed #903df4;
            border-radius: 999px;
            padding: 6px 20px;
            margin-top: 14px;
            box-shadow: 0 4px 10px rgba(144, 61, 244, 0.08);
        }
        .badge-icon {
            margin-right: 6px;
            display: flex;
            align-items: center;
        }
        .badge-label {
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            color: #4b5563;
            font-size: 0.95rem;
            margin-right: 4px;
        }
        .badge-value {
            font-family: 'Nunito', sans-serif;
            font-weight: 900;
            color: #903df4;
            font-size: 1.15rem;
        }

        /* Footer Section */
        .footer-sec {
            display: flex;
            width: 100%;
            justify-content: space-between;
            align-items: flex-end;
            padding: 0 40px;
            box-sizing: border-box;
            z-index: 4;
        }

        .date-box {
            text-align: left;
            width: 200px;
        }
        
        .meta-label {
            font-family: 'Nunito', sans-serif;
            font-weight: 800;
            font-size: 0.8rem;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .meta-value {
            font-family: 'Nunito', sans-serif;
            font-size: 1.05rem;
            color: #1f2937;
            font-weight: 800;
            border-top: 2px dashed #fca5a5;
            padding-top: 6px;
        }

        .signature-box {
            text-align: center;
            width: 240px;
        }

        .signature-text {
            font-family: 'Pacifico', cursive;
            font-size: 1.7rem;
            color: #1e1b4b;
            line-height: 1;
            margin-bottom: 2px;
            transform: rotate(-2deg);
        }

        .signature-line {
            border-top: 2px dashed #a78bfa;
            padding-top: 6px;
            font-family: 'Nunito', sans-serif;
            font-weight: 800;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            color: #4b5563;
            text-transform: uppercase;
        }

        /* Gold Seal Component */
        .seal-container {
            width: 110px;
            height: 110px;
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: -10px;
        }

        .seal-bg {
            width: 80px;
            height: 80px;
            background: radial-gradient(circle, #ffe066, #f5b041, #d35400);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 10;
            border: 3px solid #fff;
            box-shadow: 0 4px 14px rgba(211, 84, 0, 0.25);
        }

        /* Starburst teeth background */
        .seal-bg::before {
            content: "";
            position: absolute;
            width: 88px;
            height: 88px;
            background: repeating-conic-gradient(from 0deg, #f5b041 0deg 10deg, #d35400 10deg 20deg);
            border-radius: 50%;
            z-index: -1;
        }

        .seal-inner-circle {
            width: 66px;
            height: 66px;
            border: 2px dashed rgba(255, 255, 255, 0.8);
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .seal-text {
            font-family: 'Nunito', sans-serif;
            color: #ffffff;
            font-size: 0.48rem;
            font-weight: 900;
            text-align: center;
            line-height: 1.2;
            letter-spacing: 0.5px;
            text-shadow: 1px 1px 1px rgba(0,0,0,0.3);
        }

        .seal-star {
            font-size: 0.6rem;
            color: #fffbeb;
            margin-top: 1px;
        }

        /* Ribbon tails */
        .ribbon-l, .ribbon-r {
            position: absolute;
            width: 22px;
            height: 62px;
            background: linear-gradient(180deg, #ff6b8b, #ff4757);
            top: 52px;
            z-index: 5;
            clip-path: polygon(0 0, 100% 0, 100% 100%, 50% 85%, 0 100%);
        }
        
        .ribbon-l {
            left: 26px;
            transform: rotate(16deg);
        }
        
        .ribbon-r {
            right: 26px;
            transform: rotate(-16deg);
        }

        /* Controls Block */
        .controls {
            margin-top: 25px;
            display: flex;
            gap: 15px;
            z-index: 10;
        }
        
        .btn {
            padding: 12px 26px;
            border-radius: 30px;
            font-family: 'Nunito', sans-serif;
            font-weight: 800;
            font-size: 0.9rem;
            text-decoration: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: none;
            transition: all 0.3s;
        }
        
        .btn-print {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
        }
        .btn-print:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
        }

        .btn-back {
            background: white;
            color: #4b5563;
            border: 2px solid #e5e7eb;
        }
        .btn-back:hover {
            background: #f9fafb;
            transform: translateY(-2px);
        }

        /* Print Specific Styles */
        @@media print {
            body {
                background-color: #ffffff;
                margin: 0;
                padding: 0;
            }
            .controls {
                display: none !important;
            }
            .certificate-container {
                box-shadow: none !important;
                margin: 0 !important;
                width: 1000px;
                height: 710px;
                page-break-inside: avoid;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>

    <!-- Certificate Container -->
    <div class="certificate-container">
        <!-- Borders -->
        <div class="inner-border"></div>
        <div class="dashed-border"></div>
        
        <!-- Corner Decorations (Cute SVGs) -->
        <!-- Top Left: Star and Rainbow -->
        <svg class="deco-top-left" width="100" height="100" viewBox="0 0 120 120">
            <path d="M10 90 Q 30 70 80 50" stroke="#fca5a5" stroke-width="8" fill="none" stroke-linecap="round"/>
            <path d="M15 95 Q 35 75 85 55" stroke="#fde047" stroke-width="8" fill="none" stroke-linecap="round"/>
            <path d="M20 100 Q 40 80 90 60" stroke="#93c5fd" stroke-width="8" fill="none" stroke-linecap="round"/>
            <polygon points="80,25 85,38 98,40 88,50 91,63 80,55 69,63 72,50 62,40 75,38" fill="#fde047" stroke="#ca8a04" stroke-width="2"/>
            <circle cx="76" cy="44" r="1.5" fill="#000"/>
            <circle cx="84" cy="44" r="1.5" fill="#000"/>
            <path d="M78 48 Q 80 50 82 48" stroke="#000" stroke-width="1.5" fill="none"/>
        </svg>

        <!-- Top Right: Book -->
        <svg class="deco-top-right" width="100" height="100" viewBox="0 0 120 120">
            <path d="M20 70 Q 40 50 60 55 Q 80 50 100 70 L 100 30 Q 80 10 60 15 Q 40 10 20 30 Z" fill="#fff" stroke="#ec6090" stroke-width="3"/>
            <path d="M60 15 L 60 55" stroke="#ec6090" stroke-width="2"/>
            <path d="M20 70 L 20 73 Q 40 53 60 58 Q 80 53 100 73 L 100 70" fill="none" stroke="#db2777" stroke-width="3"/>
            <text x="35" y="38" font-family="'Nunito', sans-serif" font-weight="900" font-size="16" fill="#ef4444">A</text>
            <text x="75" y="35" font-family="'Nunito', sans-serif" font-weight="900" font-size="16" fill="#3b82f6">B</text>
            <text x="70" y="48" font-family="'Nunito', sans-serif" font-weight="900" font-size="14" fill="#eab308">C</text>
        </svg>

        <!-- Bottom Left: Blocks and Pencil -->
        <svg class="deco-bottom-left" width="110" height="110" viewBox="0 0 140 140">
            <rect x="20" y="80" width="32" height="32" rx="6" fill="#f87171" stroke="#dc2626" stroke-width="2"/>
            <text x="29" y="103" font-family="'Nunito', sans-serif" font-weight="900" font-size="18" fill="#fff">A</text>
            <rect x="45" y="93" width="32" height="32" rx="6" fill="#a78bfa" stroke="#7c3aed" stroke-width="2"/>
            <text x="54" y="116" font-family="'Nunito', sans-serif" font-weight="900" font-size="18" fill="#fff">B</text>
            <rect x="62" y="70" width="32" height="32" rx="6" fill="#fbbf24" stroke="#d97706" stroke-width="2"/>
            <text x="71" y="93" font-family="'Nunito', sans-serif" font-weight="900" font-size="18" fill="#fff">C</text>
            <g transform="translate(10, 50) rotate(-45)">
                <rect x="0" y="0" width="10" height="45" fill="#fbbf24"/>
                <polygon points="0,0 5,-10 10,0" fill="#fca5a5"/>
                <polygon points="3,-7 5,-10 7,-7" fill="#000"/>
                <rect x="0" y="40" width="10" height="5" fill="#f43f5e"/>
            </g>
        </svg>

        <!-- Bottom Right: Trophy -->
        <svg class="deco-bottom-right" width="110" height="110" viewBox="0 0 130 130">
            <path d="M40 30 L 90 30 L 85 70 C 85 85 45 85 45 70 Z" fill="#fbbf24" stroke="#d97706" stroke-width="2"/>
            <rect x="55" y="85" width="20" height="15" fill="#7c3aed" stroke="#6d28d9" stroke-width="2"/>
            <rect x="45" y="100" width="40" height="8" rx="2" fill="#374151"/>
            <path d="M40 40 H 30 V 55 H 41" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round"/>
            <path d="M90 40 H 100 V 55 H 89" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round"/>
            <polygon points="65,42 67,48 73,49 68,54 70,60 65,56 60,60 62,54 57,49 63,48" fill="#fff"/>
        </svg>

        <!-- Floating bubbles/stars background -->
        <div class="floating-bubble bubble-1"></div>
        <div class="floating-bubble bubble-2"></div>
        <div class="floating-bubble bubble-3"></div>
        <div class="floating-bubble bubble-4"></div>
        <div class="floating-star star-1">★</div>
        <div class="floating-star star-2">★</div>
        <div class="floating-star star-3">★</div>

        <!-- Header -->
        <div class="header">
            <img src="/assets/images/logo.png" alt="PLO Logo" class="logo-img" onerror="this.style.display='none'" />
            <h5 class="academy-name">PLO Online Academy</h5>
        </div>

        <!-- Content -->
        <div class="content">
            <h1 class="main-title">CHỨNG NHẬN <span style="color: #ec6090;">HOÀN THÀNH</span></h1>
            <p class="subtitle">
                <i class="fa fa-heart"></i> 
                <span>Chứng chỉ này được trân trọng trao tặng cho</span> 
                <i class="fa fa-heart"></i>
            </p>
            
            <div class="student-container">
                <!-- Left Sparkle lines -->
                <svg width="35" height="35" viewBox="0 0 40 40" style="vertical-align: middle; margin-right: 12px;">
                    <path d="M30 20 L 10 20 M30 15 L 15 5 M30 25 L 15 35" stroke="#ec6090" stroke-width="4" stroke-linecap="round"/>
                </svg>
                
                <span class="student-name">@((student?.FullName ?? student?.Username ?? "học sinh").ToLower())</span>
                
                <!-- Right Sparkle lines -->
                <svg width="35" height="35" viewBox="0 0 40 40" style="vertical-align: middle; margin-left: 12px;">
                    <path d="M10 20 L 30 20 M10 15 L 25 5 M10 25 L 25 35" stroke="#ec6090" stroke-width="4" stroke-linecap="round"/>
                </svg>
            </div>
            
            <p class="description">
                @if (ViewBag.Classification == "Xuất sắc")
                {
                    <span>Đã hoàn thành <span class="highlight-text">xuất sắc</span> chương học <span class="highlight-text">@chapter?.ChapterName</span> thuộc lộ trình đào tạo <span class="highlight-text">Tiếng Anh @grade?.GradeName</span>.</span>
                }
                else
                {
                    <span>Đã hoàn thành chương học <span class="highlight-text">@chapter?.ChapterName</span> thuộc lộ trình đào tạo <span class="highlight-text">Tiếng Anh @grade?.GradeName</span>.</span>
                }
            </p>

            @if (ViewBag.Classification == "Giỏi" || ViewBag.Classification == "Khá")
            {
                <div class="classification-badge">
                    <span class="badge-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24">
                            <circle cx="12" cy="10" r="7" fill="#fbbf24" stroke="#d97706" stroke-width="1.5"/>
                            <polygon points="12,5 14,9 18,9 15,12 16,16 12,14 8,16 9,12 6,9 10,9" fill="#fff"/>
                            <path d="M9 16 L 7 22 L 12 20 L 17 22 L 15 16" fill="#ff6b8b" stroke="#e11d48" stroke-width="1"/>
                        </svg>
                    </span>
                    <span class="badge-label">Xếp loại:</span>
                    <span class="badge-value">@ViewBag.Classification</span>
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="footer-sec">
            <div class="date-box">
                <div class="meta-label">Ngày cấp</div>
                <div class="meta-value">@completedDate.ToString("dd/MM/yyyy")</div>
            </div>

            <!-- Gold Seal in the middle of footer -->
            <div class="seal-container">
                <div class="ribbon-l"></div>
                <div class="ribbon-r"></div>
                <div class="seal-bg">
                    <div class="seal-inner-circle">
                        <div class="seal-text">
                            PLO OFFICIAL<br>SEAL
                            <div class="seal-star">★</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="signature-box">
                <div class="signature-text">PLO Director</div>
                <div class="signature-line">Hội đồng đánh giá năng lực</div>
            </div>
        </div>
    </div>

    <!-- User Action Controls -->
    <div class="controls">
        <button onclick="window.history.back()" class="btn btn-back">
            <i class="fa fa-arrow-left"></i> Quay lại
        </button>
        <button onclick="window.print()" class="btn btn-print">
            <i class="fa fa-print"></i> In chứng chỉ
        </button>
    </div>

</body>
</html>
