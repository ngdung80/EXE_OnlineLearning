@model List<POT_System_ASPNET.Data.Entities.WalletTransaction>
@{
    ViewData["Title"] = "Ví điện tử";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .wallet-section { padding:80px 0; background:linear-gradient(135deg,#0f172a,#1e293b); min-height:80vh; }
    .wallet-card { background:linear-gradient(135deg,rgba(236,96,144,.15),rgba(231,84,133,.08)); border:1px solid rgba(236,96,144,.3); border-radius:20px; padding:30px; color:#fff; margin-bottom:30px; }
    .wallet-balance { font-size:3rem; font-weight:800; color:#ec6090; }
    .wallet-label { color:#94a3b8; font-size:.9rem; margin-bottom:10px; }
    .topup-form { display:flex; gap:10px; flex-wrap:wrap; margin-top:20px; }
    .topup-input { flex:1; min-width:200px; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.2); color:#fff; border-radius:10px; padding:12px 16px; font-size:14px; }
    .topup-input::placeholder { color:#64748b; }
    .btn-topup { padding:12px 24px; background:linear-gradient(135deg,#10b981,#059669); color:#fff; border:none; border-radius:10px; font-weight:700; cursor:pointer; }
    .btn-topup:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(16,185,129,.4); }
    .quick-amounts { display:flex; gap:8px; margin-top:10px; flex-wrap:wrap; }
    .quick-amt { padding:6px 16px; background:rgba(255,255,255,.08); color:#e2e8f0; border:1px solid rgba(255,255,255,.15); border-radius:15px; cursor:pointer; font-size:.85rem; transition:all .2s; }
    .quick-amt:hover { background:rgba(16,185,129,.2); border-color:#10b981; color:#10b981; }
    .tx-card { background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.07); border-radius:16px; overflow:hidden; }
    .tx-header { padding:20px; border-bottom:1px solid rgba(255,255,255,.07); }
    .tx-header h4 { color:#ec6090; font-weight:700; margin:0; }
    .tx-row { display:flex; align-items:center; padding:14px 20px; border-bottom:1px solid rgba(255,255,255,.05); transition:background .2s; }
    .tx-row:hover { background:rgba(255,255,255,.03); }
    .tx-icon { width:42px; height:42px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.1rem; margin-right:14px; flex-shrink:0; }
    .tx-icon.topup { background:rgba(16,185,129,.2); }
    .tx-icon.purchase { background:rgba(236,96,144,.2); }
    .tx-info { flex:1; }
    .tx-type { font-weight:600; color:#e2e8f0; font-size:.92rem; }
    .tx-date { color:#64748b; font-size:.8rem; margin-top:2px; }
    .tx-amount { font-weight:700; font-size:1rem; }
    .tx-amount.credit { color:#10b981; }
    .tx-amount.debit { color:#ef4444; }
    .empty-state { text-align:center; padding:50px; color:#64748b; }
    .pager { display:flex; justify-content:center; gap:8px; margin-top:20px; }
    .pager a, .pager span { padding:8px 14px; background:rgba(255,255,255,.06); color:#e2e8f0; border-radius:8px; text-decoration:none; transition:all .2s; }
    .pager a:hover { background:rgba(236,96,144,.2); color:#ec6090; }
    .pager .active { background:linear-gradient(135deg,#ec6090,#e75485); color:#fff; }
    .success-msg { background:rgba(16,185,129,.15); border:1px solid #10b981; color:#10b981; padding:12px; border-radius:10px; margin-bottom:20px; }
    .error-msg { background:rgba(239,68,68,.15); border:1px solid #ef4444; color:#ef4444; padding:12px; border-radius:10px; margin-bottom:20px; }
</style>

<section class="wallet-section">
    <div class="container">
        @if (TempData["Success"] != null) { <div class="success-msg">✓ @TempData["Success"]</div> }
        @if (TempData["Error"] != null) { <div class="error-msg">✗ @TempData["Error"]</div> }

        <!-- Wallet Card -->
        <div class="row g-4 mb-4">
            <div class="col-lg-6">
                <div class="wallet-card">
                    <div class="wallet-label">💰 Số dư hiện tại</div>
                    <div class="wallet-balance">@(((POT_System_ASPNET.Data.Entities.Wallet)ViewBag.Wallet).Balance.ToString("N0")) <small style="font-size:1.2rem;color:#94a3b8;">VNĐ</small></div>
                    <form asp-controller="Wallet" asp-action="TopUp" method="post" class="topup-form">
                        @Html.AntiForgeryToken()
                        <input type="number" name="amount" id="topupAmount" class="topup-input" placeholder="Nhập số tiền (VNĐ)" min="10000" required>
                        <button type="submit" class="btn-topup">➕ Nạp tiền</button>
                    </form>
                    <div class="quick-amounts">
                        @foreach (var amt in new[] { 100000, 200000, 500000, 1000000 })
                        {
                            <span class="quick-amt" onclick="document.getElementById('topupAmount').value=@amt">@amt.ToString("N0")</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Transaction History -->
        <div class="tx-card">
            <div class="tx-header">
                <h4>📋 Lịch sử giao dịch</h4>
            </div>
            @if (Model != null && Model.Any())
            {
                foreach (var tx in Model)
                {
                    bool isTopUp = tx.TransactionType == "TopUp";
                    <div class="tx-row">
                        <div class="tx-icon @(isTopUp ? "topup" : "purchase")">
                            @(isTopUp ? "➕" : "🛒")
                        </div>
                        <div class="tx-info">
                            <div class="tx-type">@tx.Description</div>
                            <div class="tx-date">@tx.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        <div class="tx-amount @(isTopUp ? "credit" : "debit")">
                            @(isTopUp ? "+" : "-")@tx.Amount.ToString("N0") đ
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <div style="font-size:2.5rem;margin-bottom:10px;">💸</div>
                    <p>Chưa có giao dịch nào.</p>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="pager">
                @for (int p = 1; p <= (int)ViewBag.TotalPages; p++)
                {
                    <a asp-action="Index" asp-route-page="@p" class="@(p == (int)ViewBag.CurrentPage ? "active" : "")">@p</a>
                }
            </div>
        }
    </div>
</section>
