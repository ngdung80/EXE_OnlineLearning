<section class="detail-section">
    <div class="container">
        <!-- Floating cloud & star decorations -->
        @if (User.IsInRole("Student"))
        {
            <div class="kid-bg-cloud c1">☁️</div>
            <div class="kid-bg-cloud c2">☁️</div>
            <div class="kid-bg-star s1">⭐</div>
            <div class="kid-bg-star s2">⭐</div>
            <div class="kid-bg-star s3">⭐</div>
            <div class="kid-bg-star s4">⭐</div>
            <div class="kid-bg-star s5">⭐</div>
        }

        <div class="breadcrumb-bar">
            <a asp-controller="Grade" asp-action="Index">Khối lớp</a>
            <span>›</span>
            <a asp-controller="Chapter" asp-action="Index" asp-route-subjectId="@Model?.Chapter?.SubjectId">@Model?.Chapter?.Subject?.SubjectName</a>
            <span>›</span>
            <a asp-controller="Lesson" asp-action="Index" asp-route-chapterId="@Model?.ChapterId">@Model?.Chapter?.ChapterName</a>
            <span>›</span>
            <span style="color:#e2e8f0;">@Model?.LessonName</span>
        </div>

        <div class="row">
            @if (User.IsInRole("Student"))
            {
                <!-- Left Column for Video & Content -->
                <div class="col-lg-8 mb-4">
                    <div class="lesson-card">
                        <h1>@Model?.LessonName</h1>
                        <div class="lesson-meta">
                            <span class="meta-badge">📚 @(Model?.Chapter?.Subject?.SubjectName ?? "—")</span>
                            <span class="meta-badge">📑 @(Model?.Chapter?.ChapterName ?? "—")</span>
                        </div>

                        <!-- Video Player Area -->
                        @if (isVideo)
                        {
                            <div class="video-container" style="position:relative; width:100%; border-radius:16px; overflow:hidden; background:#000; box-shadow: 0 10px 30px rgba(0,0,0,0.5); margin-bottom:25px;">
                                @if (videoType == "youtube")
                                {
                                    <div style="padding-top: 56.25%; position: relative;">
                                        <iframe id="yt-player" src="@embedUrl?enablejsapi=1" style="position: absolute; top:0; left:0; width:100%; height:100%; border:none;" allowfullscreen></iframe>
                                    </div>
                                }
                                else
                                {
                                    <div id="video-loading" style="padding: 20px; text-align: center; color: #94a3b8; font-weight: 600;">
                                        <div style="width:30px; height:30px; border:3px solid rgba(255,255,255,0.1); border-radius:50%; border-top-color:#ec6090; animation:spin 1s linear infinite; margin:0 auto 10px;"></div>
                                        Đang tải video bài học...
                                    </div>
                                    <video id="direct-video" controls controlsList="nodownload" oncontextmenu="return false;" style="width:100%; height:auto; display:none;" ontimeupdate="checkDirectVideoProgress(this)">
                                        Trình duyệt của con không hỗ trợ xem trực tiếp video này.
                                    </video>
                                }
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(Model?.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" class="lesson-img" alt="@Model.LessonName">
