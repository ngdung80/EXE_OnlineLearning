</section>

@if (User.IsInRole("Student"))
{
    <!-- YouTube IFrame API script -->
    <script src="https://www.youtube.com/iframe_api"></script>
    <script>
        let correctCount = 0;
        let questionCount = 0;
        const MAX_QUESTIONS = 5;
        let currentCorrectAnswer = "";
        let currentExplanation = "";
        
        // Check if there is any video player on screen. If not, bypass the unlock gate immediately.
        let hasWatchedHalf = !document.getElementById('yt-player') && !document.getElementById('direct-video');
        
        window.addEventListener('DOMContentLoaded', () => {
            if (hasWatchedHalf) {
                enableAIQuizButton();
            }
        });

        function enableAIQuizButton() {
            const btn = document.getElementById('btn-ask-ai');
            if (btn) {
                btn.disabled = false;
                btn.style.background = 'linear-gradient(135deg,#a855f7,#7c3aed)';
                btn.style.color = '#fff';
                btn.style.cursor = 'pointer';
                btn.style.boxShadow = '0 6px 20px rgba(124,58,237,0.3)';
                btn.innerHTML = '🤖 AI ơi, đố con 1 câu!';
            }
        }

        // Direct Video Progress tracking
        let directMaxTimeWatched = 0;
        function checkDirectVideoProgress(video) {
            const currentTime = video.currentTime;
            
            // Prevent seeking forward (more than 2 seconds ahead of max watched time)
            if (currentTime > directMaxTimeWatched + 2.0) {
                video.currentTime = directMaxTimeWatched;
            } else {
                if (currentTime > directMaxTimeWatched) {
                    directMaxTimeWatched = currentTime;
                }
            }

            if (video.duration > 0 && directMaxTimeWatched >= video.duration / 2) {
                if (!hasWatchedHalf) {
                    hasWatchedHalf = true;
                    enableAIQuizButton();
                }
            }
        }

        // YouTube Player API progress tracking
        var player;
        var progressInterval;
        let ytMaxTimeWatched = 0;
        
        function onYouTubeIframeAPIReady() {
            if (document.getElementById('yt-player')) {
                player = new YT.Player('yt-player', {
                    events: {
                        'onStateChange': onPlayerStateChange
                    }
                });
            }
        }

        function onPlayerStateChange(event) {
            if (event.data == YT.PlayerState.PLAYING) {
                checkYTProgress();
                progressInterval = setInterval(checkYTProgress, 500); // Check every 500ms
            } else {
                clearInterval(progressInterval);
            }
        }

        function checkYTProgress() {
            if (!player) return;
            try {
                const duration = player.getDuration();
                const currentTime = player.getCurrentTime();

                // Prevent seeking forward (more than 2 seconds ahead of max watched time)
                if (currentTime > ytMaxTimeWatched + 2.0) {
                    player.seekTo(ytMaxTimeWatched, true);
                } else {
                    if (currentTime > ytMaxTimeWatched) {
                        ytMaxTimeWatched = currentTime;
                    }
                }

                if (duration > 0 && ytMaxTimeWatched >= duration / 2) {
                    if (!hasWatchedHalf) {
                        hasWatchedHalf = true;
                        enableAIQuizButton();
                    }
                }
            } catch (e) {
                console.error("Error checking YouTube progress:", e);
            }
        }
        
        async function loadAISingleQuestion() {
            if (questionCount >= MAX_QUESTIONS) {
                alert("Con đã hoàn thành tối đa 5 câu hỏi ôn tập của bài học này!");
                return;
            }
            
            const existingSummary = document.getElementById('quiz-completion-summary');
            if (existingSummary) existingSummary.remove();

            document.getElementById('quiz-init-screen').style.display = 'none';
            document.getElementById('quiz-question-screen').style.display = 'none';
            document.getElementById('quiz-loading-screen').style.display = 'block';
            document.getElementById('btn-next-question').style.display = 'none';
            document.getElementById('quiz-feedback-box').style.display = 'none';
            
            try {
                const response = await fetch('/AI/GenerateSingleQuestion', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lessonId: @Model.LessonId })
                });
                
                if (!response.ok) {
                    const errorData = await response.json();
                    throw new Error(errorData.error || "Không thể tải câu hỏi.");
                }
                
                const data = await response.json();
                questionCount++;
                
                currentCorrectAnswer = data.correctAnswer;
                currentExplanation = data.explanation;
                
                document.getElementById('quiz-question-content').innerText = `Câu ${questionCount}/${MAX_QUESTIONS}: ${data.questionContent}`;
                
                const optionsContainer = document.getElementById('quiz-options-container');
                optionsContainer.innerHTML = '';
                
                data.options.forEach(opt => {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'quiz-option-btn';
                    btn.innerText = opt;
                    btn.onclick = () => selectQuizOption(btn, opt);
                    optionsContainer.appendChild(btn);
                });
                
                document.getElementById('quiz-loading-screen').style.display = 'none';
                document.getElementById('quiz-question-screen').style.display = 'block';
            } catch (err) {
                document.getElementById('quiz-loading-screen').style.display = 'none';
                document.getElementById('quiz-init-screen').style.display = 'block';
                alert("Lỗi từ AI: " + err.message);
            }
        }
        
        function selectQuizOption(selectedBtn, selectedOpt) {
            const btns = document.querySelectorAll('.quiz-option-btn');
            btns.forEach(btn => btn.disabled = true);
            
            const feedbackBox = document.getElementById('quiz-feedback-box');
            const feedbackTitle = document.getElementById('quiz-feedback-title');
            const explanationText = document.getElementById('quiz-explanation-text');
            
            const isCorrect = selectedOpt.trim().toLowerCase() === currentCorrectAnswer.trim().toLowerCase() || 
                              (selectedOpt.length > 2 && currentCorrectAnswer.length > 2 && 
                               selectedOpt.substring(0, 2).toLowerCase() === currentCorrectAnswer.substring(0, 2).toLowerCase());
                               
            if (isCorrect) {
                selectedBtn.classList.add('correct');
                feedbackBox.style.background = 'rgba(16, 185, 129, 0.1)';
                feedbackBox.style.border = '1px solid rgba(16, 185, 129, 0.2)';
                feedbackTitle.style.color = '#10b981';
                feedbackTitle.innerHTML = '🎉 Chính xác! Con giỏi lắm!';
                correctCount++;
                document.getElementById('quiz-correct-count').innerText = correctCount;
            } else {
                selectedBtn.classList.add('incorrect');
                btns.forEach(btn => {
                    const optText = btn.innerText;
                    if (optText.trim().toLowerCase() === currentCorrectAnswer.trim().toLowerCase() ||
                        (optText.length > 2 && currentCorrectAnswer.length > 2 &&
                         optText.substring(0, 2).toLowerCase() === currentCorrectAnswer.substring(0, 2).toLowerCase())) {
                        btn.classList.add('correct');
                    }
                });
                feedbackBox.style.background = 'rgba(239, 68, 68, 0.1)';
                feedbackBox.style.border = '1px solid rgba(239, 68, 68, 0.2)';
                feedbackTitle.style.color = '#f87171';
                feedbackTitle.innerHTML = '💡 Con trả lời chưa đúng rồi, xem gợi ý nhé:';
            }
            
            explanationText.innerText = currentExplanation || "AI khuyên con nên xem kỹ lại bài giảng!";
            feedbackBox.style.display = 'block';
            
            if (questionCount < MAX_QUESTIONS) {
                document.getElementById('btn-next-question').style.display = 'block';
            } else {
                const oldSummary = document.getElementById('quiz-completion-summary');
                if (oldSummary) oldSummary.remove();

                let rewardHtml = "";
                let avatarPath = "";
                let rankName = "";
                
                if (correctCount === 5) {
                    avatarPath = "/assets/images/avatars/phoenix.svg";
                    rankName = "Vua Thông Thái 👑";
                } else if (correctCount >= 3) {
                    avatarPath = "/assets/images/avatars/lion.svg";
                    rankName = "Chiến Binh Chăm Chỉ 🦁";
                } else if (correctCount >= 1) {
                    avatarPath = "/assets/images/avatars/dragon.svg";
                    rankName = "Nhập Môn Tinh Nghịch 🐲";
                }
                
                if (avatarPath) {
                    rewardHtml = `
                        <div style="margin-top: 15px; padding: 12px; background: rgba(16, 185, 129, 0.1); border: 1.5px solid #10b981; border-radius: 10px; display: flex; flex-direction: column; align-items: center; gap: 8px;">
                            <div style="font-size: 0.82rem; font-weight: 700; color: #10b981;">🎁 ĐÃ MỞ KHÓA AVATAR MỚI!</div>
                            <img src="${avatarPath}" style="width: 50px; height: 50px; border-radius: 50%; border: 2px solid #10b981;" />
                            <button type="button" onclick="useUnlockedAvatar('${avatarPath}')" style="background: linear-gradient(135deg, #10b981, #059669); color: white; border: none; border-radius: 18px; padding: 6px 14px; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: all 0.2s;">
                                Sử dụng Avatar này ngay!
                            </button>
                        </div>
                    `;
                }

                const summaryDiv = document.createElement('div');
                summaryDiv.id = 'quiz-completion-summary';
                summaryDiv.style.marginTop = '20px';
                summaryDiv.style.padding = '15px';
                summaryDiv.style.background = 'rgba(168, 85, 247, 0.15)';
                summaryDiv.style.border = '2px solid #a855f7';
                summaryDiv.style.borderRadius = '12px';
                summaryDiv.style.textAlign = 'center';
                summaryDiv.innerHTML = `
                    <h5 style="color:#c084fc; font-weight:800; margin-bottom:8px; font-size:1.1rem;">🏆 Đã hoàn thành 5 câu đố AI!</h5>
                    <p style="margin:0; font-size:0.95rem; font-weight:700;">Hạng của con: <span style="color:#ec6090;">${rankName || "Cố Gắng Hơn 🎯"}</span></p>
                    <p style="margin:4px 0 0 0; font-size:0.9rem; font-weight:600;">Kết quả học tập: <span style="color:#10b981;">${correctCount}</span> / 5 câu chính xác.</p>
                    ${rewardHtml}
                `;
                document.getElementById('quiz-question-screen').appendChild(summaryDiv);
            }
        }

        async function completeLessonManual() {
            try {
                const response = await fetch('/Lesson/CompleteLesson?lessonId=' + @(Model?.LessonId ?? 0), {
                    method: 'POST'
                });
                if (response.ok) {
                    alert('Chúc mừng con đã hoàn thành bài học! Bài học đã được mở khóa để con luyện tập.');
                    const btn = document.getElementById('btn-complete-lesson');
                    if (btn) {
                        btn.innerText = '✔️ Con đã hoàn thành bài học này';
                        btn.style.background = 'rgba(16, 185, 129, 0.1)';
                        btn.style.borderColor = '#10b981';
                        btn.style.color = '#10b981';
                        btn.disabled = true;
                    }
                }
            } catch (err) {
                console.error("Error completing lesson:", err);
            }
        }

        async function useUnlockedAvatar(avatarPath) {
            try {
                const response = await fetch('/Account/UpdateAvatar?avatarPath=' + encodeURIComponent(avatarPath), {
                    method: 'POST'
                });
                const data = await response.json();
                if (data.success) {
                    alert('🎉 Đổi hình đại diện thành công! Trang web sẽ tải lại sau 1 giây.');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    alert('Lỗi: ' + (data.message || 'Không thể đổi hình đại diện.'));
                }
            } catch (err) {
                console.error(err);
                alert('Đã xảy ra lỗi khi kết nối máy chủ.');
            }
        }
    </script>
}

<script>
    let currentTestPage = 1;
    const testsPerPage = 3;

    window.addEventListener('DOMContentLoaded', () => {
        initTestPagination();
    });

    function initTestPagination() {
        const container = document.getElementById('test-list-container');
        if (!container) return;
        const items = container.getElementsByClassName('test-item-wrapper');
        if (items.length === 0) return;

        showTestPage(1);
    }

    function showTestPage(page) {
        const container = document.getElementById('test-list-container');
        if (!container) return;
        const items = container.getElementsByClassName('test-item-wrapper');
        const totalPages = Math.ceil(items.length / testsPerPage);

        if (page < 1) page = 1;
        if (page > totalPages) page = totalPages;

        currentTestPage = page;

        for (let i = 0; i < items.length; i++) {
            if (i >= (page - 1) * testsPerPage && i < page * testsPerPage) {
                items[i].style.display = 'block';
            } else {
                items[i].style.display = 'none';
            }
        }

        const info = document.getElementById('test-page-info');
        if (info) {
            info.innerText = `${page} / ${totalPages}`;
        }

        const prevBtn = document.getElementById('btn-prev-tests');
        if (prevBtn) prevBtn.disabled = (page === 1);

        const nextBtn = document.getElementById('btn-next-tests');
        if (nextBtn) nextBtn.disabled = (page === totalPages);
    }

    function prevTestPage() {
        showTestPage(currentTestPage - 1);
    }

    function nextTestPage() {
        showTestPage(currentTestPage + 1);
    }

    document.addEventListener('DOMContentLoaded', function () {
        const directVideo = document.getElementById('direct-video');
        const directLoading = document.getElementById('video-loading');
        const previewVideo = document.getElementById('preview-video');
        const previewLoading = document.getElementById('preview-video-loading');
        
        const videoElement = directVideo || previewVideo;
        const loadingElement = directLoading || previewLoading;
        
        if (directVideo) {
            directVideo.addEventListener('seeking', () => {
                if (directVideo.currentTime > directMaxTimeWatched + 1.0) {
                    directVideo.currentTime = directMaxTimeWatched;
                }
            });
        }

        if (videoElement && '@Model.FileUrl') {
            const videoUrl = '@Model.FileUrl';
            
            fetch(videoUrl)
                .then(response => {
                    if (!response.ok) throw new Error('Không thể tải video');
                    return response.blob();
                })
                .then(blob => {
                    const blobUrl = URL.createObjectURL(blob);
                    videoElement.src = blobUrl;
                    
                    if (loadingElement) loadingElement.style.display = 'none';
                    videoElement.style.display = 'block';
                })
                .catch(error => {
                    console.error('Security Video Loading Error:', error);
                    videoElement.src = videoUrl;
                    if (loadingElement) loadingElement.style.display = 'none';
                    videoElement.style.display = 'block';
                });
        }
    });
</script>
