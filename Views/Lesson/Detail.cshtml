                                <button type="button" id="btn-next-question" onclick="loadAISingleQuestion()" style="display:none; padding:8px 18px; background:linear-gradient(135deg,#ec6090,#e75485); border:none; color:#fff; font-weight:700; border-radius:20px; cursor:pointer; font-size:0.85rem; font-family:'Nunito',sans-serif;">
