@model POT_System_ASPNET.Data.Entities.Lesson
@{
    #pragma warning disable CS8602
    ViewData["Title"] = Model?.LessonName ?? "Chi tiết bài học";

    bool isVideo = false;
    string videoType = "";
    string embedUrl = "";
    if (!string.IsNullOrEmpty(Model?.FileUrl))
    {
        var url = Model.FileUrl.Trim();
        if (url.Contains("youtube.com") || url.Contains("youtu.be"))
        {
            isVideo = true;
            videoType = "youtube";
            string videoId = "";
            if (url.Contains("v="))
            {
                int vIdx = url.IndexOf("v=");
                int ampIdx = url.IndexOf("&", vIdx);
                if (ampIdx == -1) videoId = url.Substring(vIdx + 2);
                else videoId = url.Substring(vIdx + 2, ampIdx - (vIdx + 2));
            }
            else if (url.Contains("youtu.be/"))
            {
                int slashIdx = url.LastIndexOf("/");
                videoId = url.Substring(slashIdx + 1);
                if (videoId.Contains("?"))
                {
                    videoId = videoId.Substring(0, videoId.IndexOf("?"));
                }
            }
            embedUrl = "https://www.youtube.com/embed/" + videoId;
        }
        else if (url.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase) || 
                 url.EndsWith(".webm", StringComparison.OrdinalIgnoreCase) || 
                 url.EndsWith(".ogg", StringComparison.OrdinalIgnoreCase) ||
                 url.EndsWith(".mov", StringComparison.OrdinalIgnoreCase))
        {
            isVideo = true;
            videoType = "direct";
        }
    }
}
