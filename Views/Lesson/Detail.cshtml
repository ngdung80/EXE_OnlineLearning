@model POT_System_ASPNET.Data.Entities.Lesson
@{
    ViewData["Title"] = Model?.LessonName ?? "Chi tiết bài học";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .detail-section { padding:80px 0; background:linear-gradient(135deg,#0f172a,#1e293b); min-height:80vh; }
    .breadcrumb-bar { display:flex; align-items:center; gap:8px; color:#64748b; font-size:.88rem; margin-bottom:25px; flex-wrap:wrap; }
    .breadcrumb-bar a { color:#ec6090; text-decoration:none; }
    .lesson-card { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.09); border-radius:20px; padding:40px; color:#fff; }
    .lesson-card h1 { color:#ec6090; font-weight:800; font-size:1.8rem; margin-bottom:8px; }
    .lesson-meta { display:flex; gap:16px; flex-wrap:wrap; margin-bottom:30px; }
    .meta-badge { display:inline-flex; align-items:center; gap:6px; padding:6px 14px; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1); border-radius:20px; font-size:.82rem; color:#94a3b8; }
    .lesson-content { color:#e2e8f0; line-height:1.8; font-size:.95rem; margin-bottom:30px; white-space:pre-wrap; }
    .divider { border:none; border-top:1px solid rgba(255,255,255,.08); margin:30px 0; }
    .file-section h4 { color:#ec6090; margin-bottom:12px; }
    .file-link { display:inline-flex; align-items:center; gap:8px; padding:10px 20px; background:rgba(59,130,246,.15); color:#60a5fa; border-radius:12px; text-decoration:none; font-weight:600; transition:all .2s; }
    .file-link:hover { background:rgba(59,130,246,.3); color:#60a5fa; }
    .lesson-img { max-width:100%; border-radius:12px; margin-bottom:20px; }
    .related-tests { margin-top:30px; }
    .related-tests h4 { color:#ec6090; margin-bottom:15px; }
    .test-mini { display:flex; justify-content:space-between; align-items:center; padding:12px 16px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.07); border-radius:10px; margin-bottom:8px; }
    .test-mini-name { color:#e2e8f0; font-size:.9rem; font-weight:600; }
    .btn-take-mini { padding:6px 14px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff; border-radius:15px; text-decoration:none; font-size:.8rem; font-weight:700; }
    .back-btn { display:inline-flex; align-items:center; gap:6px; padding:10px 22px; background:transparent; border:2px solid #ec6090; color:#ec6090; border-radius:25px; text-decoration:none; font-weight:600; font-size:.88rem; transition:all .2s; margin-top:10px; }
    .back-btn:hover { background:rgba(236,96,144,.1); color:#ec6090; }
</style>

<section class="detail-section">
    <div class="container">
        <div class="breadcrumb-bar">
            <a asp-controller="Grade" asp-action="Index">Khối lớp</a>
            <span>›</span>
            <a asp-controller="Chapter" asp-action="Index" asp-route-subjectId="@Model?.Chapter?.SubjectId">@Model?.Chapter?.Subject?.SubjectName</a>
            <span>›</span>
            <a asp-controller="Lesson" asp-action="Index" asp-route-chapterId="@Model?.ChapterId">@Model?.Chapter?.ChapterName</a>
            <span>›</span>
            <span style="color:#e2e8f0;">@Model?.LessonName</span>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="lesson-card">
                    <h1>@Model?.LessonName</h1>
                    <div class="lesson-meta">
                        <span class="meta-badge">📚 @(Model?.Chapter?.Subject?.SubjectName ?? "—")</span>
                        <span class="meta-badge">📑 @(Model?.Chapter?.ChapterName ?? "—")</span>
                        @if (!string.IsNullOrEmpty(Model?.Status))
                        {
                            string statusColor = Model.Status == "Active" ? "#10b981" : Model.Status == "Pending" ? "#eab308" : "#ef4444";
                            string statusText = Model.Status == "Active" ? "Hoạt động" : Model.Status == "Pending" ? "Chờ duyệt" : "Không hoạt động";
                            <span class="meta-badge" style="color:@statusColor">● @statusText</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="lesson-img" alt="@Model.LessonName">
                    }

                    @if (!string.IsNullOrEmpty(Model?.ContentText))
                    {
                        <div class="lesson-content">@Model.ContentText</div>
                    }

                    @if (!string.IsNullOrEmpty(Model?.FileUrl))
                    {
                        <hr class="divider">
                        <div class="file-section">
                            <h4>📎 Tài liệu đính kèm</h4>
                            <a href="@Model.FileUrl" target="_blank" class="file-link">
                                <i class="fas fa-download"></i> Tải tài liệu
                            </a>
                        </div>
                    }

                    @if (Model?.Tests != null && Model.Tests.Any())
                    {
                        <hr class="divider">
                        <div class="related-tests">
                            <h4>📝 Đề luyện tập của bài học này</h4>
                            @foreach (var t in Model.Tests)
                            {
                                <div class="test-mini">
                                    <div class="test-mini-name">@t.TestName <span style="color:#64748b;font-size:.8rem;">(@t.Duration phút)</span></div>
                                    <a asp-controller="Test" asp-action="Take" asp-route-id="@t.TestId" class="btn-take-mini">Bắt đầu →</a>
                                </div>
                            }
                        </div>
                    }

                    @if (User.IsInRole("Student"))
                    {
                        <hr class="divider">
                        <div style="text-align:center;padding:8px 0;">
                            <a asp-controller="Lesson" asp-action="StudentLearn" asp-route-id="@Model?.LessonId"
                               style="display:inline-block;padding:16px 48px;background:linear-gradient(135deg,#e75485,#ec6090);color:#fff;border-radius:999px;text-decoration:none;font-weight:800;font-size:1.1rem;font-family:'Nunito',sans-serif;box-shadow:0 8px 24px rgba(231,84,133,.4);transition:all .3s;"
                               id="btn-start-learn">
                                🐝 Bắt đầu học bài này!
                            </a>
                            <p style="color:#94a3b8;font-size:.82rem;margin-top:10px;">Học theo lộ trình 10 phút có gamification</p>
                        </div>
                    }

                    <a asp-action="Index" asp-route-chapterId="@Model?.ChapterId" class="back-btn">← Quay lại danh sách bài học</a>
                </div>
            </div>
        </div>
    </div>
</section>
