@model List<POT_System_ASPNET.Data.Entities.Lesson>
@{
    ViewData["Title"] = "Bài học";
    var chapter = ViewBag.Chapter as POT_System_ASPNET.Data.Entities.Chapter;

    string getPageUrl(int p) {
        var query = new List<string>();
        if (ViewBag.Filter != null) {
            try {
                var filter = ViewBag.Filter;
                string? name = filter.name;
                int? gradeId = filter.gradeId;
                int? subjectId = filter.subjectId;
                int? chapterId = filter.chapterId;
                string? status = filter.status;
                if (!string.IsNullOrEmpty(name)) query.Add($"name={Uri.EscapeDataString(name)}");
                if (gradeId.HasValue) query.Add($"gradeId={gradeId}");
                if (subjectId.HasValue) query.Add($"subjectId={subjectId}");
                if (chapterId.HasValue) query.Add($"chapterId={chapterId}");
                if (!string.IsNullOrEmpty(status)) query.Add($"status={Uri.EscapeDataString(status)}");
            } catch {}
        }
        query.Add($"page={p}");
        return "?" + string.Join("&", query);
    }
}
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .lesson-section {
        padding: 140px 0 80px;
        background: transparent !important;
        min-height: 80vh;
        position: relative;
        overflow: hidden;
        font-family: 'Nunito', sans-serif !important;
        color: #1e1b4b;
    }
    .lesson-section *:not(i):not(.fa) {
        font-family: 'Nunito', sans-serif !important;
    }

    .breadcrumb-bar { display:flex; align-items:center; gap:8px; color:#6b7280; font-size:.95rem; margin-bottom:20px; font-weight: 700; position: relative; z-index: 10; }
    .breadcrumb-bar a { color:#ec6090; text-decoration:none; }
    .breadcrumb-bar a:hover { text-decoration:underline; }

    .section-hd { display:flex; justify-content:space-between; align-items:center; margin-bottom:30px; position: relative; z-index: 10; }
    .section-hd h2 { color:#ec6090; font-weight:900; margin:0; font-size: 2.2rem; }
    
    .btn-add { display:inline-flex; align-items:center; gap:8px; padding:12px 28px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff !important; border-radius:25px; text-decoration:none; font-weight:800; font-size:.9rem; transition:all .3s cubic-bezier(0.175, 0.885, 0.32, 1.275); box-shadow: 0 5px 15px rgba(236, 96, 144, 0.2); }
    .btn-add:hover { transform:translateY(-2px) scale(1.02); box-shadow:0 8px 20px rgba(236,96,144,.4); }

    .lesson-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:24px; position: relative; z-index: 10; }
    
    .lesson-card {
        background: rgba(255, 255, 255, 0.88) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        border: 4px solid #fbcfe8 !important;
        border-radius: 35px !important;
        padding: 30px;
        box-shadow: 0 10px 25px rgba(236, 96, 144, 0.05) !important;
        transition: all 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
    .lesson-card:hover {
        transform: translateY(-8px) scale(1.02) !important;
        box-shadow: 0 15px 35px rgba(168, 85, 247, 0.15), 0 0 0 6px rgba(244, 63, 94, 0.08) !important;
        border-color: #f472b6 !important;
    }

    .lesson-icon { font-size:3rem; margin-bottom:15px; }
    .lesson-name { color:#1e1b4b; font-weight:900; font-size:1.3rem; margin-bottom:10px; }
    .lesson-content { color:#4b5563; font-size:.95rem; margin-bottom:20px; flex:1; overflow:hidden; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; line-height:1.6; font-weight: 700; }
    .lesson-footer { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; }
    
    .badge { display:inline-block; padding:6px 14px; border-radius:20px; font-size:.8rem; font-weight:800; border: 1px solid transparent; }
    .badge-active { background:rgba(16,185,129,.1); color:#10b981; border-color: rgba(16,185,129,.2); }
    .badge-pending { background:rgba(234,179,8,.1); color:#d97706; border-color: rgba(234,179,8,.2); }
    .badge-inactive { background:rgba(239,68,68,.1); color:#ef4444; border-color: rgba(239,68,68,.2); }
    
    .btn-read { padding:8px 18px; background:rgba(236,96,144,.1); color:#ec6090 !important; border-radius:20px; text-decoration:none; font-size:.85rem; font-weight:800; transition:all .2s; border: 1px solid rgba(236,96,144,.2); }
    .btn-read:hover { background:rgba(236,96,144,.2); transform: translateY(-1px); }
    
    .admin-btns { display:flex; gap:8px; margin-top:15px; flex-wrap:wrap; border-top: 2px dashed #fbcfe8; padding-top: 15px; }
    .btn-sm-action { padding:8px 16px; border-radius:20px; font-size:.8rem; font-weight:800; border:none; cursor:pointer; transition:all .2s; text-decoration:none; display: inline-flex; align-items: center; justify-content: center; }
    .btn-edit-sm { background:rgba(59,130,246,.1); color:#3b82f6 !important; border: 1px solid rgba(59,130,246,.2); }
    .btn-edit-sm:hover { background:rgba(59,130,246,.2); transform: translateY(-1px); }
    .btn-del-sm { background:rgba(239,68,68,.1); color:#ef4444 !important; border: 1px solid rgba(239,68,68,.2); }
    .btn-del-sm:hover { background:rgba(239,68,68,.2); transform: translateY(-1px); }
    .btn-approve-sm { background:rgba(16,185,129,.1); color:#10b981 !important; border: 1px solid rgba(16,185,129,.2); }
    .btn-approve-sm:hover { background:rgba(16,185,129,.2); transform: translateY(-1px); }
    
    .empty-state { text-align:center; padding:60px; color:#4b5563; position: relative; z-index: 10; font-weight: 800; }

    .kid-bg-cloud {
        position: absolute;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 100px;
        pointer-events: none;
        z-index: 1;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02);
    }
    .kid-bg-cloud::before, .kid-bg-cloud::after {
        content: '';
        position: absolute;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 50%;
    }
    .kid-bg-cloud.c1 {
        width: 120px; height: 40px; top: 12%; left: 8%;
        animation: floatCloud 24s linear infinite;
    }
    .kid-bg-cloud.c1::before { width: 50px; height: 50px; top: -25px; left: 15px; }
    .kid-bg-cloud.c1::after { width: 70px; height: 70px; top: -35px; right: 15px; }

    .kid-bg-cloud.c2 {
        width: 160px; height: 50px; bottom: 15%; right: 8%;
        animation: floatCloudReverse 28s linear infinite;
    }
    .kid-bg-cloud.c2::before { width: 70px; height: 70px; top: -35px; left: 20px; }
    .kid-bg-cloud.c2::after { width: 90px; height: 90px; top: -45px; right: 20px; }

    @@keyframes floatCloud {
        0% { transform: translateX(0); }
        50% { transform: translateX(50px); }
        100% { transform: translateX(0); }
    }
    @@keyframes floatCloudReverse {
        0% { transform: translateX(0); }
        50% { transform: translateX(-50px); }
        100% { transform: translateX(0); }
    }

    .kid-bg-star {
        position: absolute;
        font-size: 2.5rem;
        color: #f59e0b;
        opacity: 0.35;
        pointer-events: none;
        z-index: 5;
    }
    .kid-bg-star.s1 { top: 15%; right: 12%; animation: orbitRight 14s ease-in-out infinite alternate; }
    .kid-bg-star.s2 { bottom: 18%; left: 10%; animation: orbitLeft 17s ease-in-out infinite alternate; color: #fbbf24; }
    .kid-bg-star.s3 { top: 45%; left: 6%; animation: floatAroundVertical 11s ease-in-out infinite alternate; font-size: 1.8rem; color: #fca5a5; }
    .kid-bg-star.s4 { bottom: 40%; right: 6%; animation: floatAroundHorizontal 15s ease-in-out infinite alternate; font-size: 2rem; color: #38bdf8; }
    .kid-bg-star.s5 { top: 10%; left: 25%; animation: diagonalFloat 20s ease-in-out infinite alternate; font-size: 1.6rem; color: #c084fc; }

    @@keyframes orbitRight {
        0% { transform: translate(0, 0) rotate(0deg) scale(1); }
        35% { transform: translate(45px, -70px) rotate(120deg) scale(1.25); }
        70% { transform: translate(-30px, -120px) rotate(240deg) scale(0.8); }
        100% { transform: translate(0, 0) rotate(360deg) scale(1); }
    }
    @@keyframes orbitLeft {
        0% { transform: translate(0, 0) rotate(360deg) scale(0.9); }
        40% { transform: translate(-60px, 50px) rotate(180deg) scale(1.3); }
        80% { transform: translate(40px, -40px) rotate(0deg) scale(0.7); }
        100% { transform: translate(0, 0) rotate(-360deg) scale(0.9); }
    }
    @@keyframes floatAroundVertical {
        0% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-90px) rotate(180deg); }
        100% { transform: translateY(0) rotate(360deg); }
    }
    @@keyframes floatAroundHorizontal {
        0% { transform: translateX(0) rotate(0deg); }
        50% { transform: translateX(90px) rotate(-180deg); }
        100% { transform: translateX(0) rotate(-360deg); }
    }
    @@keyframes diagonalFloat {
        0% { transform: translate(0, 0) rotate(0deg); }
        50% { transform: translate(80px, 80px) rotate(180deg); }
        100% { transform: translate(0, 0) rotate(360deg); }
    }
</style>

@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Student"))
{
