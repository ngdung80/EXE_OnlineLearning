    <div class="kid-lessons-container">
        <!-- Floating cloud & star decorations -->
        <div class="kid-bg-cloud c1">☁️</div>
        <div class="kid-bg-cloud c2">☁️</div>
        <div class="kid-bg-star s1">⭐</div>
        <div class="kid-bg-star s2">⭐</div>
        <div class="kid-bg-star s3">⭐</div>
        <div class="kid-bg-star s4">⭐</div>
        <div class="kid-bg-star s5">⭐</div>
 
        <div class="kid-breadcrumb">
            <a asp-controller="Grade" asp-action="Index">🎒 Khối lớp</a>
            <span>›</span>
            <a asp-controller="Subject" asp-action="Index" asp-route-gradeId="@chapter?.Subject?.GradeId">@chapter?.Subject?.Grade?.GradeName</a>
            <span>›</span>
            <a asp-controller="Chapter" asp-action="Index" asp-route-subjectId="@chapter?.SubjectId">@chapter?.Subject?.SubjectName</a>
            <span>›</span>
            <span>@chapter?.ChapterName</span>
        </div>
 
        <div class="kid-lessons-header">
            <h1 class="kid-lessons-title">Chọn Bài Học Của Bé</h1>
            <p class="kid-lessons-sub">Bé hãy chọn một bài học thật bổ ích nhé! 📝</p>
        </div>
 
        <div class="kid-lessons-grid">
            @if (Model != null && Model.Any())
            {
                var icons = new[] { "📖", "🎯", "💡", "🔬", "🧮", "📐", "🌍", "🎨" };
                int li = 0;
                foreach (var l in Model.Where(x => x.Status == "Active"))
                {
                    var fallbackIcon = icons[li++ % icons.Length];
                    var rawDesc = l.ContentText ?? "Chưa có mô tả tóm tắt nội dung bài học.";
                    var truncatedDesc = rawDesc.Length > 85 ? rawDesc.Substring(0, 82) + "..." : rawDesc;

                    <div class="kid-lesson-card">
                        <div>
                            <span class="kid-lesson-icon">@fallbackIcon</span>
                            <h2 class="kid-lesson-name">@l.LessonName</h2>
                            <p class="kid-lesson-desc" title="@rawDesc">@truncatedDesc</p>
                        </div>
                        <a asp-action="Detail" asp-route-id="@l.LessonId" class="btn-kid-lesson-action">🚀 Học Bài Ngay</a>
                    </div>
                }
            }
            else
            {
                <div style="grid-column: 1 / -1; background:rgba(255,255,255,0.85); padding:40px; border-radius:30px; border:3px solid #fbcfe8; text-align:center;">
                    <span style="font-size:4rem;">🤔</span>
                    <p style="font-family:'Nunito',sans-serif; font-size:1.2rem; font-weight:800; color:#4f46e5; margin-top:15px;">Chưa có bài học nào cho bé trong chương này.</p>
                </div>
            }
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="kid-pagination">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="@getPageUrl(ViewBag.CurrentPage - 1)" class="kid-page-btn prev">👈 Trước</a>
                }
                else
                {
                    <span class="kid-page-btn prev disabled">👈 Trước</span>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == ViewBag.CurrentPage)
                    {
                        <span class="kid-page-btn active">@i</span>
                    }
                    else
                    {
                        <a href="@getPageUrl(i)" class="kid-page-btn">@i</a>
                    }
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="@getPageUrl(ViewBag.CurrentPage + 1)" class="kid-page-btn next">Sau 👉</a>
                }
                else
                {
                    <span class="kid-page-btn next disabled">Sau 👉</span>
                }
            </div>
        }
    </div>
}
else
{
    <!-- Clouds -->
    <div class="kid-bg-cloud c1"></div>
    <div class="kid-bg-cloud c2"></div>

    <!-- Stars -->
    <div class="kid-bg-star s1">⭐</div>
    <div class="kid-bg-star s2">✨</div>
    <div class="kid-bg-star s3">🌟</div>
    <div class="kid-bg-star s4">⭐</div>
    <div class="kid-bg-star s5">✨</div>

    <section class="lesson-section">
        <div class="container">
            <div class="breadcrumb-bar">
                <a asp-controller="Grade" asp-action="Index">Khối lớp</a>
                <span>›</span>
                <a asp-controller="Subject" asp-action="Index" asp-route-gradeId="@chapter?.Subject?.GradeId">@chapter?.Subject?.Grade?.GradeName</a>
                <span>›</span>
                <a asp-controller="Chapter" asp-action="Index" asp-route-subjectId="@chapter?.SubjectId">@chapter?.Subject?.SubjectName</a>
                <span>›</span>
                <span style="color:#1e1b4b;">@chapter?.ChapterName</span>
            </div>
            <div class="section-hd">
                <h2>📝 @(chapter?.ChapterName ?? "Bài học")</h2>
                @if (User.IsInRole("Admin") || User.IsInRole("Content Manager"))
                {
                    <a asp-action="Create" asp-route-chapterId="@chapter?.ChapterId" class="btn-add"><i class="fas fa-plus"></i> Thêm bài học</a>
                }
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="lesson-grid">
                    @{ var icons = new[] { "📖", "🎯", "💡", "🔬", "🧮", "📐", "🌍", "🎨" }; int li = 0; }
                    @foreach (var l in Model)
                    {
                        <div class="lesson-card">
                            <div class="lesson-icon">@icons[li++ % icons.Length]</div>
                            <div class="lesson-name">@l.LessonName</div>
                            <div class="lesson-content">@(l.ContentText ?? "Chưa có mô tả tóm tắt nội dung bài học.")</div>
                            <div class="lesson-footer">
                                @{
                                    string badgeClass = l.Status == "Active" ? "badge-active" : l.Status == "Pending" ? "badge-pending" : "badge-inactive";
                                    string statusText = l.Status == "Active" ? "Hoạt động" : l.Status == "Pending" ? "Chờ duyệt" : "Không hoạt động";
                                }
                                <span class="badge @badgeClass">@statusText</span>
                                <a asp-action="Detail" asp-route-id="@l.LessonId" class="btn-read">Xem chi tiết →</a>
                            </div>
                            @if (User.IsInRole("Admin") || User.IsInRole("Content Manager"))
                            {
                                <div class="admin-btns">
                                    <a asp-action="Edit" asp-route-id="@l.LessonId" class="btn-sm-action btn-edit-sm">✏️ Sửa</a>
                                    @if (User.IsInRole("Admin") && l.Status == "Pending")
                                    {
                                        <form asp-action="Approve" asp-route-id="@l.LessonId" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-sm-action btn-approve-sm">✅ Duyệt</button>
                                        </form>
                                    }
                                    <form asp-action="Delete" asp-route-id="@l.LessonId" method="post" style="display:inline" onsubmit="return confirm('Xóa bài học này?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-sm-action btn-del-sm">🗑️ Xóa</button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div style="font-size:3rem;margin-bottom:15px;">📄</div>
                    <p>Chưa có bài học nào trong chương này.</p>
                </div>
            }
        </div>
    </section>
}
