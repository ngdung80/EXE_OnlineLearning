            "horse": "🐴", "ngựa": "🐴",
            "butterfly": "🦋", "bướm": "🦋",
            "spider": "🕷️", "nhện": "🕷️",
            
            // Fruits & Food
            "apple": "🍎", "táo": "🍎",
            "banana": "🍌", "chuối": "🍌",
            "orange": "🍊", "cam": "🍊",
            "watermelon": "🍉", "dưa hấu": "🍉",
            "grape": "🍇", "nho": "🍇",
            "strawberry": "🍓", "dâu": "🍓",
            "mango": "🥭", "xoài": "🥭",
