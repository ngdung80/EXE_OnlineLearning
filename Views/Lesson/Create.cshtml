@model POT_System_ASPNET.Data.Entities.Lesson
@{
    ViewData["Title"] = "Thêm bài học";
}
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .form-section {
        padding: 140px 0 80px;
        background: transparent !important;
        min-height: 80vh;
        position: relative;
        overflow: hidden;
        font-family: 'Nunito', sans-serif !important;
        color: #1e1b4b;
    }
    .form-section *:not(i):not(.fa) {
        font-family: 'Nunito', sans-serif !important;
    }

    .form-card {
        background: rgba(255, 255, 255, 0.88) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        border: 4px solid #fbcfe8 !important;
        border-radius: 35px !important;
        overflow: hidden !important;
        box-shadow: 0 15px 35px rgba(236, 96, 144, 0.08) !important;
        position: relative;
        z-index: 10;
        padding: 40px;
        color: #1e1b4b !important;
    }

    .form-card h2 { color:#ec6090; font-weight:900; margin-bottom:30px; font-size:2.2rem; }
    .form-label { color:#4f46e5; font-size:.95rem; font-weight: 800; }
    
    .form-control, .form-select { 
        background:#ffffff !important; 
        border: 2px solid #e5e7eb !important; 
        color:#1e1b4b !important; 
        border-radius:15px !important; 
        padding:12px 15px !important; 
        width:100%; 
        font-size:14px; 
        transition:all .3s; 
        font-weight: 700; 
    }
    .form-control:focus, .form-select:focus { 
        background:#fff !important; 
        border-color:#ec6090 !important; 
        box-shadow: 0 0 0 4px rgba(236, 96, 144, 0.1) !important; 
        outline:none; 
        color:#1e1b4b !important; 
    }
    .form-control::placeholder { color:#a5b4fc; }
    .form-select option { background:#ffffff; color: #1e1b4b; }
    
    .btn-save { padding:12px 30px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff !important; border:none; border-radius:25px; font-weight:800; cursor:pointer; transition:all .3s cubic-bezier(0.175, 0.885, 0.32, 1.275); box-shadow: 0 5px 15px rgba(236, 96, 144, 0.2); }
    .btn-save:hover { transform:translateY(-2px) scale(1.02); box-shadow:0 8px 20px rgba(236,96,144,.4); }
    
    .btn-cancel { display:inline-block; padding:12px 30px; background:transparent; color:#ec6090 !important; border:2px solid #ec6090; border-radius:25px; text-decoration:none; font-weight:800; transition:all .3s; }
    .btn-cancel:hover { background: rgba(236, 96, 144, 0.05); transform: translateY(-1px); }

    .kid-bg-cloud {
        position: absolute;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 100px;
        pointer-events: none;
        z-index: 1;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02);
    }
    .kid-bg-cloud::before, .kid-bg-cloud::after {
        content: '';
        position: absolute;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 50%;
    }
    .kid-bg-cloud.c1 {
        width: 120px; height: 40px; top: 12%; left: 8%;
        animation: floatCloud 24s linear infinite;
    }
    .kid-bg-cloud.c1::before { width: 50px; height: 50px; top: -25px; left: 15px; }
    .kid-bg-cloud.c1::after { width: 70px; height: 70px; top: -35px; right: 15px; }

    .kid-bg-cloud.c2 {
        width: 160px; height: 50px; bottom: 15%; right: 8%;
        animation: floatCloudReverse 28s linear infinite;
    }
    .kid-bg-cloud.c2::before { width: 70px; height: 70px; top: -35px; left: 20px; }
    .kid-bg-cloud.c2::after { width: 90px; height: 90px; top: -45px; right: 20px; }

    @@keyframes floatCloud {
        0% { transform: translateX(0); }
        50% { transform: translateX(50px); }
        100% { transform: translateX(0); }
    }
    @@keyframes floatCloudReverse {
        0% { transform: translateX(0); }
        50% { transform: translateX(-50px); }
        100% { transform: translateX(0); }
    }

    .kid-bg-star {
        position: absolute;
        font-size: 2.5rem;
        color: #f59e0b;
        opacity: 0.35;
        pointer-events: none;
        z-index: 5;
    }
    .kid-bg-star.s1 { top: 15%; right: 12%; animation: orbitRight 14s ease-in-out infinite alternate; }
    .kid-bg-star.s2 { bottom: 18%; left: 10%; animation: orbitLeft 17s ease-in-out infinite alternate; color: #fbbf24; }
    .kid-bg-star.s3 { top: 45%; left: 6%; animation: floatAroundVertical 11s ease-in-out infinite alternate; font-size: 1.8rem; color: #fca5a5; }
    .kid-bg-star.s4 { bottom: 40%; right: 6%; animation: floatAroundHorizontal 15s ease-in-out infinite alternate; font-size: 2rem; color: #38bdf8; }
    .kid-bg-star.s5 { top: 10%; left: 25%; animation: diagonalFloat 20s ease-in-out infinite alternate; font-size: 1.6rem; color: #c084fc; }

    @@keyframes orbitRight {
        0% { transform: translate(0, 0) rotate(0deg) scale(1); }
        35% { transform: translate(45px, -70px) rotate(120deg) scale(1.25); }
        70% { transform: translate(-30px, -120px) rotate(240deg) scale(0.8); }
        100% { transform: translate(0, 0) rotate(360deg) scale(1); }
    }
    @@keyframes orbitLeft {
        0% { transform: translate(0, 0) rotate(360deg) scale(0.9); }
        40% { transform: translate(-60px, 50px) rotate(180deg) scale(1.3); }
        80% { transform: translate(40px, -40px) rotate(0deg) scale(0.7); }
        100% { transform: translate(0, 0) rotate(-360deg) scale(0.9); }
    }
    @@keyframes floatAroundVertical {
        0% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-90px) rotate(180deg); }
        100% { transform: translateY(0) rotate(360deg); }
    }
    @@keyframes floatAroundHorizontal {
        0% { transform: translateX(0) rotate(0deg); }
        50% { transform: translateX(90px) rotate(-180deg); }
        100% { transform: translateX(0) rotate(-360deg); }
    }
    @@keyframes diagonalFloat {
        0% { transform: translate(0, 0) rotate(0deg); }
        50% { transform: translate(80px, 80px) rotate(180deg); }
        100% { transform: translate(0, 0) rotate(360deg); }
    }
</style>

<!-- Clouds -->
<div class="kid-bg-cloud c1"></div>
<div class="kid-bg-cloud c2"></div>

<!-- Stars -->
<div class="kid-bg-star s1">⭐</div>
<div class="kid-bg-star s2">✨</div>
<div class="kid-bg-star s3">🌟</div>
<div class="kid-bg-star s4">⭐</div>
<div class="kid-bg-star s5">✨</div>

<section class="form-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="form-card">
                    <h2>Thêm bài học mới</h2>
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Khối lớp *</label>
                                <select id="gradeSelect" class="form-select" required>
                                    <option value="">-- Chọn khối lớp --</option>
                                    @if (ViewBag.Grades != null)
                                    {
                                        foreach (var grade in (List<POT_System_ASPNET.Data.Entities.Grade>)ViewBag.Grades)
                                        {
                                            <option value="@grade.GradeId" selected="@(ViewBag.SelectedGradeId != null && (int)ViewBag.SelectedGradeId == grade.GradeId)">@grade.GradeName</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Môn học *</label>
                                <select id="subjectSelect" class="form-select" required disabled>
                                    <option value="">-- Chọn môn học --</option>
                                    @if (ViewBag.Subjects != null)
                                    {
                                        foreach (var subject in (List<POT_System_ASPNET.Data.Entities.Subject>)ViewBag.Subjects)
                                        {
                                            <option value="@subject.SubjectId" selected="@(ViewBag.SelectedSubjectId != null && (int)ViewBag.SelectedSubjectId == subject.SubjectId)">@subject.SubjectName</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Chương học *</label>
                                <select id="chapterSelect" name="ChapterId" class="form-select" required disabled>
                                    <option value="">-- Chọn chương học --</option>
                                    @if (ViewBag.Chapters != null)
                                    {
                                        foreach (var chapter in (List<POT_System_ASPNET.Data.Entities.Chapter>)ViewBag.Chapters)
                                        {
                                            <option value="@chapter.ChapterId" selected="@(ViewBag.SelectedChapterId != null && (int)ViewBag.SelectedChapterId == chapter.ChapterId)">@chapter.ChapterName</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Tên bài học *</label>
                            <input type="text" name="LessonName" class="form-control" placeholder="Ví dụ: Giới thiệu về Đạo hàm" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Nội dung bài học</label>
                            <textarea name="ContentText" class="form-control" rows="8" placeholder="Nhập nội dung bài học hoặc văn bản tại đây..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ảnh bìa</label>
                            <input type="file" name="imageFile" class="form-control" accept="image/*">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Link video học tập (YouTube hoặc link file trực tiếp)</label>
                            <input type="text" name="FileUrl" class="form-control" placeholder="Dán link YouTube hoặc đường dẫn file cục bộ từ máy tính của bạn">
                        </div>

                        <!-- Vocabulary Editor Section -->
                        <div class="mb-4">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                                <label class="form-label" style="font-weight:900; color:#ec6090; font-size:1.2rem; margin:0;">📚 Danh sách từ mới của bài học</label>
                                <button type="button" class="btn-sm-action" onclick="addVocabularyRow()" style="padding:10px 20px; background:linear-gradient(135deg,#a855f7,#7c3aed); color:#fff !important; border:none; border-radius:20px; font-weight:800; cursor:pointer; box-shadow: 0 4px 10px rgba(168, 85, 247, 0.25);">+ Thêm từ mới</button>
                            </div>
                            
                            <div id="vocab-container" style="display:flex; flex-direction:column; gap:12px;">
                                <!-- Dynamically rendered -->
                            </div>
                            
                            <input type="hidden" id="VocabularyJson" name="VocabularyJson" value="" />
                        </div>

                        <!-- Emoji datalist for suggestion -->
                        <datalist id="emoji-list">
                            <option value="🍎">🍎 Quả táo</option>
                            <option value="🍌">🍌 Quả chuối</option>
                            <option value="🍊">🍊 Quả cam</option>
                            <option value="🐱">🐱 Con mèo</option>
                            <option value="🐶">🐶 Con chó</option>
                            <option value="🐟">🐟 Con cá</option>
                            <option value="🦁">🦁 Sư tử</option>
                            <option value="🐸">🐸 Con ếch</option>
                            <option value="🐒">🐒 Con khỉ</option>
                            <option value="🚗">🚗 Ô tô</option>
                            <option value="✈️">✈️ Máy bay</option>
                            <option value="⚽">⚽ Bóng đá</option>
                            <option value="📚">📚 Quyển sách</option>
                            <option value="✏️">✏️ Bút chì</option>
                            <option value="🏫">🏫 Trường học</option>
                            <option value="🎈">🎈 Bóng bay</option>
                            <option value="🧸">🧸 Gấu bông</option>
                            <option value="🍕">🍕 Bánh Pizza</option>
                            <option value="🎂">🎂 Bánh kem</option>
                            <option value="☀️">☀️ Mặt trời</option>
                            <option value="🌧️">🌧️ Cơn mưa</option>
                            <option value="🌈">🌈 Cầu vồng</option>
                            <option value="⭐">⭐ Ngôi sao</option>
                        </datalist>

                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn-save">💾 Lưu bài học</button>
                            <a asp-action="Index" class="btn-cancel">← Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const gradeSelect = document.getElementById('gradeSelect');
        const subjectSelect = document.getElementById('subjectSelect');
        const chapterSelect = document.getElementById('chapterSelect');

        gradeSelect.addEventListener('change', async function() {
            const gradeId = this.value;
            subjectSelect.innerHTML = '<option value="">-- Chọn môn học --</option>';
            chapterSelect.innerHTML = '<option value="">-- Chọn chương học --</option>';
            subjectSelect.disabled = true;
            chapterSelect.disabled = true;

            if (!gradeId) return;

            try {
                const response = await fetch(`/Subject/GetByGrade?gradeId=${gradeId}`);
                if (response.ok) {
                    const subjects = await response.json();
                    subjects.forEach(sub => {
                        const opt = document.createElement('option');
                        opt.value = sub.subjectId;
                        opt.textContent = sub.subjectName;
                        subjectSelect.appendChild(opt);
                    });
                    subjectSelect.disabled = false;
                }
            } catch (err) {
                console.error("Error loading subjects:", err);
            }
        });

        subjectSelect.addEventListener('change', async function() {
            const subjectId = this.value;
            chapterSelect.innerHTML = '<option value="">-- Chọn chương học --</option>';
            chapterSelect.disabled = true;

            if (!subjectId) return;

            try {
                const response = await fetch(`/Chapter/GetBySubject?subjectId=${subjectId}`);
                if (response.ok) {
                    const chapters = await response.json();
                    chapters.forEach(ch => {
                        const opt = document.createElement('option');
                        opt.value = ch.chapterId;
                        opt.textContent = ch.chapterName;
                        chapterSelect.appendChild(opt);
                    });
                    chapterSelect.disabled = false;
                }
            } catch (err) {
                console.error("Error loading chapters:", err);
            }
        });

        // ===== VOCABULARY MANAGER =====
        const emojiMap = {
            // Animals
            "cat": "🐱", "mèo": "🐱",
            "dog": "🐶", "chó": "🐶",
            "fish": "🐟", "cá": "🐟",
            "bird": "🐦", "chim": "🐦",
            "lion": "🦁", "sư tử": "🦁",
            "tiger": "🐯", "hổ": "🐯", "cọp": "🐯",
            "monkey": "🐒", "khỉ": "🐒",
            "rabbit": "🐰", "thỏ": "🐰",
            "elephant": "🐘", "voi": "🐘",
            "bear": "🧸", "gấu": "🧸",
            "bee": "🐝", "ong": "🐝",
            "ant": "🐜", "kiến": "🐜",
            "frog": "🐸", "ếch": "🐸",
            "duck": "🦆", "vịt": "🦆",
            "chicken": "🐔", "gà": "🐔",
            "pig": "🐷", "heo": "🐷", "lợn": "🐷",
