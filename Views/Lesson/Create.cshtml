            "ruler": "📏", "thước": "📏",
            "bag": "🎒", "cặp": "🎒", "balo": "🎒",
            "school": "🏫", "trường": "🏫",
            "star": "⭐", "sao": "⭐",
            "heart": "❤️", "tim": "❤️",
            
            // Objects & Vehicles
            "car": "🚗", "ô tô": "🚗", "xe": "🚗",
            "plane": "✈️", "máy bay": "✈️",
            "train": "🚂", "tàu": "🚂",
            "ball": "⚽", "bóng": "⚽", "football": "⚽",
            "balloon": "🎈", "bóng bay": "🎈",
            "bicycle": "🚲", "xe đạp": "🚲",
            "clock": "⏰", "đồng hồ": "⏰", "time": "⏰",
            "house": "🏠", "nhà": "🏠",
            "sun": "☀️", "mặt trời": "☀️",
            "rain": "🌧️", "mưa": "🌧️",
            "rainbow": "🌈", "cầu vồng": "🌈",
            "flower": "🌸", "hoa": "🌸",
            "tree": "🌳", "cây": "🌳"
        };

        let vocabList = [];

        function renderVocabRows() {
            const container = document.getElementById('vocab-container');
            container.innerHTML = '';
            
            if (vocabList.length === 0) {
                container.innerHTML = `<div id="vocab-empty-msg" style="color:#4f46e5; font-size:0.95rem; padding:25px; text-align:center; background:rgba(236,96,144,0.03); border:2px dashed #fbcfe8; border-radius:20px; font-weight:800;">Chưa có từ mới nào. Hãy nhấn "+ Thêm từ mới" để bắt đầu!</div>`;
                return;
            }
            
            vocabList.forEach((item, index) => {
                const row = document.createElement('div');
                row.className = 'vocab-row';
                row.style = 'background:#ffffff; border:3px solid #fbcfe8; padding:20px; border-radius:20px; margin-bottom:15px; display:flex; flex-direction:column; gap:12px; box-shadow: 0 5px 15px rgba(236,96,144,0.03);';
                row.innerHTML = `
                    <div style="width:100%; display:flex; gap:12px; flex-wrap:wrap;">
                        <div style="flex:1; min-width:140px;">
                            <label style="font-size:0.85rem; color:#4f46e5; display:block; margin-bottom:6px; font-weight:800;">Từ mới *</label>
                            <input type="text" class="form-control" value="${item.word || ''}" oninput="updateVocabValue(${index}, 'word', this.value); suggestEmojiFromWord(${index}, this.value);" placeholder="Ví dụ: Apple" required style="padding:10px 14px; font-size:0.9rem; font-weight:700;">
                        </div>
                        <div style="flex:1; min-width:140px;">
                            <label style="font-size:0.85rem; color:#4f46e5; display:block; margin-bottom:6px; font-weight:800;">Phát âm</label>
                            <input type="text" class="form-control" value="${item.phonetic || ''}" onchange="updateVocabValue(${index}, 'phonetic', this.value)" placeholder="Ví dụ: /ˈæp.əl/" style="padding:10px 14px; font-size:0.9rem; font-weight:700;">
                        </div>
                        <div style="flex:1.2; min-width:160px;">
                            <label style="font-size:0.85rem; color:#ec6090; display:block; margin-bottom:6px; font-weight:800;">Nghĩa đúng (Đáp án đúng) *</label>
                            <input type="text" class="form-control" value="${item.meaning || ''}" oninput="updateVocabValue(${index}, 'meaning', this.value); suggestEmojiFromWord(${index}, this.value);" placeholder="Ví dụ: Quả táo" required style="padding:10px 14px; font-size:0.9rem; border-color:#ec6090; font-weight:700;">
                        </div>
                        <div style="width:140px;">
                            <label style="font-size:0.85rem; color:#4f46e5; display:block; margin-bottom:6px; font-weight:800;">Emoji / Gợi ý</label>
                            <input type="text" class="form-control" id="emoji-input-${index}" value="${item.emoji || ''}" oninput="updateVocabValue(${index}, 'emoji', this.value); handleEmojiSearch(${index}, this.value);" placeholder="Nhập từ khóa..." style="padding:10px 14px; text-align:center; font-size:0.9rem; font-weight:700;">
                            <div id="emoji-suggestions-${index}" style="margin-top:6px; display:flex; flex-wrap:wrap; gap:4px;"></div>
                        </div>
                    </div>
                    
                    <div style="width:100%; display:flex; gap:12px; flex-wrap:wrap; background:rgba(239,68,68,0.03); padding:15px; border-radius:15px; border: 2px dashed #fca5a5;">
                        <div style="flex:1; min-width:120px;">
                            <label style="font-size:0.8rem; color:#ef4444; display:block; margin-bottom:6px; font-weight:800;">Nghĩa sai (Nhiễu 1) *</label>
                            <input type="text" class="form-control" value="${item.wrong1 || ''}" onchange="updateVocabValue(${index}, 'wrong1', this.value)" placeholder="Ví dụ: Quả cam" required style="padding:8px 12px; font-size:0.85rem; border-color:rgba(239,68,68,0.2); font-weight:700;">
                        </div>
                        <div style="flex:1; min-width:120px;">
                            <label style="font-size:0.8rem; color:#ef4444; display:block; margin-bottom:6px; font-weight:800;">Nghĩa sai (Nhiễu 2) *</label>
                            <input type="text" class="form-control" value="${item.wrong2 || ''}" onchange="updateVocabValue(${index}, 'wrong2', this.value)" placeholder="Ví dụ: Quả chuối" required style="padding:8px 12px; font-size:0.85rem; border-color:rgba(239,68,68,0.2); font-weight:700;">
                        </div>
                        <div style="flex:1; min-width:120px;">
                            <label style="font-size:0.8rem; color:#ef4444; display:block; margin-bottom:6px; font-weight:800;">Nghĩa sai (Nhiễu 3) *</label>
                            <input type="text" class="form-control" value="${item.wrong3 || ''}" onchange="updateVocabValue(${index}, 'wrong3', this.value)" placeholder="Ví dụ: Con mèo" required style="padding:8px 12px; font-size:0.85rem; border-color:rgba(239,68,68,0.2); font-weight:700;">
                        </div>
                    </div>
                    
                    <div style="width:100%; display:flex; justify-content:space-between; align-items:center; border-top:2px dashed #fbcfe8; padding-top:12px; margin-top:6px;">
                        <button type="button" onclick="removeVocabRow(${index})" style="background:#fef2f2; color:#ef4444; border:2px solid #fee2e2; padding:8px 18px; border-radius:15px; cursor:pointer; font-weight:800; font-size:0.85rem; margin-left:auto; transition:all .2s;">
                            🗑️ Xóa từ này
                        </button>
                    </div>
                `;
                container.appendChild(row);
            });
        }

        function addVocabularyRow() {
            vocabList.push({ word: '', phonetic: '', meaning: '', wrong1: '', wrong2: '', wrong3: '', emoji: '' });
            renderVocabRows();
            updateHiddenInput();
        }

        function removeVocabRow(index) {
            vocabList.splice(index, 1);
            renderVocabRows();
            updateHiddenInput();
        }

        function updateVocabValue(index, field, value) {
            vocabList[index][field] = value;
            updateHiddenInput();
        }

        function updateVocabEmoji(index, emoji) {
            vocabList[index]['emoji'] = emoji;
            const input = document.getElementById(`emoji-input-${index}`);
            if (input) input.value = emoji;
            updateHiddenInput();
        }

        function suggestEmojiFromWord(index, wordValue) {
            if (!wordValue) return;
            const cleanWord = wordValue.toLowerCase().trim();
            for (let key in emojiMap) {
                if (cleanWord === key || cleanWord.includes(key)) {
                    const emoji = emojiMap[key];
                    const emojiInput = document.getElementById(`emoji-input-${index}`);
                    if (emojiInput && !emojiInput.value) {
                        updateVocabEmoji(index, emoji);
                    }
                    break;
                }
            }
        }

        function handleEmojiSearch(index, val) {
            const suggestionsContainer = document.getElementById(`emoji-suggestions-${index}`);
            if (!suggestionsContainer) return;
            
            if (!val || val.trim() === '') {
                suggestionsContainer.innerHTML = '';
                return;
            }
            
            const cleanVal = val.toLowerCase().trim();
            
            // Check if exact match to a key in dictionary, if so replace it immediately
            if (emojiMap[cleanVal]) {
                const emoji = emojiMap[cleanVal];
                updateVocabEmoji(index, emoji);
                suggestionsContainer.innerHTML = '';
                return;
            }
            
            const matches = new Set();
            for (let key in emojiMap) {
                if (key.includes(cleanVal)) {
                    matches.add(emojiMap[key]);
                }
            }
            
            suggestionsContainer.innerHTML = '';
            if (matches.size > 0) {
                matches.forEach(emoji => {
                    const span = document.createElement('span');
                    span.style = 'cursor:pointer; margin-right:5px; font-size:1.2rem; background:#f3f4f6; border: 1px solid #e5e7eb; padding:4px 8px; border-radius:8px; display:inline-block; transition: all 0.2s;';
                    span.textContent = emoji;
                    span.onclick = () => {
                        updateVocabEmoji(index, emoji);
                        suggestionsContainer.innerHTML = '';
                    };
                    suggestionsContainer.appendChild(span);
                });
            }
        }

        function updateHiddenInput() {
            document.getElementById('VocabularyJson').value = JSON.stringify(vocabList);
        }

        // Initialize empty state
        renderVocabRows();
    </script>
}
