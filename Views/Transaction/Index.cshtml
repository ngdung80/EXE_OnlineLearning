@model IEnumerable<POT_System_ASPNET.Data.Entities.Transaction>

@{
    ViewData["Title"] = "Quản lý giao dịch";
    var walletTransactions = ViewBag.WalletTransactions as List<POT_System_ASPNET.Data.Entities.WalletTransaction> ?? new List<POT_System_ASPNET.Data.Entities.WalletTransaction>();
}

<div class="container mt-5 mb-5" style="padding-top: 100px;">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h2 style="color: #e75485; font-weight: 700;">Quản lý Giao Dịch</h2>
            <p class="text-muted">Xem và duyệt lịch sử giao dịch mua gói học hoặc nạp tiền của phụ huynh.</p>
        </div>
    </div>

    <!-- Filter Form -->
    <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px; background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(10px); border: 1px solid #fce7f3 !important;">
        <div class="card-body p-4">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <input type="hidden" name="tab" id="activeTabHiddenInput" value="@(Context.Request.Query["tab"].ToString() == "wallet" ? "wallet" : "packages")" />
                
                <div class="col-md-3">
                    <label for="parentName" class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Tìm phụ huynh</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 10px 0 0 10px; border-color: #dee2e6;"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="parentName" id="parentName" class="form-control border-start-0" placeholder="Tên hoặc Username..." value="@ViewBag.ParentName" style="border-radius: 0 10px 10px 0; border-color: #dee2e6;" />
                    </div>
                </div>

                <div class="col-md-3">
                    <label for="status" class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Trạng thái</label>
                    <select name="status" id="status" class="form-select" style="border-radius: 10px; border-color: #dee2e6;">
                        <option value="">-- Tất cả trạng thái --</option>
                        @if (ViewBag.Status == "Completed")
                        {
                            <option value="Completed" selected>Thành công / Đã nạp</option>
                        }
                        else
                        {
                            <option value="Completed">Thành công / Đã nạp</option>
                        }
                        @if (ViewBag.Status == "Pending")
                        {
                            <option value="Pending" selected>Chờ xử lý / Chờ duyệt</option>
                        }
                        else
                        {
                            <option value="Pending">Chờ xử lý / Chờ duyệt</option>
                        }
                        @if (ViewBag.Status == "Cancelled")
                        {
                            <option value="Cancelled" selected>Đã hủy / Từ chối</option>
                        }
                        else
                        {
                            <option value="Cancelled">Đã hủy / Từ chối</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label for="startDate" class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Từ ngày</label>
                    <input type="date" name="startDate" id="startDate" class="form-control" value="@ViewBag.StartDate" style="border-radius: 10px; border-color: #dee2e6;" />
                </div>

                <div class="col-md-2">
                    <label for="endDate" class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Đến ngày</label>
                    <input type="date" name="endDate" id="endDate" class="form-control" value="@ViewBag.EndDate" style="border-radius: 10px; border-color: #dee2e6;" />
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold" style="border-radius: 10px; background: linear-gradient(135deg, #e75485, #ec6090); border: none;">
                        <i class="fas fa-filter me-1"></i> Lọc
                    </button>
                    <a asp-action="Index" asp-route-tab="@(Context.Request.Query["tab"].ToString() == "wallet" ? "wallet" : "packages")" class="btn btn-outline-secondary w-100 fw-bold" style="border-radius: 10px;">
                        Xóa Lọc
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 10px;">
            ✓ @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 10px;">
            ✗ @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Tabs Navigation -->
    <style>
        #transactionTabs .nav-link {
            color: #6b7280;
            border: none;
            border-bottom: 3px solid transparent;
            background: transparent;
            padding: 10px 20px;
            transition: color 0.2s, border-color 0.2s;
        }
        #transactionTabs .nav-link.active,
        #transactionTabs .nav-link:hover {
            color: #e75485 !important;
            border-bottom: 3px solid #e75485 !important;
            background: transparent !important;
        }
    </style>
    <ul class="nav nav-tabs mb-4" id="transactionTabs" role="tablist" style="border-bottom: 2px solid #fce7f3;">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold" id="packages-tab" data-bs-toggle="tab" data-bs-target="#packages" type="button" role="tab" aria-controls="packages" aria-selected="true">
                🛒 Mua gói học (@Model.Count())
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold" id="wallet-tab" data-bs-toggle="tab" data-bs-target="#wallet" type="button" role="tab" aria-controls="wallet" aria-selected="false">
                💰 Nạp tiền ví (@walletTransactions.Count)
            </button>
        </li>
    </ul>

    <div class="tab-content" id="transactionTabsContent">
        <!-- Tab 1: Packages -->
        <div class="tab-pane fade show active" id="packages" role="tabpanel" aria-labelledby="packages-tab">
            <div class="card shadow-sm" style="border-radius: 15px;">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Mã Giao Dịch</th>
                                    <th>Người Dùng</th>
                                    <th>Gói Học</th>
                                    <th>Số Tiền</th>
                                    <th>Ngày Giao Dịch</th>
                                    <th>Trạng Thái</th>
                                    <th>Thao Tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>#@item.TransactionId</td>
                                        <td>@(item.User?.Username ?? "N/A")</td>
                                        <td>@(item.Package?.PackageName ?? "N/A")</td>
                                        <td class="text-success fw-bold">@String.Format("{0:N0}", item.Amount) đ</td>
                                        <td>@(item.TransactionDate?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                                        <td>
                                            @if (item.Status == "Completed")
                                            {
                                                <span class="badge bg-success">Thành công</span>
                                            }
                                            else if (item.Status == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">@item.Status</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                @if (item.Status == "Pending")
                                                {
                                                    <form asp-action="ApprovePackageTransaction" method="post" style="margin:0;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="transactionId" value="@item.TransactionId" />
                                                        <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Duyệt giao dịch này và kích hoạt khóa học cho học sinh?')">Duyệt</button>
                                                    </form>
                                                    <form asp-action="CancelPackageTransaction" method="post" style="margin:0;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="transactionId" value="@item.TransactionId" />
                                                        <button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Từ chối giao dịch mua gói học này?')">Từ chối</button>
                                                    </form>
                                                }
                                                <form asp-action="DeletePackageTransaction" method="post" style="margin:0;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="transactionId" value="@item.TransactionId" />
                                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa giao dịch này khỏi lịch sử?')">Xóa</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">Không có giao dịch mua gói nào</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 2: Wallet Transactions -->
        <div class="tab-pane fade" id="wallet" role="tabpanel" aria-labelledby="wallet-tab">
            <div class="card shadow-sm" style="border-radius: 15px;">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Mã GD Ví</th>
                                    <th>Phụ Huynh</th>
                                    <th>Số Tiền</th>
                                    <th>Nội Dung</th>
                                    <th>Ngày Tạo</th>
                                    <th>Trạng Thái</th>
                                    <th>Thao Tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var wt in walletTransactions)
                                {
                                    var parentName = wt.Wallet?.Parent?.FullName ?? wt.Wallet?.Parent?.Username ?? "N/A";
                                    <tr>
                                        <td>#@wt.WalletTransactionId</td>
                                        <td>
                                            <div><strong>@parentName</strong></div>
                                            <small class="text-muted">ID: @(wt.Wallet?.ParentId)</small>
                                        </td>
                                        <td class="text-primary fw-bold">@String.Format("{0:N0}", wt.Amount) đ</td>
                                        <td>@wt.Description</td>
                                        <td>@(wt.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                                        <td>
                                            @if (wt.Status == "Completed")
                                            {
                                                <span class="badge bg-success">Đã nạp</span>
                                            }
                                            else if (wt.Status == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">@wt.Status</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                @if (wt.Status == "Pending")
                                                {
                                                    <form asp-action="ApproveWalletTransaction" method="post" style="margin:0;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="transactionId" value="@wt.WalletTransactionId" />
                                                        <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Duyệt giao dịch này và cộng tiền vào ví phụ huynh?')">Duyệt</button>
                                                    </form>
                                                    <form asp-action="CancelWalletTransaction" method="post" style="margin:0;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="transactionId" value="@wt.WalletTransactionId" />
                                                        <button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Từ chối giao dịch nạp tiền này?')">Từ chối</button>
                                                    </form>
                                                }
                                                <form asp-action="DeleteWalletTransaction" method="post" style="margin:0;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="transactionId" value="@wt.WalletTransactionId" />
                                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa giao dịch này khỏi lịch sử?')">Xóa</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!walletTransactions.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">Không có giao dịch nạp tiền nào</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Auto-activate tab based on URL query param e.g. ?tab=wallet
        var urlParams = new URLSearchParams(window.location.search);
        var activeTab = urlParams.get('tab');

        if (activeTab === 'wallet') {
            var walletTabEl = document.getElementById('wallet-tab');
            if (walletTabEl) {
                var tab = new bootstrap.Tab(walletTabEl);
                tab.show();
            }
        }

        // Keep track of active tab in filter form hidden input
        var activeTabInput = document.getElementById('activeTabHiddenInput');
        var tabEls = document.querySelectorAll('button[data-bs-toggle="tab"]');
        tabEls.forEach(function(tabEl) {
            tabEl.addEventListener('shown.bs.tab', function (event) {
                var targetId = event.target.getAttribute('id');
                if (targetId === 'wallet-tab') {
                    if (activeTabInput) activeTabInput.value = 'wallet';
                    // Update clear button url too
                    var clearBtn = document.querySelector('a.btn-outline-secondary');
                    if (clearBtn) clearBtn.setAttribute('href', '/Transaction?tab=wallet');
                } else {
                    if (activeTabInput) activeTabInput.value = 'packages';
                    // Update clear button url too
                    var clearBtn = document.querySelector('a.btn-outline-secondary');
                    if (clearBtn) clearBtn.setAttribute('href', '/Transaction?tab=packages');
                }
            });
        });
    });
</script>
