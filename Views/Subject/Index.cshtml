@model List<POT_System_ASPNET.Data.Entities.Subject>
@{
    ViewData["Title"] = "Môn học";
    var grade = ViewBag.Grade as POT_System_ASPNET.Data.Entities.Grade;
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<style>
    .sub-section { padding:80px 0; background:linear-gradient(135deg,#0f172a,#1e293b); min-height:80vh; }
    .breadcrumb-bar { display:flex; align-items:center; gap:8px; color:#64748b; font-size:.9rem; margin-bottom:20px; }
    .breadcrumb-bar a { color:#ec6090; text-decoration:none; }
    .breadcrumb-bar a:hover { text-decoration:underline; }
    .section-hd { display:flex; justify-content:space-between; align-items:center; margin-bottom:30px; }
    .section-hd h2 { color:#ec6090; font-weight:700; margin:0; }
    .btn-add { display:inline-flex; align-items:center; gap:8px; padding:10px 22px; background:linear-gradient(135deg,#ec6090,#e75485); color:#fff; border-radius:25px; text-decoration:none; font-weight:600; font-size:.88rem; transition:all .3s; }
    .btn-add:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(236,96,144,.4); color:#fff; }
    .subject-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:20px; }
    .sub-card { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.09); border-radius:16px; overflow:hidden; transition:all .3s; }
    .sub-card:hover { transform:translateY(-6px); border-color:rgba(236,96,144,.4); box-shadow:0 16px 35px rgba(0,0,0,.3); }
    .sub-img { width:100%; height:140px; object-fit:cover; background:linear-gradient(135deg,#1e293b,#334155); }
    .sub-img-placeholder { width:100%; height:140px; background:linear-gradient(135deg,rgba(236,96,144,.2),rgba(231,84,133,.05)); display:flex; align-items:center; justify-content:center; font-size:3rem; }
    .sub-body { padding:18px; }
    .sub-name { color:#e2e8f0; font-weight:700; font-size:1rem; margin-bottom:6px; }
    .sub-desc { color:#94a3b8; font-size:.83rem; margin-bottom:14px; line-height:1.5; }
    .sub-footer { display:flex; justify-content:space-between; align-items:center; }
    .badge-active { display:inline-block; padding:3px 10px; background:rgba(16,185,129,.2); color:#10b981; border-radius:15px; font-size:.75rem; font-weight:600; }
    .badge-inactive { display:inline-block; padding:3px 10px; background:rgba(239,68,68,.2); color:#ef4444; border-radius:15px; font-size:.75rem; font-weight:600; }
    .btn-view-ch { padding:6px 14px; background:rgba(236,96,144,.15); color:#ec6090; border-radius:15px; text-decoration:none; font-size:.8rem; font-weight:600; transition:all .2s; }
    .btn-view-ch:hover { background:rgba(236,96,144,.3); color:#ec6090; }
    .admin-btns { display:flex; gap:6px; margin-top:10px; }
    .btn-sm-action { padding:5px 12px; border-radius:12px; font-size:.76rem; font-weight:600; border:none; cursor:pointer; transition:all .2s; text-decoration:none; }
    .btn-edit-sm { background:rgba(59,130,246,.2); color:#60a5fa; }
    .btn-edit-sm:hover { background:rgba(59,130,246,.4); }
    .btn-del-sm { background:rgba(239,68,68,.2); color:#f87171; }
    .btn-del-sm:hover { background:rgba(239,68,68,.4); }
    .empty-state { text-align:center; padding:60px; color:#64748b; }
</style>

<section class="sub-section">
    <div class="container">
        <div class="breadcrumb-bar">
            <a asp-controller="Grade" asp-action="Index">Khối lớp</a>
            <span>›</span>
            <span style="color:#e2e8f0;">@(grade?.GradeName ?? "Môn học")</span>
        </div>
        <div class="section-hd">
            <h2>📖 @(grade?.GradeName ?? "Tất cả") — Môn học</h2>
            @if (User.IsInRole("Admin") || User.IsInRole("Content Manager"))
            {
                <a asp-action="Create" asp-route-gradeId="@grade?.GradeId" class="btn-add"><i class="fas fa-plus"></i> Thêm môn học</a>
            }
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="subject-grid">
                @foreach (var s in Model)
                {
                    <div class="sub-card">
                        @if (!string.IsNullOrEmpty(s.Image))
                        {
                            <img src="@s.Image" class="sub-img" alt="@s.SubjectName" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                            <div class="sub-img-placeholder" style="display:none;">📚</div>
                        }
                        else
                        {
                            <div class="sub-img-placeholder">📚</div>
                        }
                        <div class="sub-body">
                            <div class="sub-name">@s.SubjectName</div>
                            <div class="sub-desc">@(s.Description ?? "Chưa có mô tả môn học.")</div>
                            <div class="sub-footer">
                                @if (s.Status == "Active") { <span class="badge-active">Hoạt động</span> }
                                else { <span class="badge-inactive">@(s.Status == "Inactive" ? "Không hoạt động" : s.Status ?? "—")</span> }
                                <a asp-controller="Chapter" asp-action="Index" asp-route-subjectId="@s.SubjectId" class="btn-view-ch">Chương học →</a>
                            </div>
                            @if (User.IsInRole("Admin") || User.IsInRole("Content Manager"))
                            {
                                <div class="admin-btns">
                                    <a asp-action="Edit" asp-route-id="@s.SubjectId" class="btn-sm-action btn-edit-sm">✏️ Sửa</a>
                                    <form asp-action="Delete" asp-route-id="@s.SubjectId" method="post" style="display:inline" onsubmit="return confirm('Xóa môn học này?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-sm-action btn-del-sm">🗑️ Xóa</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div style="font-size:3rem;margin-bottom:15px;">📭</div>
                <p>Không tìm thấy môn học nào cho khối lớp này.</p>
                @if (User.IsInRole("Admin") || User.IsInRole("Content Manager"))
                {
                    <a asp-action="Create" asp-route-gradeId="@grade?.GradeId" class="btn-add" style="display:inline-flex;margin-top:15px;">+ Thêm môn học đầu tiên</a>
                }
            </div>
        }
    </div>
</section>
