<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - PLO Learning" : "PLO Learning - Học Tiếng Anh Online Cho Trẻ Em")</title>

    @* SEO Meta Tags *@
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "PLO Learning - Nền tảng học tiếng Anh online cá nhân hóa cho trẻ em lớp 1 và lớp 2. Lộ trình bám sát sách giáo khoa, báo cáo thông minh cho phụ huynh.")">
    <meta name="keywords" content="PLO, PLO Learning, plo-learning, học tiếng Anh online, tiếng Anh cho trẻ em, tiếng Anh lớp 1, tiếng Anh lớp 2, học tiếng Anh trực tuyến, phonics, english for kids">
    <meta name="author" content="PLO Learning">
    <meta name="robots" content="index, follow">
    <meta name="language" content="Vietnamese">
    <link rel="canonical" href="https://plo-learning.com@(Context.Request.Path)">

    @* Open Graph (Facebook, Zalo share) *@
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="PLO Learning">
    <meta property="og:title" content="@(ViewData["Title"] != null ? ViewData["Title"] + " - PLO Learning" : "PLO Learning - Học Tiếng Anh Online Cho Trẻ Em")">
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? "Nền tảng học tiếng Anh online cá nhân hóa cho trẻ em lớp 1 và lớp 2. Lộ trình bám sát SGK, báo cáo thông minh cho phụ huynh.")">
    <meta property="og:url" content="https://plo-learning.com@(Context.Request.Path)">
    <meta property="og:image" content="https://plo-learning.com/assets/images/og-banner.png">
    <meta property="og:locale" content="vi_VN">

    @* Twitter Card *@
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="PLO Learning - Học Tiếng Anh Online Cho Trẻ Em">
    <meta name="twitter:description" content="Nền tảng học tiếng Anh online cá nhân hóa cho trẻ em lớp 1 và lớp 2.">
    <meta name="twitter:image" content="https://plo-learning.com/assets/images/og-banner.png">

    @* Structured Data JSON-LD *@
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "WebSite",
      "name": "PLO Learning",
      "alternateName": "PLO",
      "url": "https://plo-learning.com",
      "description": "Nền tảng học tiếng Anh online cá nhân hóa cho trẻ em lớp 1 và lớp 2",
      "potentialAction": {
        "@@type": "SearchAction",
        "target": {
          "@@type": "EntryPoint",
          "urlTemplate": "https://plo-learning.com/Lesson?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="~/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/assets/css/fontawesome.css">
    <link rel="stylesheet" href="~/assets/css/templatemo-cyborg-gaming.css">
    <link rel="stylesheet" href="~/assets/css/owl.css">
    <link rel="stylesheet" href="~/assets/css/animate.css">
    <link rel="stylesheet" href="https://unpkg.com/swiper@7/swiper-bundle.min.css"/>

    <style>
        html {
            overflow-y: scroll !important;
        }
        body, p, span, h1, h2, h3, h4, h5, h6, input, select, textarea, button, label, a {
            font-family: 'Inter', sans-serif !important;
        }
        .fa, .fas, .far, .fab, .fa-solid, .fa-regular, .fa-brands {
            font-family: 'Font Awesome 6 Free', 'Font Awesome 5 Free', 'FontAwesome' !important;
        }
        .main-nav { display: flex; align-items: center; justify-content: space-between; width: 100%; }
        .main-nav .nav { display:flex; justify-content:flex-end; align-items:center; list-style:none; padding:0; margin:0; gap:12px; flex: 1; flex-wrap: nowrap; }
        .main-nav .nav li { position:relative; }
        .main-nav .nav li a { color:#2a0040 !important; text-decoration:none; font-size:14px; display:flex; align-items:center; transition: all .3s; white-space: nowrap; font-weight: 600; }
        .background-header .main-nav .nav li a { color:#2a0040 !important; }
        .main-nav .nav .profile-link a { background-color: #ffe6f0 !important; padding: 6px 15px !important; border-radius: 25px !important; color: #d63384 !important; }
        .main-nav .nav li a:hover, .main-nav .nav li a.active { color:#e75485 !important; }        .background-header .main-nav .nav li a:hover, .background-header .main-nav .nav li a.active { color:#e75485 !important; }
        .main-nav .nav .profile-link img { width:30px; height:30px; border-radius:50%; margin-left:8px; }
        .dropdown { display:none; position:absolute; top:100%; left:0; min-width:220px; z-index:1000; text-align:center; padding:12px; }
        .main-nav .nav .profile-link .dropdown { left: auto !important; right: 0 !important; }
        .nav li:hover .dropdown { display:block; }
        .dropdown a { display:inline-block; margin:6px; padding:8px 20px; text-decoration:none; font-size:14px; font-weight:600; border-radius:999px; background-color:#ff66b2; color:black; transition:all .3s ease; box-shadow:0 3px 6px rgba(0,0,0,.1); }
        .dropdown a:hover { background-color:#e60073; transform:translateY(-2px); box-shadow:0 5px 10px rgba(0,0,0,.2); }
        .toast-msg { position:fixed; top:20px; right:20px; z-index:9999; padding:12px 24px; border-radius:8px; font-weight:600; animation:slideIn .4s ease; }
        .toast-success { background:linear-gradient(135deg,#10b981,#059669); color:#fff; }
        .toast-error { background:linear-gradient(135deg,#ef4444,#dc2626); color:#fff; }
        .main-nav .logo { display:flex !important; align-items:center; gap:10px; border-right:none !important; flex-basis:auto !important; margin-right:4% !important; text-decoration:none; }
        .main-nav .logo img { width:45px !important; height:45px !important; object-fit:contain; }
        .logo-text { font-family:'Inter',sans-serif !important; font-weight:900; font-size:26px; color:#e75485 !important; transition:color .3s; text-transform:uppercase; letter-spacing:1px; }
        .background-header .logo-text { color:#e75485 !important; }
        @@keyframes slideIn { from { opacity:0; transform:translateX(50px); } to { opacity:1; transform:translateX(0); } }
        .admin-section, .user-section, .wallet-section, .form-section, .parent-section, .notif-section, .lesson-section, .detail-section, .mgmt-section, .ch-section, .ai-section, .chat-section, .profile-section, .edit-section, .pwd-section, .denied-section, .result-section, .list-section, .hist-section, .sub-section, .game-dashboard, .game-play-section {
            padding-top: 120px !important;
        }

        /* Spacing overrides for student theme to prevent header overflow */
        body.student-theme .main-nav .nav {
            gap: 10px !important;
        }
        body.student-theme .main-nav .nav li a {
            font-size: 13.5px !important;
            padding: 8px 6px !important;
        }
        body.student-theme .main-nav .nav .profile-link a {
            padding: 6px 10px !important;
            gap: 6px !important;
        }
        body.student-theme .header-area .main-nav #search input {
            width: 150px !important;
        }
        body.student-theme .header-area .main-nav #search input:focus {
            width: 200px !important;
        }
        body.student-theme .logo-text {
            font-size: 20px !important;
        }
        body.student-theme .main-nav .logo img {
            width: 40px !important;
            height: 40px !important;
        }
        body.student-theme .main-nav .logo {
            margin-right: 15px !important;
        }

        /* VIP Animated Avatars Design System */
        .vip-avatar-frame {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            position: relative;
            overflow: hidden;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 4px solid rgba(255, 255, 255, 0.2);
            background: #000;
        }
        .vip-avatar-frame:hover {
            transform: scale(1.08) rotate(3deg);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
        }
        .vip-avatar-frame.mini {
            width: 32px !important;
            height: 32px !important;
            border-width: 1.5px !important;
            box-shadow: 0 3px 8px rgba(0, 0, 0, 0.15) !important;
            border-radius: 50% !important;
        }
        .vip-avatar-frame.mini:hover {
            transform: scale(1.15) !important;
        }
        
        .vip-avatar-effect-bg {
            position: absolute;
            top: -10%; left: -10%; right: -10%; bottom: -10%;
            z-index: 1;
            background-size: 200% 200%;
        }
        
        .vip-avatar-glow {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            border-radius: 50%;
            z-index: 2;
            border: 4px solid transparent;
            pointer-events: none;
        }
        .vip-avatar-frame.mini .vip-avatar-glow {
            border-width: 2px !important;
        }
        
        .vip-avatar-emoji {
            z-index: 3;
            font-size: 3rem;
            transform-origin: center;
            user-select: none;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .vip-avatar-frame.mini .vip-avatar-emoji {
            font-size: 1rem !important;
        }

        /* VIP_1: Sparkle Cadet (⭐) */
        .vip-avatar-frame.vip_1 .vip-avatar-effect-bg {
            background: linear-gradient(135deg, #1e1b4b, #312e81, #4338ca);
            animation: gradientShift 6s ease infinite;
        }
        .vip-avatar-frame.vip_1 .vip-avatar-glow {
            border-color: #fbbf24;
            box-shadow: 0 0 15px rgba(251, 191, 36, 0.7), inset 0 0 10px rgba(251, 191, 36, 0.5);
            animation: pulseGlow 2s ease-in-out infinite alternate;
        }
        .vip-avatar-frame.vip_1 .vip-avatar-emoji {
            animation: spinStar 8s linear infinite;
        }

        /* VIP_2: Aqua Explorer (🌊) */
        .vip-avatar-frame.vip_2 .vip-avatar-effect-bg {
            background: linear-gradient(180deg, #0284c7, #0369a1, #1e3a8a);
            animation: waveShift 4s ease-in-out infinite alternate;
        }
        .vip-avatar-frame.vip_2 .vip-avatar-glow {
            border-color: #38bdf8;
            box-shadow: 0 0 20px rgba(56, 189, 248, 0.6), inset 0 0 12px rgba(56, 189, 248, 0.4);
            animation: waveGlow 2.5s ease-in-out infinite alternate;
        }
        .vip-avatar-frame.vip_2 .vip-avatar-emoji {
            animation: swayWave 2.5s ease-in-out infinite alternate;
        }

        /* VIP_3: Cyber Hero (🤖) */
        .vip-avatar-frame.vip_3 .vip-avatar-effect-bg {
            background: linear-gradient(135deg, #0f172a, #1e293b, #0f172a);
            background-image: radial-gradient(rgba(6, 182, 212, 0.15) 1px, transparent 0);
            background-size: 10px 10px;
        }
        .vip-avatar-frame.vip_3 .vip-avatar-glow {
            border-color: #06b6d4;
            box-shadow: 0 0 18px rgba(6, 182, 212, 0.8), inset 0 0 8px rgba(6, 182, 212, 0.5);
            animation: cyberScan 1.8s linear infinite;
        }
        .vip-avatar-frame.vip_3 .vip-avatar-emoji {
            animation: glitchRobot 3s linear infinite;
        }

        /* VIP_4: Fire Phoenix (🔥) */
        .vip-avatar-frame.vip_4 .vip-avatar-effect-bg {
            background: linear-gradient(0deg, #991b1b, #dc2626, #ea580c);
            animation: fireShift 3s ease infinite;
        }
        .vip-avatar-frame.vip_4 .vip-avatar-glow {
            border-color: #f97316;
            box-shadow: 0 0 25px rgba(249, 115, 22, 0.85), inset 0 0 15px rgba(249, 115, 22, 0.6);
            animation: fireFlicker 0.15s ease-in-out infinite alternate;
        }
        .vip-avatar-frame.vip_4 .vip-avatar-emoji {
            animation: bounceFire 1.2s ease-in-out infinite alternate;
        }

        /* VIP_5: Cosmic Overlord (🌌) */
        .vip-avatar-frame.vip_5 .vip-avatar-effect-bg {
            background: linear-gradient(135deg, #581c87, #0f172a, #701a75, #1e1b4b);
            background-size: 300% 300%;
            animation: cosmicRotate 10s ease infinite;
        }
        .vip-avatar-frame.vip_5 .vip-avatar-glow {
            border-color: #d946ef;
            box-shadow: 0 0 30px rgba(217, 70, 239, 0.9), inset 0 0 20px rgba(217, 70, 239, 0.6);
            animation: rainbowBorder 6s linear infinite;
        }
        .vip-avatar-frame.vip_5 .vip-avatar-emoji {
            animation: swirlGalaxy 15s linear infinite;
        }

        /* Animations */
        @@keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        @@keyframes pulseGlow {
            0% { box-shadow: 0 0 10px rgba(251, 191, 36, 0.4), inset 0 0 5px rgba(251, 191, 36, 0.2); }
            100% { box-shadow: 0 0 25px rgba(251, 191, 36, 0.9), inset 0 0 15px rgba(251, 191, 36, 0.7); }
        }
        @@keyframes spinStar {
            0% { transform: rotate(0deg) scale(0.95); }
            50% { transform: rotate(180deg) scale(1.05); }
            100% { transform: rotate(360deg) scale(0.95); }
        }
        @@keyframes waveShift {
            0% { transform: translateY(0) scale(1); }
            100% { transform: translateY(-5px) scale(1.05); }
        }
        @@keyframes waveGlow {
            0% { border-color: #0284c7; box-shadow: 0 0 10px rgba(2, 132, 199, 0.4); }
            100% { border-color: #38bdf8; box-shadow: 0 0 25px rgba(56, 189, 248, 0.8); }
        }
        @@keyframes swayWave {
            0% { transform: rotate(-8deg) translateX(-2px); }
            100% { transform: rotate(8deg) translateX(2px); }
        }
        @@keyframes cyberScan {
            0% { border-color: #0891b2; box-shadow: 0 0 10px rgba(8, 145, 178, 0.4); }
            50% { border-color: #22d3ee; box-shadow: 0 0 22px rgba(34, 211, 238, 0.9); }
            100% { border-color: #0891b2; box-shadow: 0 0 10px rgba(8, 145, 178, 0.4); }
        }
        @@keyframes glitchRobot {
            0%, 90%, 100% { transform: translate(0) scale(1); }
            92% { transform: translate(-3px, 2px) skewX(5deg); }
            94% { transform: translate(3px, -2px) skewX(-5deg); }
            96% { transform: translate(-2px, -2px) scale(1.05); }
            98% { transform: translate(2px, 1px) scale(0.95); }
        }
        @@keyframes fireShift {
            0% { background-position: 50% 0%; }
            50% { background-position: 50% 100%; }
            100% { background-position: 50% 0%; }
        }
        @@keyframes fireFlicker {
            0% { opacity: 0.85; box-shadow: 0 0 15px rgba(249, 115, 22, 0.6); }
            100% { opacity: 1; box-shadow: 0 0 28px rgba(249, 115, 22, 0.95); }
        }
        @@keyframes bounceFire {
            0% { transform: translateY(3px) scaleY(0.92); }
            100% { transform: translateY(-5px) scaleY(1.08); }
        }
        @@keyframes cosmicRotate {
            0% { background-position: 0% 0%; }
            50% { background-position: 100% 100%; }
            100% { background-position: 0% 0%; }
        }
        @@keyframes rainbowBorder {
            0% { border-color: #d946ef; box-shadow: 0 0 20px rgba(217, 70, 239, 0.7); }
            33% { border-color: #6366f1; box-shadow: 0 0 20px rgba(99, 102, 241, 0.7); }
            66% { border-color: #06b6d4; box-shadow: 0 0 20px rgba(6, 182, 212, 0.7); }
            100% { border-color: #d946ef; box-shadow: 0 0 20px rgba(217, 70, 239, 0.7); }
        }
        @@keyframes swirlGalaxy {
            0% { transform: rotate(0deg) scale(0.95); }
            50% { transform: rotate(180deg) scale(1.05); }
            100% { transform: rotate(360deg) scale(0.95); }
        }

        /* Student Role Bright Kid Theme Override Rules */
        body.student-theme {
            background: linear-gradient(135deg, #e0f2fe 0%, #faf5ff 50%, #fdf2f8 100%) !important;
            color: #1e1b4b !important;
        }

        /* Kid-friendly floating background decorations */
        .kid-floating-decor {
            position: fixed;
            z-index: 1;
            pointer-events: none;
            user-select: none;
            opacity: 0.38;
            transition: opacity 0.3s;
            filter: drop-shadow(0 8px 15px rgba(0,0,0,0.06));
        }
        
        @@keyframes floatBob {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-25px) rotate(12deg) scale(1.05); }
            100% { transform: translateY(0px) rotate(0deg); }
        }
        
        @@keyframes floatSway {
            0% { transform: translate(0, 0) rotate(0deg); }
            50% { transform: translate(20px, -20px) rotate(-15deg) scale(1.1); }
            100% { transform: translate(0, 0) rotate(0deg); }
        }

        @@keyframes floatSpin {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(180deg) scale(1.08); }
            100% { transform: translateY(0px) rotate(360deg); }
        }

        .kid-floating-decor.decor-1 { font-size: 3.8rem; top: 12%; left: 2%; animation: floatBob 7s ease-in-out infinite; }
        .kid-floating-decor.decor-2 { font-size: 3.2rem; bottom: 12%; left: 3%; animation: floatSway 9s ease-in-out infinite; }
        .kid-floating-decor.decor-3 { font-size: 3.5rem; top: 22%; right: 3%; animation: floatBob 8s ease-in-out infinite; }
        .kid-floating-decor.decor-4 { font-size: 3rem; bottom: 22%; right: 2%; animation: floatSway 10s ease-in-out infinite; }
        .kid-floating-decor.decor-5 { font-size: 3.6rem; top: 58%; left: 1%; animation: floatSpin 15s linear infinite; }
        .kid-floating-decor.decor-6 { font-size: 4.2rem; top: 72%; right: 1%; animation: floatBob 9s ease-in-out infinite; }
        .kid-floating-decor.decor-7 { font-size: 2.8rem; top: 6%; right: 18%; animation: floatSway 7s ease-in-out infinite; }

