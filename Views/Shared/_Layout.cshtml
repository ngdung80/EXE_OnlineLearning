        }

        body.student-theme .pwd-card .req-ok {
            color: #10b981 !important;
        }

        body.student-theme .btn-save {
            padding: 12px 30px !important;
            background: linear-gradient(135deg, #ec6090, #e75485) !important;
            color: #fff !important;
            border: none !important;
            border-radius: 25px !important;
            font-weight: 800 !important;
            cursor: pointer !important;
            transition: all .3s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
            box-shadow: 0 5px 15px rgba(236, 96, 144, 0.2) !important;
            display: inline-block !important;
        }

        body.student-theme .btn-save:hover {
            transform: translateY(-2px) scale(1.03) !important;
            box-shadow: 0 8px 20px rgba(236, 96, 144, 0.4) !important;
        }

        body.student-theme .btn-cancel {
            padding: 12px 30px !important;
            background: transparent !important;
            color: #ec6090 !important;
            border: 2px solid #ec6090 !important;
            border-radius: 25px !important;
            text-decoration: none !important;
            font-weight: 800 !important;
            display: inline-block !important;
            text-align: center !important;
            transition: all .3s !important;
        }

        body.student-theme .btn-cancel:hover {
            background: #ec6090 !important;
            color: #fff !important;
            transform: translateY(-2px) !important;
        }

        body.student-theme .btn-edit {
            background: linear-gradient(135deg, #ec6090, #e75485) !important;
            color: #fff !important;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
        }
        body.student-theme .btn-edit:hover {
            color: #fff !important;
            box-shadow: 0 8px 20px rgba(236, 96, 144, 0.4) !important;
        }
        body.student-theme .btn-pwd {
            background: transparent !important;
            color: #ec6090 !important;
            border: 2px solid #ec6090 !important;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
        }
        body.student-theme .btn-pwd:hover {
            background: #ec6090 !important;
            color: #fff !important;
            box-shadow: 0 8px 20px rgba(236, 96, 144, 0.2) !important;
        }

        /* Locked lesson cards */
        body.student-theme .lesson-card-item.locked {
            background: rgba(241, 245, 249, 0.7) !important;
            border-color: #cbd5e1 !important;
            opacity: 0.8 !important;
        }

        /* Completed lesson cards */
        body.student-theme .lesson-card-item.completed {
            background: #f0fdf4 !important;
            border-color: #86efac !important;
        }

        /* Text colors in cards */
        body.student-theme .step-title,
        body.student-theme .item-title,
        body.student-theme .list-item-title,
        body.student-theme .lesson-card-name,
        body.student-theme .test-name,
        body.student-theme .q-txt,
        body.student-theme .chat-header h2,
        body.student-theme .page-title {
            color: #1e1b4b !important;
            font-weight: 800 !important;
        }

        body.student-theme .page-title i {
            color: #ec6090 !important;
        }

        body.student-theme .page-subtitle,
        body.student-theme .lesson-card-desc,
        body.student-theme .test-meta,
        body.student-theme .list-item-meta,
        body.student-theme .chat-header p,
        body.student-theme .welcome-msg p {
            color: #4f46e5 !important;
            opacity: 0.85 !important;
        }

        /* Step numbers */
        body.student-theme .step-num {
            background: linear-gradient(135deg, #ec6090, #e75485) !important;
            color: #ffffff !important;
            box-shadow: 0 4px 10px rgba(236, 96, 144, 0.3) !important;
        }

        /* Bouncy transitions & Hover */
        body.student-theme .item-card, 
        body.student-theme .list-item, 
        body.student-theme .lesson-card-item:not(.locked), 
        body.student-theme .btn-send, 
        body.student-theme .btn-start-practice, 
        body.student-theme .quick-btn,
        body.student-theme .test-card,
        body.student-theme .btn-take,
        body.student-theme .btn-back,
        body.student-theme .btn-filter,
        body.student-theme .btn-view {
            transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.25s, box-shadow 0.25s, background-color 0.25s !important;
        }

        body.student-theme .item-card:hover, 
        body.student-theme .list-item:hover, 
        body.student-theme .lesson-card-item.completed:hover,
        body.student-theme .test-card:hover {
            transform: translateY(-6px) scale(1.02) !important;
            border-color: #c084fc !important;
            box-shadow: 0 15px 30px rgba(168, 85, 247, 0.15) !important;
            background: #ffffff !important;
        }

        /* Active states */
        body.student-theme .item-card.active,
        body.student-theme .list-item.active {
            border-color: #a855f7 !important;
            background: #faf5ff !important;
            box-shadow: 0 10px 25px rgba(168, 85, 247, 0.15) !important;
        }

        /* Pulse animation for active card */
        @@keyframes softPulse {
            0% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.4); }
            70% { box-shadow: 0 0 0 8px rgba(168, 85, 247, 0); }
            100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0); }
        }
        body.student-theme .item-card.active {
            animation: softPulse 2s infinite !important;
        }

        /* Icons in cards */
        body.student-theme .item-card i {
            color: #ec6090 !important;
        }

        body.student-theme .item-card.active i {
            color: #a855f7 !important;
        }

        /* Table */
        body.student-theme .table {
            color: #1e1b4b !important;
        }
        body.student-theme .table thead th {
            background: rgba(236, 96, 144, 0.08) !important;
            color: #ec6090 !important;
            font-weight: 700 !important;
        }
        body.student-theme .table tbody tr {
            border-bottom: 1px solid #e2e8f0 !important;
        }
        body.student-theme .table tbody tr:hover {
            background: #faf5ff !important;
        }
        body.student-theme .table tbody td {
            color: #1e1b4b !important;
        }

        /* Score badges */
        body.student-theme .score-badge {
            font-weight: 700 !important;
        }
        body.student-theme .score-high {
            background: #d1fae5 !important;
            color: #065f46 !important;
        }
        body.student-theme .score-mid {
            background: #fef9c3 !important;
            color: #854d0e !important;
        }
        body.student-theme .score-low {
            background: #fee2e2 !important;
            color: #991b1b !important;
        }

        /* Buttons styling */
        body.student-theme .btn-start-practice,
        body.student-theme .btn-take,
        body.student-theme .btn-back,
        body.student-theme .btn-send,
        body.student-theme .btn-filter {
            background: linear-gradient(135deg, #ec6090, #e75485) !important;
            color: #ffffff !important;
            border: none !important;
            border-radius: 99px !important;
            font-weight: 700 !important;
            box-shadow: 0 5px 15px rgba(236, 96, 144, 0.2) !important;
        }

        body.student-theme .btn-start-practice:hover,
        body.student-theme .btn-take:hover,
        body.student-theme .btn-back:hover,
        body.student-theme .btn-send:hover,
        body.student-theme .btn-filter:hover {
            transform: translateY(-3px) scale(1.03) !important;
            box-shadow: 0 8px 25px rgba(236, 96, 144, 0.35) !important;
            color: #ffffff !important;
        }

        body.student-theme .btn-view {
            background: rgba(99, 102, 241, 0.1) !important;
            color: #4f46e5 !important;
            border-radius: 99px !important;
        }
        body.student-theme .btn-view:hover {
            background: #4f46e5 !important;
            color: #ffffff !important;
            transform: translateY(-2px) !important;
        }

        /* Chat view overrides */
        body.student-theme .bubble.ai {
            background: #e0f2fe !important;
            color: #0369a1 !important;
            border: 1px solid #bae6fd !important;
            border-radius: 4px 16px 16px 16px !important;
        }
        body.student-theme .bubble.user {
            background: linear-gradient(135deg, #ec6090, #e75485) !important;
            color: #ffffff !important;
            border-radius: 16px 4px 16px 16px !important;
        }
        body.student-theme .avatar.ai {
            background: linear-gradient(135deg, #0284c7, #0369a1) !important;
        }
        body.student-theme .quick-btn {
            background: rgba(236, 96, 144, 0.08) !important;
            border: 2px solid rgba(236, 96, 144, 0.2) !important;
            color: #ec6090 !important;
            font-weight: 700 !important;
        }
        body.student-theme .quick-btn:hover {
            background: #ec6090 !important;
            color: #ffffff !important;
            transform: translateY(-3px) scale(1.02) !important;
        }
        body.student-theme .chat-input-wrap textarea {
            background: #ffffff !important;
            border: 2px solid #ddd6fe !important;
            color: #1e1b4b !important;
        }
        body.student-theme .chat-input-wrap textarea:focus {
            border-color: #ec6090 !important;
        }
        body.student-theme .typing {
            background: rgba(255, 255, 255, 0.8) !important;
            border: 1px solid #ddd6fe !important;
        }

        /* Filters */
        body.student-theme .filter-select {
            background: #ffffff !important;
            border: 2px solid #e0e7ff !important;
            color: #1e1b4b !important;
        }
        body.student-theme .filter-select option {
            background: #ffffff !important;
            color: #1e1b4b !important;
        }

        /* Global back button */
        .btn-global-back {
            position: fixed;
            top: 110px;
            left: 30px;
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: 30px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.25);
            color: #ffffff !important;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease, background-color 0.3s, border-color 0.3s !important;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
            text-decoration: none !important;
            opacity: 1;
            transform: translateX(0);
        }
        .btn-global-back.btn-back-hidden {
            transform: translateX(-150px) !important;
            opacity: 0 !important;
            pointer-events: none !important;
        }
        .btn-global-back:not(.btn-back-hidden):hover {
            transform: translateY(-2px) scale(1.05) !important;
            background: #ffffff;
            color: #1e1b4b !important;
            box-shadow: 0 8px 25px rgba(255, 255, 255, 0.25);
        }

        /* Student theme overrides */
        body.student-theme .btn-global-back {
            background: rgba(255, 255, 255, 0.9) !important;
            border: 3px solid #fbcfe8 !important;
            color: #ec6090 !important;
            font-family: 'Nunito', sans-serif !important;
            font-weight: 900 !important;
            box-shadow: 0 8px 20px rgba(236, 96, 144, 0.12) !important;
        }
        body.student-theme .btn-global-back:not(.btn-back-hidden):hover {
            background: #ec6090 !important;
            border-color: #ec6090 !important;
            color: #ffffff !important;
            box-shadow: 0 10px 25px rgba(236, 96, 144, 0.3) !important;
            transform: translateY(-3px) scale(1.05) !important;
        }

        @@media (max-width: 991px) {
            .btn-global-back {
                top: 90px;
                left: 15px;
                padding: 8px 14px;
                font-size: 0.8rem;
            }
        }
        @@media (max-width: 576px) {
            .btn-global-back {
                top: 85px;
                left: 10px;
                padding: 8px 10px;
            }
            .btn-global-back span {
                display: none;
            }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="@(User.IsInRole("Student") ? "student-theme" : "")">
    @if (User.IsInRole("Student"))
    {
        <div class="kid-floating-decor decor-1" title="Bong bóng bay">🎈</div>
        <div class="kid-floating-decor decor-2" title="Gấu Teddy">🧸</div>
        <div class="kid-floating-decor decor-3" title="Kỳ lân">🦄</div>
        <div class="kid-floating-decor decor-4" title="Chú ong">🐝</div>
        <div class="kid-floating-decor decor-5" title="Tên lửa">🚀</div>
        <div class="kid-floating-decor decor-6" title="Cầu vồng">🌈</div>
        <div class="kid-floating-decor decor-7" title="Nhạc cụ">🎨</div>
    }
    <header class="header-area header-sticky">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <nav class="main-nav">
                        <a asp-controller="Home" asp-action="Index" class="logo">
                            <img src="~/assets/images/logo.png" asp-append-version="true" alt="PLO Logo">
                            <span class="logo-text">PLO</span>
                        </a>
                        @if (!User.IsInRole("Admin") && !User.IsInRole("Content Manager") && !User.IsInRole("Content Approver") && !User.IsInRole("Student"))
                        {
                            <div class="search-input">
                                <form id="search" action="#">
                                    <input type="text" placeholder="Tìm kiếm bài học..." id="searchText" name="searchKeyword"/>
                                    <i class="fa fa-search"></i>
                                </form>
                            </div>
                        }
                        @{
                            var activeCtrl = ViewContext.RouteData.Values["controller"]?.ToString();
                            var activeAct = ViewContext.RouteData.Values["action"]?.ToString();
                            
                            bool isHomeActive = activeCtrl == "Home" && activeAct == "Index";
                            bool isGradeActive = activeCtrl == "Grade" || activeCtrl == "Subject" || activeCtrl == "Chapter" || activeCtrl == "Lesson";
                            bool isAIActive = activeCtrl == "AI";
                            bool isPracticeActive = activeCtrl == "Test" && activeAct == "Practice";
                            bool isHistoryActive = activeCtrl == "Test" && activeAct == "History";
                            bool isPackageListActive = activeCtrl == "Package" && activeAct == "List";
                            
                            // Admin links
                            bool isRevenueActive = activeCtrl == "Revenue";
                            bool isTransactionActive = activeCtrl == "Transaction";
                            bool isUserActive = activeCtrl == "User";
                            bool isPackageManageActive = activeCtrl == "Package" && activeAct != "List";
                        }
                        <ul class="nav">
                            <li><a asp-controller="Home" asp-action="Index" class="@(isHomeActive ? "active" : "")">Trang chủ</a></li>
                            @if (!User.IsInRole("Parent"))
                            {
                                <li><a href="/Grade" class="@(isGradeActive ? "active" : "")">Khối lớp</a></li>
                            }

                            @if (!User.Identity!.IsAuthenticated || User.IsInRole("Parent"))
                            {
                                <li><a asp-controller="Package" asp-action="List" class="@(isPackageListActive ? "active" : "")">Gói học</a></li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li><a href="/Revenue" class="@(isRevenueActive ? "active" : "")">Quản lý thu nhập</a></li>
                                <li><a href="/Transaction" class="@(isTransactionActive ? "active" : "")">Quản lý giao dịch</a></li>
                                <li><a href="/User" class="@(isUserActive ? "active" : "")">Quản lý người dùng</a></li>
                                <li><a href="/Package" class="@(isPackageManageActive ? "active" : "")">Quản lý gói học</a></li>
                            }

                            @if (User.IsInRole("Content Manager"))
                            {
                                <li><a href="/QuestionReport">Báo cáo câu hỏi</a></li>
                                <li><a href="/Question">Ngân hàng câu hỏi</a></li>
                            }
                            @if (User.IsInRole("Content Approver"))
                            {
                                <li><a href="/QuestionReport">Duyệt báo cáo</a></li>
                                <li><a href="/Question">Danh sách câu hỏi</a></li>
                            }

                            @if (User.Identity.IsAuthenticated)
                            {
                                <li><a href="/Certificate" class="@(activeCtrl == "Certificate" ? "active" : "")">Chứng chỉ</a></li>
                                 @if (User.IsInRole("Parent"))
                                 {
                                     <li><a asp-controller="Parent" asp-action="LinkedStudents" class="@(activeCtrl == "Parent" && activeAct == "LinkedStudents" ? "active" : "")">Học sinh liên kết</a></li>
                                     <li><a asp-controller="Wallet" asp-action="Index" class="@(activeCtrl == "Wallet" ? "active" : "")">Ví: @Context.Session.GetString("WalletBalance") đ</a></li>
                                 }
                                @if (User.IsInRole("Student"))
                                {
                                    <li><a asp-controller="AI" asp-action="Chat" class="@(isAIActive ? "active" : "")">Trợ lý AI</a></li>
                                    <li><a asp-controller="Test" asp-action="Practice" class="@(isPracticeActive ? "active" : "")">Luyện tập</a></li>
                                    <li><a asp-controller="Game" asp-action="Index" class="@(activeCtrl == "Game" ? "active" : "")"><i class="fa fa-gamepad" style="margin-right: 5px;"></i> Trò chơi</a></li>
                                    <li><a asp-controller="Test" asp-action="History" class="@(isHistoryActive ? "active" : "")">Lịch sử làm bài</a></li>
                                    <li><a asp-controller="Account" asp-action="AvatarShop" class="@(activeCtrl == "Account" && activeAct == "AvatarShop" ? "active" : "")"><i class="fa fa-shopping-cart" style="margin-right: 5px;"></i> Cửa hàng sao</a></li>
                                }
                                <li class="profile-link">
                                    <a asp-controller="Account" asp-action="Profile" style="display: flex; align-items: center; gap: 8px;">
                                        <span>@User.FindFirst("FullName")?.Value</span>
                                        @if (User.IsInRole("Student"))
                                        {
                                            <span style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white; padding: 3px 8px; border-radius: 12px; font-size: 0.72rem; font-weight: 800; display: inline-flex; align-items: center; gap: 3px; box-shadow: 0 2px 6px rgba(245, 158, 11, 0.3); border: 1px solid rgba(255, 255, 255, 0.4);"><i class="fas fa-star" style="color: white !important;"></i> @(Context.Session.GetString("StudentStars") ?? "0")</span>
                                        }
                                        
                                        @{
                                            var layoutUserImage = User.FindFirst("Image")?.Value;
                                            if (layoutUserImage != null && layoutUserImage.StartsWith("VIP_"))
                                            {
                                                <div class="vip-avatar-frame mini @layoutUserImage.ToLower()" title="Avatar VIP">
                                                    <div class="vip-avatar-effect-bg"></div>
                                                    <div class="vip-avatar-glow"></div>
                                                    <div class="vip-avatar-emoji">
                                                        @(layoutUserImage == "VIP_1" ? "⭐" : layoutUserImage == "VIP_2" ? "🌊" : layoutUserImage == "VIP_3" ? "🤖" : layoutUserImage == "VIP_4" ? "🔥" : "🌌")
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <img src="@(layoutUserImage ?? "/assets/images/profile-header.jpg")" alt="" onerror="this.src='/assets/images/profile-header.jpg'" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;">
                                            }
                                        }
                                    </a>
                                    <div class="dropdown">
                                        <a asp-controller="Account" asp-action="Profile" style="color:#f6f6f6!important;">Hồ sơ</a>
                                        <a asp-controller="Account" asp-action="ChangePassword" style="color:#f6f6f6!important;">Đổi mật khẩu</a>
                                        <a asp-controller="Account" asp-action="Logout" style="color:#f6f6f6!important;">Đăng xuất</a>
                                    </div>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <a asp-controller="Account" asp-action="Login"
                                       style="display:inline-block;background-color:#e75485;color:white;padding:10px 20px;border-radius:25px;text-decoration:none;font-weight:500;">
                                        Đăng ký / Đăng nhập
                                    </a>
                                </li>
                            }
                        </ul>
                        <a class="menu-trigger"><span>Menu</span></a>
                    </nav>
                </div>
            </div>
        </div>
    </header>

    @* Toast notifications *@
    @if (TempData["Success"] != null)
    {
        <div class="toast-msg toast-success" id="toastMsg">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-msg toast-error" id="toastMsg">@TempData["Error"]</div>
    }

    @if (!(activeCtrl == "Home" && activeAct == "Index"))
    {
        <button onclick="goBackOrHome()" class="btn-global-back" title="Quay lại">
            <i class="fa fa-arrow-left"></i> <span>Quay lại</span>
        </button>
    }

    <main style="display: flow-root;">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div class="under-footer" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
                        <p>Bản quyền &copy; @DateTime.Now.Year Nền tảng học tập PLO. Bảo lưu mọi quyền.</p>
                        @if (!User.Identity!.IsAuthenticated || User.IsInRole("Admin"))
                        {
                            <a href="/Account/LoginAdmin" style="color:#475569;font-size:.75rem;text-decoration:none;">🛡️ Trang Admin</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.min.js"></script>
    <script src="~/assets/js/owl-carousel.js"></script>
    <script src="~/assets/js/animation.js"></script>
    <script src="~/assets/js/imagesloaded.js"></script>
    <script src="~/assets/js/custom.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Auto-hide toast
            const toast = document.getElementById('toastMsg');
            if (toast) setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity .5s'; setTimeout(() => toast.remove(), 500); }, 3500);

            // Dynamic active nav link
            const currentPath = window.location.pathname.toLowerCase();
            const navLinks = document.querySelectorAll('.main-nav .nav a');
            
            navLinks.forEach(link => link.classList.remove('active'));
            
            let activeLink = null;
            
            // Try to find a link that exactly matches the current path
            navLinks.forEach(link => {
                const href = link.getAttribute('href');
                if (!href || href === '#') return;
                
                try {
                    const url = new URL(href, window.location.origin);
                    if (url.pathname.toLowerCase() === currentPath) {
                        activeLink = link;
                    }
                } catch (e) {
                    if (href.toLowerCase() === currentPath) {
                        activeLink = link;
                    }
                }
            });
            
            // If no exact match, look for prefix matching (e.g. /Grade/Index matches /Grade)
            if (!activeLink) {
                let bestMatchLength = 0;
                navLinks.forEach(link => {
                    const href = link.getAttribute('href');
                    if (!href || href === '#' || href === '/') return;
                    
                    let linkPath = '';
                    try {
                        linkPath = new URL(href, window.location.origin).pathname.toLowerCase();
                    } catch (e) {
                        linkPath = href.toLowerCase();
                    }
                    
                    if (currentPath.startsWith(linkPath) && linkPath.length > bestMatchLength) {
                        activeLink = link;
                        bestMatchLength = linkPath.length;
                    }
                });
            }
            
            // Fallback to "Trang chủ" if we are on the root path
            if (!activeLink && (currentPath === '/' || currentPath === '/home' || currentPath === '/home/index')) {
                navLinks.forEach(link => {
                    const text = link.textContent.trim().toLowerCase();
                    if (text === 'trang chủ') activeLink = link;
                });
            }
            
            if (activeLink) {
                activeLink.classList.add('active');
                
                // Highlight dropdown parent if active link is inside a dropdown
                const dropdownParent = activeLink.closest('li')?.querySelector('a:first-child');
                if (dropdownParent && dropdownParent !== activeLink) {
                    dropdownParent.classList.add('active');
                }
            }
        });

        // Global smart back function
        function goBackOrHome() {
            if (document.referrer && document.referrer.includes(window.location.host)) {
                window.history.back();
            } else {
                window.location.href = '/';
            }
        }

        // Hide back button on scroll down, show on scroll up
        document.addEventListener('DOMContentLoaded', function () {
            let lastScrollTop = 0;
            const backBtn = document.querySelector('.btn-global-back');
            if (backBtn) {
                window.addEventListener('scroll', function () {
                    let scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                    if (scrollTop > lastScrollTop && scrollTop > 50) {
                        // Scroll Down
                        backBtn.classList.add('btn-back-hidden');
                    } else {
                        // Scroll Up
                        backBtn.classList.remove('btn-back-hidden');
                    }
                    lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
                }, { passive: true });
            }
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
